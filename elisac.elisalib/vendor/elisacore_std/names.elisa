extern Name

type NameId = id[Name]


def __cast__(value: u32) -> NameId:
    return value.cast[NameId]


global NAME_TABLE_INVALID_ID: NameId = 0.u32().NameId()
const NAME_TABLE_INITIAL_BUCKETS: usize = 16


const enum NameCasePolicy of i8:
    CaseSensitive = 0
    AsciiCaseInsensitive = 1


struct NameEntry:
    text: sview
    owned_text: darray[u8]
    hash: u64
    original_hash: u64


struct NameBucket:
    name_id: mutable NameId


struct NameTable:
    owner: mutable Arena&
    entries: mutable darray[NameEntry]
    buckets: mutable darray[NameBucket]


struct InternedName:
    table: NameTable&
    id: NameId


def __cast__(name: InternedName) -> NameId:
    return name.id


def name_table_init(owner: mutable Arena&) -> NameTable:
    return NameTable{owner: owner, entries: [], buckets: []}


def name_cstr_view(text: cstr) -> sview:
    return text[0:text.len]


def name_ascii_lower(ch: char) -> char:
    (ch.i64() + 32).char() return if ch >= 'A' and ch <= 'Z'
    return ch


def name_table_hash_step(hash: u64, ch: char) -> u64:
    next: mutable u64 = hash
    next <- next ^ ch.u64()
    next <- next * 1099511628211
    return next


def name_text_hash(text: sview, policy: NameCasePolicy) -> u64:
    hash: mutable u64 = 1469598103934665603
    index: mutable i64 = 0
    while index < text.len:
        ch: mutable char = text.data[index.usize()].char()
        if policy == NameCasePolicy.AsciiCaseInsensitive:
            ch <- name_ascii_lower(ch)
        hash <- name_table_hash_step(hash, ch)
        index <- index + 1
    return hash


def name_text_eq(left: sview, right: sview, policy: NameCasePolicy) -> bool:
    false return if left.len != right.len
    index: mutable i64 = 0
    while index < left.len:
        left_ch: mutable char = left.data[index.usize()].char()
        right_ch: mutable char = right.data[index.usize()].char()
        if policy == NameCasePolicy.AsciiCaseInsensitive:
            left_ch <- name_ascii_lower(left_ch)
            right_ch <- name_ascii_lower(right_ch)
        false return if left_ch != right_ch
        index <- index + 1
    return true


def name_table_valid_id(table: NameTable&, name_id: NameId) -> bool:
    false return if name_id == NAME_TABLE_INVALID_ID
    return (!name_id).usize() <= table.entries.count


def name_table_entry(table: NameTable&, name_id: NameId) -> NameEntry:
    assert name_table_valid_id(table, name_id)
    return table.entries[(!name_id).usize() - 1]


def name_table_text(table: NameTable&, name_id: NameId) -> sview:
    if not name_table_valid_id(table, name_id):
        return ("".cast[cstr])[0:0]
    return table.entries[(!name_id).usize() - 1].text


def valid_id(table: NameTable&, name_id: NameId) -> bool:
    return name_table_valid_id(table, name_id)


def text(table: NameTable&, name_id: NameId) -> sview:
    return name_table_text(table, name_id)


def interned(table: NameTable&, name_id: NameId) -> InternedName:
    return InternedName{table: table, id: name_id}


def valid(name_id: NameId) -> bool:
    return name_id != NAME_TABLE_INVALID_ID


def invalid(name_id: NameId) -> bool:
    return name_id == NAME_TABLE_INVALID_ID


def text(name_id: NameId, table: NameTable&) -> sview:
    return table.text(name_id)


def matches_view(name_id: NameId, table: NameTable&, text: sview, policy: NameCasePolicy) -> bool:
    return table.has_text_view(name_id, text, policy)


def matches(name_id: NameId, table: NameTable&, text: cstr, policy: NameCasePolicy) -> bool:
    return name_id.matches_view(table, name_cstr_view(text), policy)


def matches_cs(name_id: NameId, table: NameTable&, text: cstr) -> bool:
    return name_id.matches(table, text, NameCasePolicy.CaseSensitive)


def matches_ci(name_id: NameId, table: NameTable&, text: cstr) -> bool:
    return name_id.matches(table, text, NameCasePolicy.AsciiCaseInsensitive)


def valid(name: InternedName) -> bool:
    return name.table.valid_id(name.id)


def value(name: InternedName) -> NameId:
    return name.id


def text(name: InternedName) -> sview:
    return name.table.text(name.id)


def matches_view(name: InternedName, text: sview, policy: NameCasePolicy) -> bool:
    return name.table.has_text_view(name.id, text, policy)


def matches(name: InternedName, text: cstr, policy: NameCasePolicy) -> bool:
    return name.matches_view(name_cstr_view(text), policy)


def matches_cs(name: InternedName, text: cstr) -> bool:
    return name.matches(text, NameCasePolicy.CaseSensitive)


def matches_ci(name: InternedName, text: cstr) -> bool:
    return name.matches(text, NameCasePolicy.AsciiCaseInsensitive)


def name_table_eq(left: NameId, right: NameId) -> bool:
    return left == right and left != NAME_TABLE_INVALID_ID


def name_table_bucket_capacity_for_count(count: usize) -> usize:
    capacity: mutable usize = NAME_TABLE_INITIAL_BUCKETS
    target: usize = count * 2 + 1
    while capacity < target:
        capacity <- capacity * 2
    return capacity


def name_table_bucket_index(hash: u64, capacity: usize) -> usize:
    return (hash & (capacity - 1).u64()).usize()


def name_table_insert_existing_bucket(table: mutable NameTable&, name_id: NameId) -> void:
    if table.buckets.count == 0:
        return
    entry: NameEntry = name_table_entry(table, name_id)
    index: mutable usize = name_table_bucket_index(entry.hash, table.buckets.count)
    while table.buckets[index].name_id != NAME_TABLE_INVALID_ID:
        index <- (index + 1) & (table.buckets.count - 1)
    table.buckets[index].name_id <- name_id


def name_table_rebuild_buckets(table: mutable NameTable&, capacity: usize) -> void:
    can Memory.Allocate, Abort.Panic:
        in table.owner:
            table.buckets <- []
            for _ in 0..<capacity:
                table.buckets.push(NameBucket{name_id: NAME_TABLE_INVALID_ID})
            for index in 0..<table.entries.count:
                table.name_table_insert_existing_bucket((index + 1).u32().NameId())


def name_table_ensure_capacity(table: mutable NameTable&, next_count: usize) -> void:
    can Memory.Allocate, Abort.Panic:
        if table.buckets.count != 0 and next_count * 2 < table.buckets.count:
            return
        capacity: usize = name_table_bucket_capacity_for_count(next_count)
        table.name_table_rebuild_buckets(capacity)


def name_table_find(table: NameTable&, text: sview, hash: u64, policy: NameCasePolicy) -> NameId:
    NAME_TABLE_INVALID_ID return if table.buckets.count == 0
    index: mutable usize = name_table_bucket_index(hash, table.buckets.count)
    checked: mutable usize = 0
    while checked < table.buckets.count:
        name_id: NameId = table.buckets[index].name_id
        NAME_TABLE_INVALID_ID return if name_id == NAME_TABLE_INVALID_ID
        entry: NameEntry = name_table_entry(table, name_id)
        name_id return if entry.hash == hash and name_text_eq(entry.text, text, policy)
        index <- (index + 1) & (table.buckets.count - 1)
        checked <- checked + 1
    return NAME_TABLE_INVALID_ID


def name_table_intern_view(table: mutable NameTable&, text: sview, policy: NameCasePolicy) -> NameId:
    can Memory.Allocate, Abort.Panic:
        hash: u64 = name_text_hash(text, policy)
        existing: NameId = table.name_table_find(text, hash, policy)
        existing return if existing != NAME_TABLE_INVALID_ID
        table.name_table_ensure_capacity(table.entries.count + 1)
        in table.owner:
            original_hash: u64 = name_text_hash(text, NameCasePolicy.CaseSensitive)
            table.entries.push(NameEntry{text: text, owned_text: [], hash: hash, original_hash: original_hash})
            name_id: NameId = table.entries.count.u32().NameId()
            table.name_table_insert_existing_bucket(name_id)
            return name_id


def intern_view(table: mutable NameTable&, text: sview, policy: NameCasePolicy) -> NameId:
    can Memory.Allocate, Abort.Panic:
        return name_table_intern_view(table, text, policy)


def name_table_intern_copy(table: mutable NameTable&, text: sview, policy: NameCasePolicy) -> NameId:
    can Memory.Allocate, Abort.Panic:
        hash: u64 = name_text_hash(text, policy)
        existing: NameId = table.name_table_find(text, hash, policy)
        existing return if existing != NAME_TABLE_INVALID_ID
        table.name_table_ensure_capacity(table.entries.count + 1)
        in table.owner:
            original_hash: u64 = name_text_hash(text, NameCasePolicy.CaseSensitive)
            owned_text: mutable darray[u8] = []
            index: mutable i64 = 0
            while index < text.len:
                owned_text.push(text.data[index.usize()])
                index <- index + 1
            owned_text.push(0)
            stable_text: sview = owned_text.items.cast[cstr][0:text.len]
            table.entries.push(NameEntry{text: stable_text, owned_text: owned_text, hash: hash, original_hash: original_hash})
            name_id: NameId = table.entries.count.u32().NameId()
            table.name_table_insert_existing_bucket(name_id)
            return name_id


def intern_copy(table: mutable NameTable&, text: sview, policy: NameCasePolicy) -> NameId:
    can Memory.Allocate, Abort.Panic:
        return name_table_intern_copy(table, text, policy)


def name_table_intern(table: mutable NameTable&, text: sview, policy: NameCasePolicy) -> NameId:
    can Memory.Allocate, Abort.Panic:
        return table.name_table_intern_copy(text, policy)


def intern(table: mutable NameTable&, text: cstr, policy: NameCasePolicy) -> NameId:
    can Memory.Allocate, Abort.Panic:
        return name_table_intern(table, name_cstr_view(text), policy)


def intern_ci(table: mutable NameTable&, text: cstr) -> NameId:
    can Memory.Allocate, Abort.Panic:
        return name_table_intern(table, name_cstr_view(text), NameCasePolicy.AsciiCaseInsensitive)


def has_text_view(table: NameTable&, name_id: NameId, text: sview, policy: NameCasePolicy) -> bool:
    false return if not name_table_valid_id(table, name_id)
    entry: NameEntry = name_table_entry(table, name_id)
    return name_text_eq(entry.text, text, policy)


def has_text(table: NameTable&, name_id: NameId, text: cstr, policy: NameCasePolicy) -> bool:
    return table.has_text_view(name_id, name_cstr_view(text), policy)


def has_text_cs(table: NameTable&, name_id: NameId, text: cstr) -> bool:
    return table.has_text(name_id, text, NameCasePolicy.CaseSensitive)


def has_text_ci(table: NameTable&, name_id: NameId, text: cstr) -> bool:
    return table.has_text(name_id, text, NameCasePolicy.AsciiCaseInsensitive)
