# ============================================================
# Deque helpers - Elisa core runtime dialect
# ============================================================

include "./arena.elisa"

const ARENA_DEQUE_INIT_CAP: usize = 16

struct Deque[T]:
    items: mutable T&?
    head: mutable usize
    count: mutable usize
    capacity: mutable usize

@internal
def deque_items_from_alloc[T](ptr: heap void&) -> mutable T&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable T&]

@internal
def deque_mutable_void_from_items[T](items: mutable T&) -> mutable void&:
    trusted Unsafe.PointerCast:
        return items.cast[mutable void&]

@internal
def deque_void_from_items[T](items: T&) -> void&:
    trusted Unsafe.PointerCast:
        return items.cast[void&]

@internal
def deque_void_from_items_at[T](items: T&, index: usize) -> void&:
    trusted [Unsafe.PointerCast, Unsafe.PointerArithmetic]:
        return (items + index).cast[void&]

@internal
def deque_mutable_void_from_items_at[T](items: mutable T&, index: usize) -> mutable void&:
    trusted [Unsafe.PointerCast, Unsafe.PointerArithmetic]:
        return (items + index).cast[mutable void&]

def arena_deque_init[T]() -> Deque[T]:
    out: mutable Deque[T] = zeroed
    return out

def arena_deque_init_buffer[T](buffer: T&, capacity: usize) -> Deque[T]:
    out: mutable Deque[T] = zeroed
    out.items as & <- buffer
    out.head <- 0
    out.count <- 0
    out.capacity <- capacity
    return out

def arena_deque_with_capacity[T](a: mutable Arena&, capacity: usize) -> Deque[T]:
    can Memory.Allocate, Abort.Panic:
        if capacity == 0:
            out0: mutable Deque[T] = zeroed
            return out0

        out: mutable Deque[T] = zeroed
        out.items as & <- deque_items_from_alloc[T](arena_alloc(a, capacity * size_of(T)))
        out.head <- 0
        out.count <- 0
        out.capacity <- capacity
        return out

def arena_deque_len[T](d: Deque[T]&) -> usize:
    return d.count

def arena_deque_capacity[T](d: Deque[T]&) -> usize:
    return d.capacity

def arena_deque_is_empty[T](d: Deque[T]&) -> bool:
    return d.count == 0

def arena_deque_clear[T](d: mutable Deque[T]&):
    d.head <- 0
    d.count <- 0

def arena_deque_buffer_index[T](d: Deque[T]&, logical_index: usize) -> usize:
    can Abort.Panic:
        assert d.capacity > 0
        assert logical_index < d.capacity

        head_len: usize = d.capacity - d.head
        return (d.head + logical_index) if logical_index < head_len else logical_index - head_len

def arena_deque_copy_linearized[T](d: Deque[T]&, dst: mutable T&):
    if d.count == 0:
        return

    assert d.items != null

    if d.head <= d.capacity - d.count:
        arena_memcpy(
            deque_mutable_void_from_items[T](dst),
            deque_void_from_items_at[T](d.items, d.head),
            d.count * size_of(T)
        )
        return

    head_count: usize = d.capacity - d.head
    tail_count: usize = d.count - head_count

    arena_memcpy(
        deque_mutable_void_from_items[T](dst),
        deque_void_from_items_at[T](d.items, d.head),
        head_count * size_of(T)
    )
    arena_memcpy(
        deque_mutable_void_from_items_at[T](dst, head_count),
        deque_void_from_items[T](d.items),
        tail_count * size_of(T)
    )

def arena_deque_reserve[T](a: mutable Arena&, d: mutable Deque[T]&, needed: usize) -> mutable Deque[T]&:
    can Memory.Allocate, Abort.Panic:
        d return if needed <= d.capacity

        new_capacity: mutable usize = d.capacity
        if new_capacity == 0:
            new_capacity <- ARENA_DEQUE_INIT_CAP

        trusted Unsafe.AssumeProgress:
            while needed > new_capacity:
                new_capacity <- new_capacity * 2

        new_items: mutable T& = deque_items_from_alloc[T](arena_alloc(a, new_capacity * size_of(T)))
        arena_deque_copy_linearized(d, new_items)

        d.items as & <- new_items
        d.head <- 0
        d.capacity <- new_capacity
        return d

def arena_deque_ensure_unused[T](a: mutable Arena&, d: mutable Deque[T]&, additional: usize) -> mutable Deque[T]&:
    can Memory.Allocate, Abort.Panic:
        needed: usize = d.count + additional
        assert needed >= d.count
        return arena_deque_reserve(a, d, needed)

def arena_deque_push_front_assume_capacity[T](d: mutable Deque[T]&, item: T):
    can Abort.Panic:
        assert d.items != null
        assert d.count < d.capacity

        if d.head == 0:
            d.head <- d.capacity

        d.head <- d.head - 1
        d.items[d.head] <- item
        d.count <- d.count + 1

def arena_deque_push_back_assume_capacity[T](d: mutable Deque[T]&, item: T):
    can Abort.Panic:
        assert d.items != null
        assert d.count < d.capacity

        physical_index: usize = arena_deque_buffer_index(d, d.count)
        d.items[physical_index] <- item
        d.count <- d.count + 1

def arena_deque_push_front_bounded[T](d: mutable Deque[T]&, item: T) -> bool:
    can Abort.Panic:
        false return if d.count >= d.capacity

        arena_deque_push_front_assume_capacity(d, item)
        return true

def arena_deque_push_back_bounded[T](d: mutable Deque[T]&, item: T) -> bool:
    can Abort.Panic:
        false return if d.count >= d.capacity

        arena_deque_push_back_assume_capacity(d, item)
        return true

def arena_deque_push_front[T](a: mutable Arena&, d: mutable Deque[T]&, item: T) -> mutable Deque[T]&:
    can Memory.Allocate, Abort.Panic:
        _ = arena_deque_ensure_unused(a, d, 1)
        arena_deque_push_front_assume_capacity(d, item)
        return d

def arena_deque_push_back[T](a: mutable Arena&, d: mutable Deque[T]&, item: T) -> mutable Deque[T]&:
    can Memory.Allocate, Abort.Panic:
        _ = arena_deque_ensure_unused(a, d, 1)
        arena_deque_push_back_assume_capacity(d, item)
        return d

def arena_deque_front[T](d: Deque[T]&) -> T&?:
    return null if d.count == 0 or d.items == null else &d.items[d.head]

def arena_deque_back[T](d: Deque[T]&) -> T&?:
    can Abort.Panic:
        null return if d.count == 0 or d.items == null

        physical_index: usize = arena_deque_buffer_index(d, d.count - 1)
        return &d.items[physical_index]

def arena_deque_at[T](d: Deque[T]&, index: usize) -> T&:
    can Abort.Panic:
        assert index < d.count
        assert d.items != null

        physical_index: usize = arena_deque_buffer_index(d, index)
        return &d.items[physical_index]

def arena_deque_pop_front[T](d: mutable Deque[T]&, out: mutable T&) -> bool:
    can Abort.Panic:
        false return if d.count == 0 or d.items == null

        out[0] <- d.items[d.head]
        if d.count == 1:
            d.count <- 0
            d.head <- 0
            return true

        d.head <- arena_deque_buffer_index(d, 1)
        d.count <- d.count - 1
        return true

def arena_deque_pop_back[T](d: mutable Deque[T]&, out: mutable T&) -> bool:
    can Abort.Panic:
        false return if d.count == 0 or d.items == null

        physical_index: usize = arena_deque_buffer_index(d, d.count - 1)
        out[0] <- d.items[physical_index]
        d.count <- d.count - 1
        if d.count == 0:
            d.head <- 0
        return true
