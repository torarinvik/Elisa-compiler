# ============================================================
# Slice[T]: a borrowed, disjoint-partitionable view over a contiguous T buffer.
#
# Slice is all-scalar ({base: uintptr, count: usize}) so it is structurally
# thread-shareable and may be passed BY VALUE across a spawn/nursery boundary --
# the safe, bounds-checked alternative to casting a raw `uintptr` to `T&` in every
# worker. `split` carves a Slice into provably DISJOINT sub-bands (one per worker),
# so writing each band in parallel is data-race free by construction. The single
# unsafe step (viewing a darray's backing as a raw pointer) is encapsulated in
# `slice`, audited once, instead of scattered through user code.
#
# Idiomatic surface (uniform call syntax): build with `slice(&da)`, then `s.get(i)`,
# `s.set(i, v)`, `s.len()`, `s.split(n, k)` -- each is a plain overloaded free
# function, so `s.get(i)` and `get(s, i)` are the same call.
#
# BORROW SAFETY: `slice(&da)` is recorded as a storage-view borrow of `da` (see
# storageViewDependencyForCall), so a relocating mutation of `da` (push/resize/...)
# followed by a use of the slice is a stale-reference compile error -- the same
# guarantee darray interior references get. (A reserve_commit/stable-base darray
# grows in place and never relocates, so the slice stays valid and nothing is
# flagged.) The remaining contract -- the darray outlives the slice -- is honoured
# by structured use (the source outlives the nursery that joins the workers).
# ============================================================

struct Slice[T]:
	base: uintptr
	count: usize

# Borrow a darray's full backing as a Slice. The one unsafe view, encapsulated here.
def slice[T](da: mutable darray[T]&) -> Slice[T]:
	return Slice[T] { base: (&da[0.usize()]).cast[uintptr], count: da.count }

# Coerce a parallel-iteration source to a Slice. Overloaded for a darray (borrows its full backing,
# like `slice`) and for a Slice (identity). The `for x in xs by par:` lowering calls `as_slice(xs)`
# so it can index the source through a thread-shareable, all-scalar Slice -- reading element `idx` on
# its band's worker is race-free because each global index is visited exactly once.
def as_slice[T](da: mutable darray[T]&) -> Slice[T]:
	return Slice[T] { base: (&da[0.usize()]).cast[uintptr], count: da.count }

def as_slice[T](s: Slice[T]) -> Slice[T]:
	return s

# Number of elements. `s.len()` reads the same value as the `count` field.
def len[T](s: Slice[T]) -> usize:
	return s.count

# The sub-band `s[start:end]` (clamped to the slice). Used by `parallel for band in s:` to hand
# each worker its disjoint [start, end) chunk; the bands tile the slice with no overlap, so
# writing each band on its own worker is race-free by construction.
def slice_band[T](s: Slice[T], start: usize, end: usize) -> Slice[T]:
	lo: usize = start if start < s.count else s.count
	hi: usize = end if end < s.count else s.count
	if hi <= lo:
		return Slice[T] { base: s.base, count: 0.usize() }
	p: mutable T& = s.base.cast[mutable T&]
	return Slice[T] { base: (&p[lo]).cast[uintptr], count: hi - lo }

# The idx-th of `nbands` disjoint, contiguous sub-bands (ceil split). Bands tile the
# slice with no overlap, so handing band k to worker k is race-free for writes.
def split[T](s: Slice[T], nbands: usize, idx: usize) -> Slice[T]:
	band: usize = (s.count + nbands - 1.usize()) / nbands
	lo: usize = idx * band
	if lo >= s.count:
		return Slice[T] { base: s.base, count: 0.usize() }
	hi: usize = (lo + band if lo + band < s.count else s.count)
	p: mutable T& = s.base.cast[mutable T&]
	return Slice[T] { base: (&p[lo]).cast[uintptr], count: hi - lo }

# Bounds-checked read (panics on out-of-range): the safe default. `s.get(i)`.
def get[T](s: Slice[T], i: usize) -> T:
	can Abort.Panic:
		if i >= s.count:
			panic("Slice index out of bounds")
		p: T& = s.base.cast[T&]
		return p[i]

# Bounds-checked write (panics on out-of-range): the safe default. `s.set(i, v)`.
def set[T](s: Slice[T], i: usize, v: T) -> void:
	can Abort.Panic:
		if i >= s.count:
			panic("Slice index out of bounds")
		p: mutable T& = s.base.cast[mutable T&]
		p[i] <- v

# Unchecked variants for hot loops where the index is provably in range (e.g. a
# `for i in 0..<s.len()`): no per-access bounds branch.
def get_unchecked[T](s: Slice[T], i: usize) -> T:
	p: T& = s.base.cast[T&]
	return p[i]

def set_unchecked[T](s: Slice[T], i: usize, v: T) -> void:
	p: mutable T& = s.base.cast[mutable T&]
	p[i] <- v

# ============================================================
# ReadView[T]: a borrowed, read-only view over a contiguous T buffer.
#
# Unlike Slice[T] which carves disjoint write bands, ReadView covers the
# WHOLE source array and exposes only reads. It is the natural complement
# for double-buffer / stencil parallel patterns:
#
#   src_view: ReadView[f64] = read_view(&src)   # full array, read-only
#   dst_slice: Slice[f64]   = slice(&dst)        # full array, write-only bands
#   nursery:
#       for band in 0..<w:
#           submit stencil_worker(src_view, dst_slice.split(w, band), ...)
#
# Each worker writes to its disjoint dst band while reading ANY neighbour
# from src_view — including cells that fall in another worker's write band.
# This is race-free by construction: src is only read, dst bands are disjoint.
#
# ReadView is all-scalar ({base: uintptr, count: usize}) and structurally
# thread-shareable; pass it BY VALUE across spawn/nursery boundaries.
#
# BORROW SAFETY: `read_view(&da)` is recorded as a storage-view borrow of
# `da` (see storageViewDependencyForCall), so a relocating mutation of `da`
# while the view is live is a stale-reference compile error — the same
# guarantee Slice[T] and interior references get.
# ============================================================

struct ReadView[T]:
	base: uintptr
	count: usize

# Borrow a darray's full backing as a read-only view. The one unsafe pointer
# view, encapsulated here; no writes are possible through the returned value.
def read_view[T](da: mutable darray[T]&) -> ReadView[T]:
	return ReadView[T] { base: (&da[0.usize()]).cast[uintptr], count: da.count }

# Number of elements. `v.len()`.
def len[T](v: ReadView[T]) -> usize:
	return v.count

# Bounds-checked read (panics on out-of-range): the safe default. `v.get(i)`.
def get[T](v: ReadView[T], i: usize) -> T:
	can Abort.Panic:
		if i >= v.count:
			panic("ReadView index out of bounds")
		p: T& = v.base.cast[T&]
		return p[i]

# Unchecked read for hot inner loops where the index is provably in range.
def get_unchecked[T](v: ReadView[T], i: usize) -> T:
	p: T& = v.base.cast[T&]
	return p[i]
