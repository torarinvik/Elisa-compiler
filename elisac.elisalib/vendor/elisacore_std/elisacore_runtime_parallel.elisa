# ============================================================
# Data-parallel combinators over Slice[T]: the safe, one-line fast path.
#
# `each` and `reduce` fold the nursery + split boilerplate into a single call. They
# partition a Slice into W disjoint bands (one per worker), run on a structured nursery
# (every worker joined before the call returns), and pass only thread-shareable values
# across the boundary -- no raw casts, no manual pool/barrier/join.
#
# `reduce` is the contention-free shape: each worker folds its band into a PRIVATE partial
# slot, and the W partials are merged afterward with the same op -- so there is no shared
# accumulator and no atomic-RMW-in-a-loop (the reduction footgun the perf lints steer away
# from). `op` must be associative and `identity` its unit for the result to be partition-
# independent (it is: verified bit-identical across w=1/2/4/8).
# ============================================================

# Default worker count for a data-parallel op over `n` elements: the performance-core count
# (perf_cores), capped at `n` (never more threads than elements) and at least 1. This is the
# "inference does the plumbing" default so the common case needs no hand-tuned worker count.
def default_workers_for(n: usize) -> usize:
	if n == 0.usize():
		return 1.usize()
	cores: mutable usize = perf_cores().usize()
	if cores < 1.usize():
		cores <- 1.usize()
	if cores > n:
		return n
	return cores

# Parallel for-each over disjoint bands: `each(s, worker)` runs `worker(band)` on each disjoint
# band in parallel and joins them all -- the "parallel for band" as one call. The worker count
# is inferred (default_workers_for); pass a trailing `w` only to tune it explicitly.
def each[T](s: Slice[T], body: func(Slice[T]) -> i64, w: usize = 0.usize()) -> void:
	can Parallel:
		nw: usize = w if w != 0.usize() else default_workers_for(s.len())
		nursery workers(nw):
			for t in 0..<nw:
				submit body(s.split(nw, t))

# Index-band worker arg: a half-open global index range [lo, hi) and the per-index body. The
# ranges across workers are the disjoint ceil-split partition of [0, n), so every index is
# visited exactly once and no two workers touch the same index -- writes through `body(i)` to
# distinct `out[i]` slots are race-free by construction (the same disjointness as `split`).
struct ParIndexArg:
	lo: usize
	hi: usize
	body: func(usize) -> i64 can[Abort.Panic]

def par_index_worker(a: ParIndexArg) -> i64:
	can Abort.Panic:
		for i in a.lo ..< a.hi:
			_ = a.body(i)
		return 0

# Parallel index-for: runs `body(i)` for every `i` in `[0, n)` in parallel over disjoint index
# bands, joining all workers before returning. This is the lowering target of the `by par` sugar
# on a range for-loop:
#
#	for i in 0 ..< n by par:
#		out[i] <- f(in[i])        # desugars to  for_indices_par(n, lambda i => { ...; 0 })
#
# Disjoint bands => race-free for the canonical "write your own index" shape. Sharing a darray (or
# any non-thread-shareable value) into the body is still rejected at the lambda/nursery boundary.
def for_indices_par(n: usize, body: func(usize) -> i64 can[Abort.Panic], w: usize = 0.usize()) -> void:
	can Parallel, Abort.Panic:
		nw: usize = w if w != 0.usize() else default_workers_for(n)
		band: usize = (n + nw - 1.usize()) / nw
		nursery workers(nw):
			for t in 0..<nw:
				lo: usize = t * band
				hi: usize = (lo + band if lo + band < n else n)
				submit par_index_worker(ParIndexArg { lo: lo if lo < n else n, hi: hi, body: body })

struct ParMapArg[T, U]:
	src: Slice[T]
	dst: Slice[U]
	transform: func(T) -> U

# Worker: fill the dst band with transform(src element) for each index. src and dst bands are the
# t-th of the same `split(nw, t)` over equal-length slices, so they are aligned and disjoint across
# workers (race-free writes; in-range -> get/set_unchecked).
def par_map_worker[T, U](a: ParMapArg[T, U]) -> i64:
	n: usize = a.src.len()
	for i in 0..<n:
		a.dst.set_unchecked(i, a.transform(a.src.get_unchecked(i)))
	return 0

# Parallel map-into: fills the already-allocated `dst` with `transform(src[i])` over disjoint bands
# in parallel. `dst` must already have the same length as `src` (the caller allocates it, so the
# result lives in the caller's region — no darray crosses the call boundary). The `[... by par]`
# map comprehension lowers to this.
def par_map[T, U](src: Slice[T], dst: Slice[U], transform: func(T) -> U, w: usize = 0.usize()) -> void:
	can Parallel:
		nw: usize = w if w != 0.usize() else default_workers_for(src.len())
		nursery workers(nw):
			for t in 0..<nw:
				submit par_map_worker[T, U](ParMapArg[T, U] { src: src.split(nw, t), dst: dst.split(nw, t), transform: transform })

# Parallel map-collect: builds and RETURNS a fresh darray holding `transform(src[i])`, filled in
# parallel over disjoint bands. Unlike `par_map` (caller pre-allocates `dst`), this allocates the
# result in its own inferred region and the caller adopts it (region-return inference) -- so a
# `[f(x) for x in xs by par]` map lowers to one call, no caller-side scratch. Equivalent to
# `out = []; out.resize(src.len()); par_map(src, slice(&out), transform); out`.
def par_map_collect[T, U](src: Slice[T], transform: func(T) -> U, w: usize = 0.usize()) -> darray[U]:
	can Parallel, Memory.Allocate, Memory.Release, Abort.Panic:
		out: mutable darray[U] = []
		_ = out.resize(src.len())
		par_map(src, slice(&out), transform, w)
		return out

struct ReduceArg[T]:
	band: Slice[T]
	partials: Slice[T]
	id: usize
	identity: T
	op: func(T, T) -> T

# Worker: fold one band into the accumulator, write the partial into the worker's own slot
# (id < w = partials length, so the write is in-range -> set_unchecked, no panic/effects).
def reduce_worker[T](a: ReduceArg[T]) -> i64:
	acc: mutable T = a.identity
	n: usize = a.band.len()
	for i in 0..<n:
		acc <- a.op(acc, a.band.get_unchecked(i))
	a.partials.set_unchecked(a.id, acc)
	return 0

# Parallel reduction: `reduce(s, identity, op)` folds `s` to a single T. Each worker reduces its
# disjoint band into a private partial; partials are merged with `op`. `op` must be associative
# with unit `identity`. The worker count is inferred; pass a trailing `w` to tune it explicitly.
def reduce[T](s: Slice[T], identity: T, op: func(T, T) -> T, w: usize = 0.usize()) -> T:
	can Parallel, Memory.Allocate, Memory.Release, Abort.Panic:
		nw: usize = w if w != 0.usize() else default_workers_for(s.len())
		partials: mutable darray[T] = []
		_ = partials.resize(nw)
		for i in 0..<nw:
			partials[i] <- identity
		ps: Slice[T] = slice(&partials)
		nursery workers(nw):
			for t in 0..<nw:
				submit reduce_worker[T](ReduceArg[T] { band: s.split(nw, t), partials: ps, id: t, identity: identity, op: op })
		acc: mutable T = identity
		for i in 0..<nw:
			acc <- op(acc, partials[i])
		return acc

struct MapReduceArg[T, U]:
	band: Slice[T]
	partials: Slice[U]
	id: usize
	identity: U
	transform: func(T) -> U
	op: func(U, U) -> U

# Worker: fold one band into the accumulator, applying `transform` to each element on the way in,
# then write the partial into the worker's own slot (id < w = partials length -> set_unchecked).
def map_reduce_worker[T, U](a: MapReduceArg[T, U]) -> i64:
	acc: mutable U = a.identity
	n: usize = a.band.len()
	for i in 0..<n:
		acc <- a.op(acc, a.transform(a.band.get_unchecked(i)))
	a.partials.set_unchecked(a.id, acc)
	return 0

# Fused parallel transform-then-reduce: `map_reduce(s, identity, transform, op)` folds `s` to a
# single U by combining `transform(element)` values with `op` (no intermediate collection). This is
# the contention-free shape generalised with a per-element transform: each worker reduces its
# disjoint band into a private partial, partials merged with `op` (which must be associative with
# unit `identity`). The worker count is inferred; pass a trailing `w` to tune it.
def map_reduce[T, U](s: Slice[T], identity: U, transform: func(T) -> U, op: func(U, U) -> U, w: usize = 0.usize()) -> U:
	can Parallel, Memory.Allocate, Memory.Release, Abort.Panic:
		nw: usize = w if w != 0.usize() else default_workers_for(s.len())
		partials: mutable darray[U] = []
		_ = partials.resize(nw)
		for i in 0..<nw:
			partials[i] <- identity
		ps: Slice[U] = slice(&partials)
		nursery workers(nw):
			for t in 0..<nw:
				submit map_reduce_worker[T, U](MapReduceArg[T, U] { band: s.split(nw, t), partials: ps, id: t, identity: identity, transform: transform, op: op })
		acc: mutable U = identity
		for i in 0..<nw:
			acc <- op(acc, partials[i])
		return acc
