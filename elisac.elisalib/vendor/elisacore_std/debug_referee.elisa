# ============================================================
# Debug referee - opt-in runtime guardrails for dangerous values
# ============================================================

const DEBUG_REFEREE_TRACE_CAP: usize = 256
const DEBUG_TRACE_TAPE_CAP: usize = 1024

permission Debug:
    Referee
    Trace

const DEBUG_TRACE_KIND_CHECKPOINT: int = 1
const DEBUG_TRACE_KIND_VALUE: int = 2
const DEBUG_TRACE_KIND_BOUNDARY: int = 3

const DEBUG_TRACE_HASH_INITIAL: u64 = 0x12345678
const DEBUG_TRACE_HASH_PRIME: u64 = 16777619

const DEBUG_REFEREE_KIND_CHECK_CALLABLE: int = 1
const DEBUG_REFEREE_KIND_CHECK_POINTER: int = 2
const DEBUG_REFEREE_KIND_TRACE_VALUE: int = 3
const DEBUG_REFEREE_KIND_CHECKPOINT: int = 4

const DEBUG_REFEREE_REASON_OK: int = 0
const DEBUG_REFEREE_REASON_POISON: int = 1
const DEBUG_REFEREE_REASON_NEAR_NULL: int = 2
const DEBUG_REFEREE_REASON_NON_CANONICAL_X86_64: int = 3

const DEBUG_REFEREE_NEAR_NULL_LIMIT: uintptr = 0x10000
const DEBUG_REFEREE_POISON_GENERIC: uintptr = 0x0000800000000000
const DEBUG_REFEREE_POISON_GOT: uintptr = 0x0000800000000001
const DEBUG_REFEREE_POISON_TLS: uintptr = 0x0000800000000002
const DEBUG_REFEREE_POISON_TCB: uintptr = 0x0000800000000003
const DEBUG_REFEREE_POISON_DTV: uintptr = 0x0000800000000004

struct DebugRefereeEvent:
    sequence: mutable u64
    kind: mutable int
    reason: mutable int
    value: mutable uintptr
    label: mutable cstr

struct DebugTraceEvent:
    sequence: mutable u64
    kind: mutable int
    a: mutable uintptr
    b: mutable uintptr
    c: mutable uintptr
    label: mutable cstr

global mutable debug_referee_enabled: bool = false
global mutable debug_referee_trace_enabled: bool = false
global mutable debug_referee_sequence: u64 = 0
global mutable debug_referee_event_count: usize = 0
global mutable debug_referee_last_event: DebugRefereeEvent = zeroed
global mutable debug_referee_events: DebugRefereeEvent[DEBUG_REFEREE_TRACE_CAP] = zeroed

global mutable debug_trace_enabled: bool = false
global mutable debug_trace_sequence: u64 = 0
global mutable debug_trace_event_count: usize = 0
global mutable debug_trace_overflowed: bool = false
global mutable debug_trace_hash: u64 = DEBUG_TRACE_HASH_INITIAL
global mutable debug_trace_last_event: DebugTraceEvent = zeroed
global mutable debug_trace_events: DebugTraceEvent[DEBUG_TRACE_TAPE_CAP] = zeroed

# ------------------------------------------------------------
# Execution trace ring buffer (-ftrace "rewind a few steps")
# ------------------------------------------------------------
# Under -ftrace the compiler emits a call to elisa_trace_record(func_name, line) at
# every statement boundary. Only the most recent ELISA_TRACE_CAP steps are retained, so
# memory stays bounded no matter how long the program runs. At a fault or breakpoint,
# call elisa_trace_dump() (e.g. from lldb: `call elisa_trace_dump()`) to print the recent
# execution path newest-first -- observational "rewind" without reversible execution.

const ELISA_TRACE_CAP: usize = 256

# Minimal libc externs for the trace dump. debug_referee.elisa otherwise depends only
# on language builtins; snprintf+write resolve against libc at final link without
# pulling in the rest of the runtime. (write(2,...) is portable; the `stderr` global is
# not a stable cross-platform symbol, e.g. it is __stderrp on macOS.)
extern snprintf(buf: mutable u8&?, bufsize: usize, fmt: u8&, ...) -> int can[Console.Format]
extern write(fd: int, buf: void&, count: usize) -> isize can[Console]
extern getenv(name: u8&) -> u8&?
extern signal(sig: int, handler: void&?) -> void&?
# `raise` is a reserved keyword in Elisa, so re-raise via kill(getpid(), sig).
extern getpid() -> int
extern kill(pid: int, sig: int) -> int
# sigaction with SA_SIGINFO gives the handler the siginfo_t, which carries the faulting
# address (si_addr) -- so the dump can report WHERE the fault touched memory.
extern sigaction(sig: int, act: void&, oldact: void&?) -> int

# Common signal numbers (consistent across macOS/Linux for these four).
const ELISA_SIG_ILL: int = 4
const ELISA_SIG_ABRT: int = 6
const ELISA_SIG_FPE: int = 8
const ELISA_SIG_SEGV: int = 11
const ELISA_SA_SIGINFO: i32 = 0x40
# Byte offset of si_addr in macOS x86_64 siginfo_t (si_signo/errno/code/pid/uid/status
# = 6 ints = 24 bytes, then void* si_addr). On Linux x86_64 it is 16; gated below.
const ELISA_SIGINFO_ADDR_OFFSET_DARWIN: u64 = 24

# Matches the C `struct sigaction` byte layout used by the libc sigaction() call:
# handler (8), sa_mask (sigset_t = u32, 4), sa_flags (int, 4) = 16 bytes.
struct ElisaSigaction:
    handler: mutable uintptr
    mask: mutable u32
    flags: mutable i32

global mutable elisa_trace_fault_checked: bool = false

struct ElisaTraceEntry:
    name: mutable cstr
    var_name: mutable cstr
    value: mutable u64
    line: mutable u32
    repeat: mutable u32
    has_value: mutable u8

global mutable elisa_trace_ring: ElisaTraceEntry[ELISA_TRACE_CAP] = zeroed
global mutable elisa_trace_pos: u64 = 0     # ring head: number of distinct entries written
global mutable elisa_trace_total: u64 = 0   # actual steps recorded (counts deduped repeats)

# Plain step record: just function + line (the execution path).
def elisa_trace_record(name: cstr, line: u32) -> void:
    if not elisa_trace_fault_checked:
        elisa_trace_maybe_install_fault_handler()
    elisa_trace_total <- elisa_trace_total + 1
    # Collapse a consecutive run of the same plain step (e.g. a hot loop body) into a
    # single entry with a repeat count, so a tight loop does not flush the whole ring.
    if elisa_trace_pos > 0:
        last: usize = ((elisa_trace_pos - 1) % ELISA_TRACE_CAP.u64()).usize()
        # Compare the name by POINTER (the compiler passes one constant string per
        # function, so identity == same function) -- cheap, and avoids a string compare on
        # the hot path. cstr `==` would do a ctx_streq.
        if elisa_trace_ring[last].has_value == 0 and elisa_trace_ring[last].line == line and elisa_trace_ring[last].name.cast[uintptr] == name.cast[uintptr]:
            elisa_trace_ring[last].repeat <- elisa_trace_ring[last].repeat + 1
            return
    idx: usize = (elisa_trace_pos % ELISA_TRACE_CAP.u64()).usize()
    elisa_trace_ring[idx].name <- name
    elisa_trace_ring[idx].line <- line
    elisa_trace_ring[idx].repeat <- 0
    elisa_trace_ring[idx].has_value <- 0
    elisa_trace_pos <- elisa_trace_pos + 1

# Value record: a variable received a (scalar/pointer) value at this step.
def elisa_trace_record_value(name: cstr, line: u32, var_name: cstr, value: u64) -> void:
    elisa_trace_total <- elisa_trace_total + 1
    idx: usize = (elisa_trace_pos % ELISA_TRACE_CAP.u64()).usize()
    elisa_trace_ring[idx].name <- name
    elisa_trace_ring[idx].line <- line
    elisa_trace_ring[idx].var_name <- var_name
    elisa_trace_ring[idx].value <- value
    elisa_trace_ring[idx].repeat <- 0
    elisa_trace_ring[idx].has_value <- 1
    elisa_trace_pos <- elisa_trace_pos + 1

def elisa_trace_count() -> u64:
    return elisa_trace_total

# On a fault, print the recent trace then restore the default disposition and re-raise so
# the original crash still happens (core dump etc.). snprintf/write in a handler is not
# strictly async-signal-safe but is the common, useful choice for a crash dump.
# SA_SIGINFO handler: (int sig, siginfo_t *info, void *uctx). Reads si_addr from info,
# prints the faulting address + signal, dumps the recent trace, then restores the default
# disposition and re-raises so the original crash still happens.
def elisa_trace_fault_handler(sig: int, info: uintptr, uctx: uintptr) -> void:
    si_addr: mutable uintptr = 0
    if info != 0:
        p: uintptr = info + ELISA_SIGINFO_ADDR_OFFSET_DARWIN.uintptr()
        slot: uintptr& = p.cast[uintptr&]
        si_addr <- slot
    fbuf: mutable u8[96] = zeroed
    fw: int = snprintf(fbuf[0], 96, "*** elisa fault: signal %lld at address 0x%llx ***\n", sig.i64(), si_addr.u64()) can Console.Format
    if fw > 0:
        _ = write(2, (&fbuf[0]).cast[void&], fw.usize()) can Console
    elisa_trace_dump() can Console
    _ = signal(sig, null)
    _ = kill(getpid(), sig)

def elisa_trace_install_one(sig: int) -> void:
    act: mutable ElisaSigaction = zeroed
    act.handler <- elisa_trace_fault_handler.cast[void&?].uintptr()
    act.flags <- ELISA_SA_SIGINFO
    _ = sigaction(sig, (&act).cast[void&], null)

# Install the fault handler for SIGSEGV/SIGABRT/SIGILL/SIGFPE. Callable directly (e.g. a
# program -- or the emulator's own handler -- can opt in explicitly).
def elisa_trace_install_fault_handler() -> void:
    elisa_trace_install_one(ELISA_SIG_SEGV)
    elisa_trace_install_one(ELISA_SIG_ABRT)
    elisa_trace_install_one(ELISA_SIG_ILL)
    elisa_trace_install_one(ELISA_SIG_FPE)

# Auto-install once, gated by ELISA_TRACE_ON_FAULT. Off by default so it never clobbers a
# program's own signal handling (e.g. the emulator installs its SIGSEGV handler later,
# which then overrides this one -- the emulator should call elisa_trace_dump() itself).
def elisa_trace_maybe_install_fault_handler() -> void:
    if elisa_trace_fault_checked:
        return
    elisa_trace_fault_checked <- true
    if getenv("ELISA_TRACE_ON_FAULT".cast[u8&]) != null:
        elisa_trace_install_fault_handler()

def elisa_trace_dump() -> void:
    entries: u64 = elisa_trace_pos
    n: mutable u64 = entries
    if n > ELISA_TRACE_CAP.u64():
        n <- ELISA_TRACE_CAP.u64()
    hdr: mutable u8[160] = zeroed
    hw: int = snprintf(hdr[0], 160, "--- elisa trace: most recent %llu entries (%llu step(s)) ---\n", n, elisa_trace_total) can Console.Format
    if hw > 0:
        _ = write(2, (&hdr[0]).cast[void&], hw.usize()) can Console
    i: mutable u64 = 0
    while i < n:
        idx: usize = ((elisa_trace_pos - 1 - i) % ELISA_TRACE_CAP.u64()).usize()
        nm: cstr = elisa_trace_ring[idx].name
        ln: u32 = elisa_trace_ring[idx].line
        rep: u32 = elisa_trace_ring[idx].repeat
        buf: mutable u8[256] = zeroed
        w: mutable int = 0
        if elisa_trace_ring[idx].has_value != 0:
            vn: cstr = elisa_trace_ring[idx].var_name
            vv: u64 = elisa_trace_ring[idx].value
            w <- snprintf(buf[0], 256, "  [-%llu] %s:%u  %s = %llu (0x%llx)\n", i, nm, ln, vn, vv, vv) can Console.Format
        elif rep != 0:
            w <- snprintf(buf[0], 256, "  [-%llu] %s:%u (x%u)\n", i, nm, ln, rep + 1) can Console.Format
        else:
            w <- snprintf(buf[0], 256, "  [-%llu] %s:%u\n", i, nm, ln) can Console.Format
        if w > 0:
            wn: mutable usize = w.usize()
            if wn > 256:
                wn <- 256
            _ = write(2, (&buf[0]).cast[void&], wn) can Console
        i <- i + 1

def debug_referee_set_enabled(enabled: bool) can[Debug.Referee]:
    debug_referee_enabled <- enabled

def debug_referee_set_trace_enabled(enabled: bool) can[Debug.Referee]:
    debug_referee_trace_enabled <- enabled

def debug_referee_reset() can[Debug.Referee]:
    debug_referee_sequence <- 0
    debug_referee_event_count <- 0
    debug_referee_last_event <- DebugRefereeEvent(0, 0, 0, 0, "")

def debug_referee_last_reason() -> int:
    return debug_referee_last_event.reason

def debug_referee_last_value() -> uintptr:
    return debug_referee_last_event.value

def debug_referee_last_kind() -> int:
    return debug_referee_last_event.kind

def debug_referee_trace_count() -> usize:
    return debug_referee_event_count

def debug_referee_trace_event_at(index: usize) -> DebugRefereeEvent:
    if index >= DEBUG_REFEREE_TRACE_CAP:
        return DebugRefereeEvent(0, 0, 0, 0, "")
    return debug_referee_events[index]

def debug_referee_is_poison(value: uintptr) -> bool:
    if value == DEBUG_REFEREE_POISON_GENERIC:
        return true
    if value == DEBUG_REFEREE_POISON_GOT:
        return true
    if value == DEBUG_REFEREE_POISON_TLS:
        return true
    if value == DEBUG_REFEREE_POISON_TCB:
        return true
    if value == DEBUG_REFEREE_POISON_DTV:
        return true
    return false

def debug_referee_is_near_null(value: uintptr) -> bool:
    return value != 0 and value < DEBUG_REFEREE_NEAR_NULL_LIMIT

def debug_referee_is_noncanonical_x86_64(value: uintptr) -> bool:
    high: uintptr = value >> 48
    sign: uintptr = (value >> 47) & 1
    if sign == 0:
        return high != 0
    return high != 0xffff

def debug_referee_pointer_reason(value: uintptr) -> int:
    if debug_referee_is_poison(value):
        return DEBUG_REFEREE_REASON_POISON
    if debug_referee_is_near_null(value):
        return DEBUG_REFEREE_REASON_NEAR_NULL
    if debug_referee_is_noncanonical_x86_64(value):
        return DEBUG_REFEREE_REASON_NON_CANONICAL_X86_64
    return DEBUG_REFEREE_REASON_OK

def debug_referee_record(kind: int, reason: int, value: uintptr, label: cstr) can[Debug.Referee]:
    debug_referee_sequence <- debug_referee_sequence + 1
    event: DebugRefereeEvent = DebugRefereeEvent(debug_referee_sequence, kind, reason, value, label)
    debug_referee_last_event <- event

    if debug_referee_trace_enabled:
        slot: usize = debug_referee_event_count % DEBUG_REFEREE_TRACE_CAP
        debug_referee_events[slot] <- event
        debug_referee_event_count <- debug_referee_event_count + 1

def debug_referee_trace_value(label: cstr, value: uintptr) can[Debug.Referee]:
    can Debug.Referee:
        if debug_referee_trace_enabled:
            debug_referee_record(DEBUG_REFEREE_KIND_TRACE_VALUE, DEBUG_REFEREE_REASON_OK, value, label)

def debug_referee_checkpoint(label: cstr) can[Debug.Referee]:
    can Debug.Referee:
        if debug_referee_trace_enabled:
            debug_referee_record(DEBUG_REFEREE_KIND_CHECKPOINT, DEBUG_REFEREE_REASON_OK, 0, label)

def debug_referee_check_pointer(label: cstr, value: uintptr) -> bool can[Debug.Referee]:
    can Debug.Referee:
        reason: int = debug_referee_pointer_reason(value)
        if reason != DEBUG_REFEREE_REASON_OK:
            debug_referee_record(DEBUG_REFEREE_KIND_CHECK_POINTER, reason, value, label)
            return false
        if debug_referee_trace_enabled:
            debug_referee_record(DEBUG_REFEREE_KIND_CHECK_POINTER, DEBUG_REFEREE_REASON_OK, value, label)
        return true

def debug_referee_check_callable(label: cstr, value: uintptr) -> bool can[Debug.Referee]:
    can Debug.Referee:
        reason: int = debug_referee_pointer_reason(value)
        if reason != DEBUG_REFEREE_REASON_OK:
            debug_referee_record(DEBUG_REFEREE_KIND_CHECK_CALLABLE, reason, value, label)
            return false
        if debug_referee_trace_enabled:
            debug_referee_record(DEBUG_REFEREE_KIND_CHECK_CALLABLE, DEBUG_REFEREE_REASON_OK, value, label)
        return true

def debug_referee_assert_pointer(label: cstr, value: uintptr) can[Debug.Referee, Abort.Panic]:
    can Debug.Referee, Abort.Panic:
        if not debug_referee_enabled:
            return
        if debug_referee_check_pointer(label, value):
            return
        panic("debug referee stopped unsafe pointer")

def debug_referee_assert_callable(label: cstr, value: uintptr) can[Debug.Referee, Abort.Panic]:
    can Debug.Referee, Abort.Panic:
        if not debug_referee_enabled:
            return
        if debug_referee_check_callable(label, value):
            return
        panic("debug referee stopped unsafe callable")

def debug_trace_set_enabled(enabled: bool) can[Debug.Trace]:
    debug_trace_enabled <- enabled

def debug_trace_reset() can[Debug.Trace]:
    debug_trace_sequence <- 0
    debug_trace_event_count <- 0
    debug_trace_overflowed <- false
    debug_trace_hash <- DEBUG_TRACE_HASH_INITIAL
    debug_trace_last_event <- DebugTraceEvent(0, 0, 0, 0, 0, "")

def debug_trace_count() -> usize:
    return debug_trace_event_count

def debug_trace_fingerprint() -> u64:
    return debug_trace_hash

def debug_trace_did_overflow() -> bool:
    return debug_trace_overflowed

def debug_trace_event_at(index: usize) -> DebugTraceEvent:
    if index >= DEBUG_TRACE_TAPE_CAP:
        return DebugTraceEvent(0, 0, 0, 0, 0, "")
    return debug_trace_events[index]

def debug_trace_event_kind_at(index: usize) -> int:
    if index >= DEBUG_TRACE_TAPE_CAP:
        return 0
    return debug_trace_events[index].kind

def debug_trace_event_a_at(index: usize) -> uintptr:
    if index >= DEBUG_TRACE_TAPE_CAP:
        return 0
    return debug_trace_events[index].a

def debug_trace_event_b_at(index: usize) -> uintptr:
    if index >= DEBUG_TRACE_TAPE_CAP:
        return 0
    return debug_trace_events[index].b

def debug_trace_event_c_at(index: usize) -> uintptr:
    if index >= DEBUG_TRACE_TAPE_CAP:
        return 0
    return debug_trace_events[index].c

def debug_trace_last_kind() -> int:
    return debug_trace_last_event.kind

def debug_trace_mix_word(word: uintptr) can[Debug.Trace]:
    debug_trace_hash <- (debug_trace_hash ^ word.u64()) * DEBUG_TRACE_HASH_PRIME

def debug_trace_record(kind: int, label: cstr, a: uintptr, b: uintptr, c: uintptr) can[Debug.Trace]:
    can Debug.Trace:
        if not debug_trace_enabled:
            return

        debug_trace_sequence <- debug_trace_sequence + 1
        event: DebugTraceEvent = DebugTraceEvent(debug_trace_sequence, kind, a, b, c, label)
        debug_trace_last_event <- event

        debug_trace_mix_word(debug_trace_sequence.uintptr())
        debug_trace_mix_word(kind.uintptr())
        debug_trace_mix_word(a)
        debug_trace_mix_word(b)
        debug_trace_mix_word(c)

        if debug_trace_event_count < DEBUG_TRACE_TAPE_CAP:
            debug_trace_events[debug_trace_event_count] <- event
        else:
            debug_trace_overflowed <- true
        debug_trace_event_count <- debug_trace_event_count + 1

def debug_trace_checkpoint(label: cstr) can[Debug.Trace]:
    can Debug.Trace:
        debug_trace_record(DEBUG_TRACE_KIND_CHECKPOINT, label, 0, 0, 0)

def debug_trace_value(label: cstr, value: uintptr) can[Debug.Trace]:
    can Debug.Trace:
        debug_trace_record(DEBUG_TRACE_KIND_VALUE, label, value, 0, 0)

def debug_trace_boundary(label: cstr, a: uintptr, b: uintptr, c: uintptr) can[Debug.Trace]:
    can Debug.Trace:
        debug_trace_record(DEBUG_TRACE_KIND_BOUNDARY, label, a, b, c)

def debug_trace_assert_fingerprint(expected: u64) can[Debug.Trace, Abort.Panic]:
    can Abort.Panic:
        if debug_trace_hash != expected:
            panic("debug trace fingerprint mismatch")
