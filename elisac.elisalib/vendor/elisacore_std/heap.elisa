# ============================================================
# Orthogonal heap helpers - Elisa core runtime dialect
# ============================================================

include "./collections.elisa"

struct FixedBufferAllocator:
    data: mutable u8&?
    capacity: mutable usize
    end_index: mutable usize

struct FixedBufferMark:
    end_index: usize

@intrusive
struct MemoryPoolFreeNode:
    next: mutable heap MemoryPoolFreeNode&?

struct MemoryPool[T]:
    arena: mutable Arena
    free_list: mutable heap MemoryPoolFreeNode&?

def fixed_buffer_allocator_init(buffer: u8&, size: usize) -> FixedBufferAllocator:
    return FixedBufferAllocator(buffer, size, 0)

def fixed_buffer_align_forward(value: usize, alignment: usize) -> usize:
    value return if alignment <= 1

    remainder: usize = value % alignment
    return value if remainder == 0 else value + (alignment - remainder)

def fixed_buffer_owns_ptr(a: FixedBufferAllocator&, ptr: void&) -> bool:
    false return if a.data == null

    trusted Unsafe.PointerCast:
        base: uintptr = a.data.cast[u8&].uintptr()
        raw: uintptr = ptr.cast[u8&].uintptr()
        limit: uintptr = base + a.capacity.uintptr()
        return raw >= base and raw < limit

def fixed_buffer_owns_range(a: FixedBufferAllocator&, ptr: void&, size_bytes: usize) -> bool:
    false return if a.data == null

    trusted Unsafe.PointerCast:
        base: uintptr = a.data.cast[u8&].uintptr()
        raw: uintptr = ptr.cast[u8&].uintptr()
        limit: uintptr = base + a.capacity.uintptr()
        end_raw: uintptr = raw + size_bytes.uintptr()
        return raw >= base and end_raw <= limit

def fixed_buffer_is_last_allocation(a: FixedBufferAllocator&, ptr: void&, size_bytes: usize) -> bool:
    false return if a.data == null

    trusted Unsafe.PointerCast:
        base: uintptr = a.data.cast[u8&].uintptr()
        raw: uintptr = ptr.cast[u8&].uintptr()
        end_raw: uintptr = raw + size_bytes.uintptr()
        return end_raw == base + a.end_index.uintptr()

def fixed_buffer_snapshot(a: FixedBufferAllocator&) -> FixedBufferMark:
    return FixedBufferMark(a.end_index)

def fixed_buffer_rewind(a: mutable FixedBufferAllocator&, mark: FixedBufferMark):
    can Abort.Panic:
        assert mark.end_index <= a.capacity
        a.end_index <- mark.end_index

def fixed_buffer_reset(a: mutable FixedBufferAllocator&):
    a.end_index <- 0

def fixed_buffer_alloc_align(a: mutable FixedBufferAllocator&, size_bytes: usize, alignment: usize) -> mutable void&?:
    null return if a.data == null

    trusted [Unsafe.PointerCast, Unsafe.PointerArithmetic]:
        base: u8& = a.data.cast[u8&]
        adjusted_addr: usize = fixed_buffer_align_forward((base + a.end_index).uintptr().usize(), alignment)
        adjusted_index: usize = (adjusted_addr.uintptr() - base.uintptr()).usize()
        null return if adjusted_index > a.capacity
        null return if size_bytes > a.capacity - adjusted_index

        result: void& = (base + adjusted_index).cast[void&]
        a.end_index <- adjusted_index + size_bytes
        return result

def fixed_buffer_alloc(a: mutable FixedBufferAllocator&, size_bytes: usize) -> mutable void&?:
    return fixed_buffer_alloc_align(a, size_bytes, size_of(uintptr))

def fixed_buffer_alloc_align_or_panic(a: mutable FixedBufferAllocator&, size_bytes: usize, alignment: usize) -> mutable void&:
    can Abort.Panic:
        raw: void&? = fixed_buffer_alloc_align(a, size_bytes, alignment)
        assert raw != null
        trusted Unsafe.PointerCast:
            return raw.cast[void&]

def fixed_buffer_alloc_or_panic(a: mutable FixedBufferAllocator&, size_bytes: usize) -> mutable void&:
    can Abort.Panic:
        raw: void&? = fixed_buffer_alloc(a, size_bytes)
        assert raw != null
        trusted Unsafe.PointerCast:
            return raw.cast[void&]

def fixed_buffer_resize(a: mutable FixedBufferAllocator&, ptr: void&, old_size: usize, new_size: usize) -> bool:
    false return if not fixed_buffer_owns_range(a, ptr, old_size)

    new_size <= old_size return if not fixed_buffer_is_last_allocation(a, ptr, old_size)

    false return if a.data == null

    if new_size <= old_size:
        a.end_index <- a.end_index - (old_size - new_size)
        return true

    trusted Unsafe.PointerCast:
        base: uintptr = a.data.cast[u8&].uintptr()
        start_index: usize = (ptr.cast[u8&].uintptr() - base).usize()
        false return if start_index + new_size > a.capacity

        a.end_index <- start_index + new_size
        return true

def fixed_buffer_release(a: mutable FixedBufferAllocator&, ptr: void&, size_bytes: usize):
    if fixed_buffer_is_last_allocation(a, ptr, size_bytes):
        a.end_index <- a.end_index - size_bytes

def memory_pool_init[T]() -> MemoryPool[T]:
    return zeroed

def memory_pool_init_capacity[T](count: usize) -> MemoryPool[T]:
    out: mutable MemoryPool[T] = zeroed
    memory_pool_add_capacity(&out, count) can Memory.Allocate, Abort.Panic
    return out

def memory_pool_add_capacity[T](pool: mutable MemoryPool[T]&, count: usize):
    can Memory.Allocate, Abort.Panic:
        item_size: mutable usize = size_of(T)
        if item_size < size_of(MemoryPoolFreeNode):
            item_size <- size_of(MemoryPoolFreeNode)

        for i in 0..<count:
            raw: heap void& = arena_alloc(&pool.arena, item_size)
            trusted Unsafe.PointerCast:
                node: heap MemoryPoolFreeNode& = raw.cast[heap MemoryPoolFreeNode&]
                node.next <- pool.free_list
                pool.free_list as & <- node

def memory_pool_create[T](pool: mutable MemoryPool[T]&) -> mutable heap T&:
    can Memory.Allocate, Abort.Panic:
        if pool.free_list != null:
            node: heap MemoryPoolFreeNode& = pool.free_list
            pool.free_list <- node.next
            trusted Unsafe.PointerCast:
                item: heap T& = node.cast[heap T&]
                item[0] <- zeroed
                return item

        item_size: mutable usize = size_of(T)
        if item_size < size_of(MemoryPoolFreeNode):
            item_size <- size_of(MemoryPoolFreeNode)

        raw: heap void& = arena_alloc(&pool.arena, item_size)
        trusted Unsafe.PointerCast:
            item: heap T& = raw.cast[heap T&]
            item[0] <- zeroed
            return item

def memory_pool_destroy[T](pool: mutable MemoryPool[T]&, ptr: mutable heap T&):
    ptr[0] <- zeroed
    trusted Unsafe.PointerCast:
        node: heap MemoryPoolFreeNode& = ptr.cast[heap MemoryPoolFreeNode&]
        node.next <- pool.free_list
        pool.free_list as & <- node

def memory_pool_reset[T](pool: mutable MemoryPool[T]&):
    arena_reset(&pool.arena)
    pool.free_list <- null

def memory_pool_deinit[T](pool: mutable MemoryPool[T]&):
    arena_free(&pool.arena) can Memory.Release, Abort.Panic
    pool.arena <- zeroed
    pool.free_list <- null

# ------------------------------------------------------------
# Region-anchored object pool
# ------------------------------------------------------------
# Like MemoryPool[T], but its slabs come from a borrowed region arena (`owner`) rather than an
# arena it owns. Freed slots are recycled through an intrusive free list; forgetting to free is
# safe because the region bulk-frees every slab at teardown, so `region_pool_free` is purely a
# slot-reuse optimization, never a correctness obligation. Slots are pointer-stable (never move).
# There is deliberately no deinit: the region owns the arena and reclaims it at `destroy r`.

struct RegionPool[T]:
    owner: mutable Arena&?
    free_list: mutable heap MemoryPoolFreeNode&?

def region_pool_new[T](owner: mutable Arena&) -> RegionPool[T]:
    out: mutable RegionPool[T] = zeroed
    out.owner as & <- owner
    return out

def region_pool_create[T](pool: mutable RegionPool[T]&) -> mutable heap T&:
    can Memory.Allocate, Abort.Panic:
        if pool.free_list != null:
            node: heap MemoryPoolFreeNode& = pool.free_list
            pool.free_list <- node.next
            trusted Unsafe.PointerCast:
                item: heap T& = node.cast[heap T&]
                item[0] <- zeroed
                return item

        item_size: mutable usize = size_of(T)
        if item_size < size_of(MemoryPoolFreeNode):
            item_size <- size_of(MemoryPoolFreeNode)

        assert pool.owner != null
        owner: mutable Arena& = pool.owner
        raw: heap void& = arena_alloc(owner, item_size)
        trusted Unsafe.PointerCast:
            item: heap T& = raw.cast[heap T&]
            item[0] <- zeroed
            return item

def region_pool_free[T](pool: mutable RegionPool[T]&, ptr: mutable heap T&):
    ptr[0] <- zeroed
    trusted Unsafe.PointerCast:
        node: heap MemoryPoolFreeNode& = ptr.cast[heap MemoryPoolFreeNode&]
        node.next <- pool.free_list
        pool.free_list as & <- node

def create[T](pool: mutable RegionPool[T]&) -> mutable heap T&:
    return region_pool_create[T](pool) can Memory.Allocate, Abort.Panic

def recycle[T](pool: mutable RegionPool[T]&, ptr: mutable heap T&):
    region_pool_free[T](pool, ptr)

# Canonical usage (prefer this safe, ergonomic form over the raw region_pool_* functions):
#
#     region scratch(4096):
#         pool: mutable RegionPool[Node] = region_pool_new(scratch.ref[mutable Arena&])
#         h = pool.acquire()              # h: Pooled[Node], inferred
#         h.ptr.value <- 42               # borrow the object via h.ptr while h is live
#         pool.release(move h)            # OPTIONAL: recycles the slot for reuse
#         # ... dropping h without releasing is also safe: the region reclaims the
#         #     whole slab at `destroy scratch` (release is reuse, never an obligation).
#
# `pool.acquire()` / `pool.release(move h)` auto-borrow the mutable pool receiver (no
# explicit `.ref[...]`), and `T` is inferred from the binding type, so `[T]` need not be
# repeated on `region_pool_new`. Safety: a raw interior borrow taken out of the handle
# (`b = h.ptr`) and used after release is a compile error — including when the borrow is
# stashed in a struct/aggregate field or laundered through a function that returns it.
#
# An `affine` (use-at-most-once, droppable) owning handle for one pooled object. `acquire`
# produces one; `release` consumes it. Because the handle is affine, the compiler rejects
# use-after-release and double-release (the same checker that guards Thread/MutexGuard). Because
# it is `affine` (not `linear`), it is DROPPABLE: forgetting to release just forgoes slot reuse
# — the region still bulk-frees the slab at teardown, so dropping is safe (never a leak, never a
# dangling slot). Borrow the object via `handle.ptr` while the handle is live.
affine struct Pooled[T]:
    ptr: mutable heap T&

def region_pool_acquire[T](pool: mutable RegionPool[T]&) -> Pooled[T]:
    return Pooled[T](region_pool_create[T](pool)) can Memory.Allocate, Abort.Panic

def region_pool_release[T](pool: mutable RegionPool[T]&, handle: Pooled[T]):
    # Recycle inline (rather than calling region_pool_free) so we never hand the handle's
    # interior mutable ref across a call boundary, which the affine checker forbids.
    slot: mutable heap T& = handle.ptr
    slot[0] <- zeroed
    trusted Unsafe.PointerCast:
        node: heap MemoryPoolFreeNode& = slot.cast[heap MemoryPoolFreeNode&]
        node.next <- pool.free_list
        pool.free_list as & <- node

def acquire[T](pool: mutable RegionPool[T]&) -> Pooled[T]:
    return region_pool_acquire[T](pool) can Memory.Allocate, Abort.Panic

def release[T](pool: mutable RegionPool[T]&, handle: Pooled[T]):
    region_pool_release[T](pool, move handle)
