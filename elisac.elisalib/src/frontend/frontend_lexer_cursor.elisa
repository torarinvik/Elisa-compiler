@inline(always)
def frontend_peek_char_at(lexer: Lexer&, offset: usize) -> i64:
    return frontend_char_at(lexer.source, lexer.source_len, lexer.position + offset)
@inline(always)
def frontend_make_source_view(source: u8&, start: usize, end: usize) -> sview:
    if end <= start:
        return frontend_empty_view()
    return sview(source, start.i64(), end.i64())
@inline(always)
def advance_char(lexer: mutable Lexer&) -> i64:
    if frontend_is_eof(lexer):
        return FRONTEND_CH_NUL

    ch: i64 = frontend_cur_char(lexer)
    lexer.position <- lexer.position + 1
    if ch == FRONTEND_CH_NL:
        lexer.line <- lexer.line + 1
        lexer.column <- 1
    else:
        lexer.column <- lexer.column + 1
    return ch
