@inline(always)
def frontend_peek_char_at(lexer: FrontendLexer&, offset: usize) -> i64:
    return frontend_char_at(lexer.source, lexer.source_len, lexer.pos + offset)
@inline(always)
def frontend_make_source_view(source: u8&, start: usize, end: usize) -> sview:
    if end <= start:
        return frontend_empty_view()
    return sview(source, start.i64(), end.i64())
@inline(always)
def frontend_advance_char(lexer: mutable FrontendLexer&) -> i64:
    if frontend_is_eof(lexer):
        return FRONTEND_CH_NUL

    ch: i64 = frontend_cur_char(lexer)
    lexer.pos <- lexer.pos + 1
    if ch == FRONTEND_CH_NL:
        lexer.line <- lexer.line + 1
        lexer.col <- 1
    else:
        lexer.col <- lexer.col + 1
    return ch
