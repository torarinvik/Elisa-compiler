def skip_line_comment(lexer: mutable Lexer&):
    while not lexer.is_eof() and lexer.current_char() != FRONTEND_CH_NL:
        lexer.advance_char()
@inline(always)
def skip_spaces(lexer: mutable Lexer&):
    while not lexer.is_eof() and lexer.current_char() in {FRONTEND_CH_SPACE, FRONTEND_CH_TAB}:
        lexer.advance_char()
