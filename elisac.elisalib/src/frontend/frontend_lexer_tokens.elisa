            return frontend_make_token(FrontendTokenKind.Question, pos, frontend_make_lexer_view(lexer, start, lexer.pos), frontend_empty_view())

        if ch == FRONTEND_CH_TILDE:
            _ = frontend_advance_char(lexer)
            return frontend_make_token(FrontendTokenKind.Tilde, pos, frontend_make_lexer_view(lexer, start, lexer.pos), frontend_empty_view())

        if ch == FRONTEND_CH_AT:
            _ = frontend_advance_char(lexer)
            return frontend_make_token(FrontendTokenKind.At, pos, frontend_make_lexer_view(lexer, start, lexer.pos), frontend_empty_view())

        _ = frontend_advance_char(lexer)
        return frontend_make_token(FrontendTokenKind.Ident, pos, frontend_make_lexer_view(lexer, start, lexer.pos), frontend_empty_view())

        return frontend_make_token(FrontendTokenKind.Eof, frontend_cur_pos(lexer), frontend_empty_view(), frontend_empty_view())
def frontend_tokenize(a: mutable Arena&, filename: u8&, source: u8&) -> darray[FrontendToken]:
    tokens: darray[FrontendToken] = frontend_tokenize_with_len(a, filename, source, runtime_strlen(source)) can Memory.Allocate, Abort.Panic
    return tokens
def frontend_tokenize_with_len(a: mutable Arena&, filename: u8&, source: u8&, source_len: usize) -> darray[FrontendToken]:
    can Memory.Allocate, Abort.Panic:
        lexer: mutable FrontendLexer = frontend_new_lexer_with_len(a, filename, source, source_len)
        in a:
            tokens: mutable darray[FrontendToken] = []

            while true:
                token: FrontendToken = frontend_next_token(lexer)
                tokens.push(token)
                match token.kind:
                    FrontendTokenKind.Eof:
                        return tokens
                    _:
                        pass

            return tokens
