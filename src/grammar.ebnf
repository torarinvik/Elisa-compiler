(* ==========================================================================
   Elisa — concrete grammar (EBNF)
   ==========================================================================
   Derived from the stage0 (Go) reference implementation:
     compiler/src/lexer/*.go   (tokens, layout, literal decoding)
     compiler/src/parser/*.go  (recursive-descent parser, precedence climbing)

   Notation: standard ISO-ish EBNF.
     ::=        defines a production
     |          alternation
     [ x ]      optional
     { x }      zero or more
     ( x y )    grouping
     "x"        literal token text
     'x'        literal character
     ?comment?  informal description where a full production would be noise

   Layout is significant (Python-like): NEWLINE / INDENT / DEDENT are
   synthesized by the lexer from line breaks and indentation width, and are
   treated as ordinary tokens below. A logical line ends at NEWLINE; an
   indented block is INDENT stmt* DEDENT. Many constructs also accept an
   inline single-statement/single-declaration form in place of a block
   (`if cond: stmt` instead of `if cond:\n    stmt`) — this is written
   `block(X)` and defined once, below.
   ========================================================================== *)


(* ==========================================================================
   1. Lexical grammar
   ========================================================================== *)

letter        ::= 'a'..'z' | 'A'..'Z' | '_' | ?unicode identifier-start rune?
digit         ::= '0'..'9'
ident         ::= letter { letter | digit | ?unicode identifier-continue rune? }

int_lit       ::= digit { digit | '_' } [ type_suffix ]
hex_lit       ::= "0x" hex_digit { hex_digit } [ type_suffix ]
hex_digit     ::= digit | 'a'..'f' | 'A'..'F'
float_lit     ::= digit { digit } '.' digit { digit } [ ( 'e' | 'E' ) [ '+' | '-' ] digit { digit } ] [ type_suffix ]
type_suffix   ::= "i8" | "i16" | "i32" | "i64" | "isize"
                | "u8" | "u16" | "u32" | "u64" | "usize" | "uintptr"
                | "f32" | "f64"
                (* numeric literals bind their declared type from context; a
                   suffix is only required to disambiguate (drop freely
                   except for literals exceeding i64::MAX). *)

string_lit    ::= '"' { str_char | escape } '"'
char_lit      ::= "'" ( str_char | escape ) "'"
str_char      ::= ?any byte except '"' / "'" / '\' / newline, per literal kind?
escape        ::= '\\' | '\"' | '\'' | "\n" | "\r" | "\t" | "\0"
                | '\x' hex_digit hex_digit
                | '\u' hex_digit hex_digit hex_digit hex_digit  (* surrogate pairs supported *)

comment       ::= line_comment | block_comment
line_comment  ::= '#' { ?any char except newline? }
block_comment ::= '"""' { ?any char? } '"""'      (* a `"` string opener that forms `"""` *)

NEWLINE       ::= ?end of logical line — layout token?
INDENT        ::= ?increase in indentation — layout token?
DEDENT        ::= ?decrease in indentation — layout token?

(* Reserved keywords (always keywords, never plain identifiers): *)
reserved_kw   ::= "def" | "error" | "enum" | "struct" | "const" | "global"
                | "extern" | "export" | "if" | "match" | "elif" | "else"
                | "while" | "break" | "continue" | "return" | "heap" | "stack"
                | "static" | "mutable" | "repr" | "packed" | "pass" | "panic"
                | "not" | "and" | "or" | "null" | "true" | "false" | "zeroed"
                | "sizeof" | "size_of" | "alignof" | "align_of"
                | "offsetof" | "offset_of" | "tail" | "try" | "catch" | "raise"
                | "region" | "new" | "is" | "as" | "in" | "with" | "to"

(* Contextual keywords (lexed as IDENT; recognized by text + position, so
   they remain valid identifiers elsewhere — each has a disambiguator in the
   parser). This set is why local variables should avoid these names when
   they could be confused for the statement form: *)
contextual_kw ::= "module" | "extend" | "using" | "include" | "public" | "private"
                | "type" | "alias" | "law" | "permission" | "effect" | "protocol"
                | "impl" | "affine" | "can" | "ensures" | "ensure" | "requires"
                | "changes" | "preserves" | "fulfills" | "decreases" | "uses"
                | "invariant" | "defer" | "for" | "let" | "scope" | "cascade"
                | "parallel" | "lock" | "ghost" | "destroy" | "leak" | "mark"
                | "checkpoint" | "restore" | "reset" | "promote" | "adopt"
                | "wait" | "notify" | "pool" | "nursery" | "emit" | "submit"
                | "await" | "move" | "do" | "lambda" | "λ" | "get" | "rewrite"
                | "guard" | "layout" | "common" | "of" | "forall" | "exists"

operators     ::= ":" | "::" | "->" | "=>" | "." | ".." | "..<" | "..>" | "..="
                | "," | "(" | ")" | "[" | "]" | "{" | "}" | "#" | "&" | "?" | "?="
                | "!" | "@" | "..." | "<-"
                | "+=" | "-=" | "*=" | "/=" | "%=" | "^=" | "|=" | "&="
                | "<<=" | ">>=" | "="
                | "==" | "!=" | "<" | ">" | "<=" | ">="
                | "+" | "-" | "*" | "/" | "%"
                | "|" | "^" | "<<" | ">>" | "~" | "|>" | ";"


(* ==========================================================================
   2. Top-level structure
   ========================================================================== *)

file          ::= { decl_unit }

(* A single declaration unit; visibility sections and module/extend bodies
   flatten their members into the surrounding sequence of decl_units. *)
decl_unit     ::= { decorator }
                  ( module_decl
                  | extend_decl
                  | using_decl
                  | include_decl
                  | visibility_section
                  | type_alias_decl
                  | alias_decl
                  | law_decl
                  | named_block_decl        (* permission / effect / protocol *)
                  | impl_decl
                  | "affine" decl_unit
                  | static_if_decl
                  | decl )

decorator     ::= '@' ident [ '(' [ decorator_arg { ',' decorator_arg } ] ')' ]
                   (* e.g. @inline(always), @hot — args are balanced-paren
                      token runs; decorator semantics beyond parsing are
                      declaration-specific (see @hot / @property / @method). *)
decorator_arg ::= ?balanced token run, no top-level comma?

decl          ::= func_decl | struct_decl | enum_decl | const_decl | global_decl
                | extern_decl | export_decl | error_decl

module_decl   ::= "module" ident ':' block(decl_unit)
extend_decl   ::= "extend" qualified_ident ':' block(decl_unit)
                   (* extends an existing `module`/`struct` namespace; member
                      collection is identical to module_decl. *)
using_decl    ::= "using" using_target { ',' using_target } NEWLINE
using_target  ::= qualified_ident [ "as" ident ]                (* alias form *)
                | qualified_ident '.' '{' ident { ',' ident } '}'  (* selective form *)
include_decl  ::= "include" string_lit NEWLINE

visibility_section
              ::= ( "public" | "private" ) ':' block(decl_unit)

static_if_decl
              ::= "static" ( "if" | "elif" ) expr ':' block(decl_unit)
                  { "static" "elif" expr ':' block(decl_unit) }
                  [ "static" "else" ':' block(decl_unit) ]


(* ==========================================================================
   3. Declarations
   ========================================================================== *)

qualified_ident ::= ident { ( '.' | '::' ) ident }

generic_param_list
              ::= '[' generic_param { ',' generic_param } ']'
generic_param ::= ident                              (* type parameter *)
                | "region" ident                      (* region parameter *)
                | "permission" ident                  (* permission/effect-set parameter *)

(* ---- def / lemma --------------------------------------------------------- *)

func_decl     ::= { decorator } [ "static" ] "def" ident [ generic_param_list ]
                  '(' [ param_list ] ')'
                  [ "->" type_expr ]
                  [ "can" effect_grant_list ]
                  [ "ensures" ensures_clause { ',' ensures_clause } ]
                  [ "changes" ensures_path { ',' ensures_path } ]
                  [ "preserves" ensures_path { ',' ensures_path } ]
                  [ "fulfills" fulfills_clause { ',' fulfills_clause } ]
                  ':' func_body
                  (* `lemma` reuses this exact grammar (parseFuncDeclRest),
                     flagged IsLemma by its caller. *)

param_list    ::= param { ',' param } [ ',' "..." ]     (* trailing variadic in extern/some sigs *)
param         ::= [ "mutable" ] ident ':' type_expr [ '=' expr ]

(* Leading body statements `requires <bool-expr>` / `ensure <bool-expr>` /
   `decreases <expr>` / `decreases *` / `uses <name>` are value-contract
   forms lifted out of the parsed body into the FuncDecl's contract fields
   (NOT post-signature clauses — `-> T requires ...` would collide with the
   region-prefixed type grammar). They must be the function body's leading
   statements. *)
value_contract_stmt
              ::= "requires" expr [ scoped_proof ] NEWLINE
                | "ensure" expr [ scoped_proof ] NEWLINE
                | "decreases" ( expr { ',' expr } | '*' [ string_lit ] ) NEWLINE
                | "uses" ident NEWLINE
scoped_proof  ::= "proof" ':' block(stmt)

ensures_clause ::= expr                     (* may reference `result` / `old(expr)` *)
ensures_path   ::= expr                     (* a frame-condition path, e.g. `self.count` *)
fulfills_clause ::= qualified_ident

effect_grant_list
              ::= '[' effect_ref { ',' effect_ref } ']'
                | effect_ref { ',' effect_ref }          (* bare trailing form, no brackets *)
effect_ref    ::= qualified_ident

func_body     ::= NEWLINE INDENT { stmt } DEDENT
                | ?inline?: { stmt-on-same-line }

(* ---- struct --------------------------------------------------------------- *)

struct_decl   ::= { decorator } [ "affine" ]
                  "struct" ident [ generic_param_list ] [ struct_layout_suffix ] ':'
                  block( struct_member )
struct_layout_suffix
              ::= "layout" ( layout_mode [ '(' layout_opt { ',' layout_opt } ')' ]
                           | '(' layout_opt { ',' layout_opt } ')' )     (* mode-less keeps default *)
layout_mode   ::= "aos" | "soa" | "c" | "packed"
layout_opt    ::= "sparse" | "handle" ':' ( "u8" | "u16" | "u32" | "u64" | "ptr" )

struct_member ::= field_decl | func_decl | "pass"
field_decl    ::= ident ':' type_expr NEWLINE

(* ---- enum ------------------------------------------------------------------ *)

enum_decl     ::= { decorator } "enum" ident [ "is" qualified_ident ]   (* sealed-refinement parent *)
                  [ struct_layout_suffix ]
                  ':' ( "pass" NEWLINE                                  (* abstract root, no variants *)
                      | NEWLINE INDENT
                          { "pass"
                          | common_fields
                          | enum_variant }
                        DEDENT )
common_fields ::= "common" ( ':' block(field_decl)                       (* legacy indented form *)
                            | '(' field_decl_inline { ',' field_decl_inline } ')' )  (* canonical inline *)
field_decl_inline ::= ident ':' type_expr
enum_variant  ::= ident [ '(' [ variant_field { ',' variant_field } ] ')' ] NEWLINE
                | ident ':' block(func_decl)          (* variant with its own method block *)
variant_field ::= [ ident ':' ] type_expr

(* ---- const / global --------------------------------------------------------- *)

const_decl    ::= "const" ident [ ':' type_expr ] '=' expr NEWLINE
global_decl   ::= "global" ident [ ':' type_expr ] '=' expr NEWLINE

(* ---- extern / export --------------------------------------------------------- *)

extern_decl   ::= "extern" [ string_lit ] ( func_signature_decl | "foreign" '[' string_lit { ',' string_lit } ']' ':' block(func_signature_decl) )
export_decl   ::= "export" func_decl                    (* exported native-linkage def *)
func_signature_decl
              ::= "def" ident '(' [ param_list ] ')' [ "->" type_expr ] NEWLINE

(* ---- error -------------------------------------------------------------- *)

error_decl    ::= "error" ident [ '(' [ variant_field { ',' variant_field } ] ')' ] NEWLINE
                | "error" ident ':' block( ident [ '(' [ variant_field { ',' variant_field } ] ')' ] NEWLINE )
                   (* an error SET: named error type with member "cases" *)

(* ---- type alias / alias ------------------------------------------------- *)

type_alias_decl ::= "type" ident [ '[' ident { ',' ident } ']' ] '=' type_expr NEWLINE
alias_decl      ::= "alias" ident '=' ( effect_ref { ',' effect_ref } | type_expr ) NEWLINE
                     (* effect-set / capability alias, or plain type alias sugar *)

(* ---- law (refinement / algebraic law) ------------------------------------ *)

law_decl      ::= "law" ident '(' [ param_list ] ')' '=' expr NEWLINE
                   (* predicate may use quantifier syntax: forall/exists *)

(* ---- permission / effect / protocol -------------------------------------- *)

named_block_decl
              ::= ( "permission" | "effect" | "protocol" ) ident
                  [ '(' [ param_list ] ')' ] ':' block( protocol_member )
protocol_member
              ::= func_signature_decl | field_decl | "pass"

(* ---- impl ----------------------------------------------------------------- *)

impl_decl     ::= "impl" [ generic_param_list ] qualified_ident [ "for" type_expr ] ':'
                  block( func_decl )
                   (* inherent `impl Type:` and trait `impl Trait for Type:` both
                      allowed; member `def`s are captured, the grouping itself
                      is not retained beyond scoping. *)


(* ==========================================================================
   4. Statements
   ========================================================================== *)

(* block(X) — the shared inline-or-indented body shape used throughout: *)
block(X)      ::= ':' ( NEWLINE INDENT { X } DEDENT
                       | X )                     (* inline single-item form *)

stmt          ::= if_stmt | while_stmt | for_stmt | match_stmt
                | return_stmt | break_stmt | continue_stmt
                | var_decl_stmt | assign_stmt | expr_stmt
                | defer_stmt | contract_stmt | can_block_stmt
                | region_stmt | concurrency_stmt | "pass" NEWLINE

if_stmt       ::= "if" expr block(stmt)
                  { "elif" expr block(stmt) }
                  [ "else" block(stmt) ]

while_stmt    ::= "while" expr block(stmt)

for_stmt      ::= "for" for_pattern "in" expr [ "if" expr ] block(stmt)
for_pattern   ::= ident | '(' ident { ',' ident } ')'

match_stmt    ::= "match" expr ':' NEWLINE INDENT { match_arm } DEDENT
match_arm     ::= pattern_or [ "if" expr ] ':' block(stmt)

(* Pattern grammar (also used by `is`-test expressions, see §5). *)
pattern_or    ::= pattern { '|' pattern }
pattern       ::= "_"                                          (* wildcard *)
                | literal                                       (* literal pattern *)
                | ident                                          (* bare binding *)
                | qualified_ident '(' [ pattern_or { ',' pattern_or } ] ')'   (* variant, incl. payload *)
                | ident '{' [ struct_pattern_field { ',' struct_pattern_field } ] '}'  (* struct pattern *)
                | pattern "as" ident                             (* alias-bind *)
                | qualified_ident ident                          (* category/type binder sugar: `Type s` *)
struct_pattern_field
              ::= ident [ ':' pattern_or ]

return_stmt   ::= "return" [ "if" expr ]                        NEWLINE  (* bare `return if COND` guard *)
                | "return" expr [ "if" expr ]                   NEWLINE  (* value-first `VALUE return if COND` *)
                | "return" expr                                 NEWLINE

break_stmt    ::= "break" [ "if" expr ] NEWLINE
continue_stmt ::= "continue" [ "if" expr ] NEWLINE
                   (* `break if COND` / `continue if COND` desugar at parse
                      time to `if COND: break` / `if COND: continue`. *)

var_decl_stmt ::= [ "mutable" ] ident ':' type_expr [ '@' expr ] '=' expr NEWLINE
                | [ "mutable" ] ident ':' type_expr NEWLINE           (* declaration w/o initializer *)
                   (* `@<owner>` binds an explicit region/owner annotation on
                      a container-typed local (replaces the removed
                      `[...] in <owner>` expression-owner form). *)

assign_stmt   ::= lvalue assign_op expr NEWLINE
lvalue        ::= postfix_expr                                  (* ident / field / index chain *)
assign_op     ::= "<-"                                           (* mutation of an existing binding *)
                | '=' | "+=" | "-=" | "*=" | "/=" | "%="
                | "^=" | "|=" | "&=" | "<<=" | ">>="
                   (* `=` introduces/rebinds in a var_decl_stmt's initializer
                      position; `<-` is the in-place mutation operator used
                      against an already-declared `mutable` binding — this is
                      the load-bearing distinction in Elisa's mutability model. *)

expr_stmt     ::= expr NEWLINE

defer_stmt    ::= "defer" block(stmt)

contract_stmt ::= value_contract_stmt
                | "invariant" expr NEWLINE                       (* struct-field / in-body invariant *)

can_block_stmt ::= "can" ':' block(stmt)                         (* scoped effect grant block *)

(* ---- region statements ---------------------------------------------------- *)

region_stmt   ::= "region" ident block(stmt)                     (* named region scope *)
                | "scope" block(stmt)                            (* lexical arena scope *)
                | "promote" expr "to" ( "heap" | "stack" | ident ) NEWLINE
                | "adopt" expr "into" expr NEWLINE
                | "destroy" expr NEWLINE
                | "leak" expr NEWLINE
                | "mark" ident NEWLINE
                | "checkpoint" ident NEWLINE
                | "restore" ident NEWLINE
                | "reset" ident NEWLINE

(* ---- concurrency statements ------------------------------------------------ *)

concurrency_stmt
              ::= "pool" ident '(' [ expr { ',' expr } ] ')' block(stmt)
                | "nursery" [ ident ] block(stmt)
                | "lock" expr block(stmt)
                | "parallel" "for" for_pattern "in" expr block(stmt)
                | "wait" expr NEWLINE
                | "notify" expr NEWLINE
                | "cascade" expr NEWLINE
                | "emit" expr NEWLINE
                | "ghost" block(stmt)                             (* verification-only, erased at runtime *)


(* ==========================================================================
   5. Expressions
   ========================================================================== *)

(* Precedence, LOWEST to HIGHEST binding (each level left-associative unless
   noted). Mirrors the parser's descent chain exactly:
     parseExpr -> parseOr -> parseAnd -> parseNot -> parseComparison ->
     parseAs -> parseBitwiseOr -> parseBitwiseXor -> parseBitwiseAnd ->
     parseShift -> parseAddSub -> parseMulDiv -> parseUnary -> parsePostfix
     -> parsePrimary                                                        *)

expr          ::= ternary_expr                                    (* top: `get`/`try` propagation folds an
                                                                       optional trailing `else expr` here *)
ternary_expr  ::= or_expr [ "if" or_expr "else" expr ]             (* `a if cond else b`, disableable in
                                                                       comprehension/where contexts *)

or_expr       ::= and_expr { "or" and_expr }
and_expr      ::= not_expr { "and" not_expr }
not_expr      ::= "not" not_expr
                | "let" ident '=' not_expr                        (* optional-bind sugar *)
                | comparison_expr
comparison_expr
              ::= as_expr { comparison_op as_expr | is_expr | in_expr }
comparison_op ::= "==" | "!=" | "<" | ">" | "<=" | ">="
is_expr       ::= "is" [ "not" ] is_test_expr                      (* refinement / variant / struct / type test *)
                | "is" ident                                       (* refutable bare binding, docs/80 *)
in_expr       ::= [ "not" ] "in" membership_rhs
membership_rhs ::= as_expr [ ( ".." | "..<" | "..>" | "..=" ) as_expr ]

as_expr       ::= bitor_expr                                       (* `as` casts fold in at postfix (.cast[T]) *)
bitor_expr    ::= bitxor_expr { '|' bitxor_expr }
bitxor_expr   ::= bitand_expr { '^' bitand_expr }
bitand_expr   ::= shift_expr { '&' shift_expr }
shift_expr    ::= addsub_expr { ( "<<" | ">>" ) addsub_expr }
addsub_expr   ::= muldiv_expr { ( '+' | '-' ) muldiv_expr }
muldiv_expr   ::= unary_expr { ( '*' | '/' | '%' ) unary_expr }

unary_expr    ::= "new" [ '[' expr ']' ] unary_expr                 (* region-poly / explicit-owner alloc *)
                | "submit" [ '[' expr ']' ] unary_expr              (* pool/nursery task submission sugar *)
                | "await" unary_expr
                | "move" unary_expr
                | '-' unary_expr
                | '~' unary_expr
                | '!' unary_expr
                | '&' unary_expr                                    (* address-of *)
                | postfix_expr

postfix_expr  ::= primary_expr { postfix_op }
postfix_op    ::= '.' ident                                         (* field access *)
                | "?." ( ident | '(' expr ')' )                      (* safe-navigation field/call *)
                | '.' "cast" '[' type_expr ']'                       (* reinterpret cast *)
                | '.' "ref" '[' type_expr ']'                        (* `&x` + cast shorthand *)
                | '.' "call_as" '[' type_expr ']' '(' [ arg_list ] ')'
                | ident '?' '(' ')'                                  (* postfix-shorthand optional ctor/cast *)
                | ident '(' ')'                                      (* postfix-shorthand ctor/cast, e.g. x.i32() *)
                | '(' [ arg_list ] ')'                               (* call *)
                | '[' expr ']'                                       (* index *)
                | "::" ident                                        (* qualified access continuation *)
                | ident '.' "of" '.' ident                           (* enum column: `EnumName of .field` *)

arg_list      ::= arg { ',' arg } [ ',' "..." ]                      (* trailing arg-forward `...` *)
arg           ::= [ ident ':' ] expr                                 (* positional or named *)

primary_expr  ::= int_lit | hex_lit | float_lit | string_lit | char_lit
                | "null" | "true" | "false" | "zeroed"
                | '.' ident { '.' ident }                            (* shorthand member expr: `.Variant` *)
                | list_lit | brace_lit
                | ( "sizeof" | "size_of" ) type_arg [ '(' ')' ]
                | ( "alignof" | "align_of" ) type_arg [ '(' ')' ]
                | ( "offsetof" | "offset_of" ) ( '[' type_expr ']' '(' ident ')' | '(' type_expr ',' ident ')' )
                | "try" [ or_expr ]
                | catch_expr
                | match_expr
                | "raise" or_expr
                | query_expr
                | "do" ':' expr_block_value
                | ( "lambda" | 'λ' ) lambda_expr
                | "cascade" cascade_expr
                | "get" ident postfix_expr [ "else" expr ]            (* `?`-operator equivalent (docs/80) *)
                | "rewrite" rewrite_expr
                | qualified_ident [ struct_lit_tail ]                 (* ident / qualified name / ctor call *)
                | '(' expr ')'
                | quantifier_expr

list_lit      ::= '[' [ list_elem { ',' list_elem } | list_comprehension ] ']'
list_elem     ::= [ "..." ] expr                                     (* spread element *)
list_comprehension
              ::= [ comp_head_binding { ',' comp_head_binding } ',' ] expr "for" for_pattern "in" expr [ "if" expr ]
comp_head_binding
              ::= ident [ ':' type_expr ] '=' expr                   (* head-binding sugar (list form only) *)

brace_lit     ::= '{' [ brace_body ] '}'
brace_body    ::= dict_entry { ',' dict_entry }                      (* dict literal *)
                | expr "for" for_pattern "in" expr [ "if" expr ]      (* set comprehension *)
                | expr ':' expr "for" for_pattern "in" expr [ "if" expr ]  (* dict comprehension *)
                | ident '=' expr ',' set_or_dict_comprehension        (* head-binding dict/set comprehension *)
                | membership_candidate { ',' membership_candidate }   (* set-membership literal *)
                | struct_field { ',' struct_field }                   (* struct brace literal (see struct_lit_tail) *)
dict_entry    ::= expr ':' expr
membership_candidate
              ::= expr [ ( ".." | "..<" | "..>" | "..=" ) expr ]
set_or_dict_comprehension
              ::= expr [ ':' expr ] "for" for_pattern "in" expr [ "if" expr ]

struct_lit_tail
              ::= [ '[' type_expr { ',' type_expr } ']' ] ( '(' [ struct_arg { ',' struct_arg } ] ')'
                                                           | '{' [ struct_field { ',' struct_field } ] '}' )
struct_arg    ::= [ ident ':' ] expr
struct_field  ::= [ "..." ] ident [ ':' expr ]                       (* `...other` spread, or `name`/`name: expr` *)

catch_expr    ::= "catch" expr ':' NEWLINE INDENT { catch_arm } DEDENT
catch_arm     ::= ( qualified_ident [ '(' [ pattern_or { ',' pattern_or } ] ')' ] | "_" ) ':' block(stmt)

match_expr    ::= "match" expr ':' NEWLINE INDENT { match_expr_arm } DEDENT
match_expr_arm ::= pattern_or [ "if" expr ] ':' expr NEWLINE

query_expr    ::= ?LINQ-like query pipeline over a collection — from/where/select-style sugar?

expr_block_value
              ::= NEWLINE INDENT { stmt } expr NEWLINE DEDENT         (* `do:` block yielding a value *)

lambda_expr   ::= '(' [ param_list ] ')' [ "->" type_expr ] ':' ( expr | expr_block_value )

cascade_expr  ::= expr ':' NEWLINE INDENT { '.' ident { postfix_op } NEWLINE } DEDENT
                   (* `cascade obj: .method(...) \n .other(...)` chains onto `obj` *)

rewrite_expr  ::= expr "to" expr                                      (* proof/refinement rewrite step *)

quantifier_expr
              ::= ( "forall" | "exists" ) for_pattern "in" expr ':' expr

(* ---- `is`-test / refinement-binding grammar (docs/80) -------------------- *)
is_test_expr  ::= '[' is_test_target { '|' is_test_target } ']'       (* bracketed union-of-targets *)
                | is_test_target { '|' is_test_target }
is_test_target
              ::= is_test_target_bare [ "as" ident | ident ]           (* trailing alias / binder sugar *)
is_test_target_bare
              ::= qualified_variant_target '(' [ match_pattern_arg { ',' match_pattern_arg } ] ')'  (* variant test *)
                | ident struct_pattern_tail                            (* struct test *)
                | '.' postfix_expr                                     (* shorthand-member test *)
                | '(' is_test_expr ')'
                | ident ident                                          (* `Type binder` sugar *)
                | type_expr                                            (* bare type test *)
qualified_variant_target
              ::= ident { '.' ident }
struct_pattern_tail
              ::= '(' [ struct_pattern_field { ',' struct_pattern_field } ] ')'
                | '{' [ struct_pattern_field { ',' struct_pattern_field } ] '}'
match_pattern_arg
              ::= pattern_or


(* ==========================================================================
   6. Types
   ========================================================================== *)

type_expr     ::= optional_type
optional_type ::= ref_type [ '?' ]                                    (* `T?` = Optional[T] sugar *)
ref_type      ::= base_type { '&' [ "mutable" ] }                       (* `T&`, `mutable T&` (canonical:
                                                                            `mutable` sits inside the type) *)
base_type     ::= builtin_type
                | qualified_ident [ generic_args ]                    (* named / generic type: `T[U]` *)
                | "func" '(' [ type_expr { ',' type_expr } ] ')' [ "->" type_expr ]
                | '(' type_expr { ',' type_expr } ')'                   (* tuple type *)
                | "view" '[' type_expr ']'                              (* view type *)
                | "darray" '[' type_expr ']'
                | "dict" '[' type_expr ',' type_expr ']'
                | "set" '[' type_expr ']'

generic_args  ::= '[' type_expr { ',' type_expr } ']'

builtin_type  ::= "void" | "bool" | "char"
                | "int" | "i8" | "i16" | "i32" | "i64" | "isize"
                | "u8" | "u16" | "u32" | "u64" | "usize" | "uintptr"
                | "f32" | "f64" | "cstr" | "dstr"


(* ==========================================================================
   Notes on ambiguity resolution (informative — matches parser heuristics)
   ========================================================================== *
   - `<-` (mutation) vs `=` (introduction/rebinding at declaration site) is
     the canonical mutability marker; there is no plain `x = expr` mutation
     of an existing binding.
   - `is` after a comparison-level expression dispatches to either a TYPE
     test, a VARIANT/STRUCT test, or a refutable BARE BINDING, disambiguated
     by: builtin/type-name vs lowercase-non-builtin identifier, and by the
     token immediately following (docs/80).
   - `get IDENT ...` (no `else`) is sugar for "propagate None": absence
     early-returns the enclosing function's `null`/None, mirroring Rust's
     `?` operator; `get EXPR else EXPR2` supplies an explicit fallback.
   - `break if COND` / `continue if COND` / bare `return if COND` are
     postfix guards, desugaring at parse time to `if COND: break` /
     `if COND: continue` / `if COND: return` — no new AST node.
   - Several legacy forms are hard-parse-errors that this grammar does NOT
     accept, though the parser recognizes and rejects them with a directed
     diagnostic: `.cast[T]()`, `.ref[T]()` trailing calls, `.specialize[T]()`,
     legacy `!`-suffixed reference casts, `try? ... default`, `sizeof`/
     `alignof`/`offsetof` (use the `_`-spelled forms), `[...] in <owner>`
     list-owner, `enum ... layout(index: uN)` (use `handle:`), raw
     concurrency primitives (`spawn1`, `pool_submit1`, `cond_wait`, raw
     atomics) outside of the safe sugar forms shown above.
   ========================================================================== *)
