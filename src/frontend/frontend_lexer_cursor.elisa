@inline(always)
def peek(lexer: Lexer&, offset: usize) -> char:
    return char_at(lexer.source, lexer.source_len, lexer.position + offset)

@inline(always)
def make_source_view(source: u8&, start: usize, end: usize) -> sview?:
    if end <= start:
        return null
    return sview(source, start.i64(), end.i64())

@inline(always)
def advance_char(lexer: mutable Lexer&) -> char:
    if lexer.is_eof():
        return NULL_CHAR

    ch: char = lexer.current_char()
    lexer.position <- lexer.position + 1
    if ch == '\n':
        lexer.line <- lexer.line + 1
        lexer.column <- 1
    else:
        lexer.column <- lexer.column + 1
    return ch
