@inline(always)
def char_at(source: u8&, source_len: usize, index: usize) -> char:
    if index >= source_len:
        return NULL_CHAR
    return source[index].char()

@inline(always)
def current_char(lexer: Lexer&) -> char:
    return char_at(lexer.source, lexer.source_len, lexer.position)

@inline(always)
def match_char(lexer: mutable Lexer&, expected: char) -> bool:
    if lexer.current_char() == expected:
        lexer.advance_char()
        return true
    return false

def read_string(lexer: mutable Lexer&) -> Token:
    position: LexerPosition = lexer.cursor_position()
    lexer.advance_char()
    start: usize = lexer.position

    while not lexer.is_eof() and lexer.current_char() != '"' and lexer.current_char() != '\n':
        if lexer.current_char() == '\\':
            lexer.advance_char()
            if lexer.is_eof():
                return Token(TokenKind.StringLit, position, start, lexer.position)
            if lexer.current_char() == '\n':
                return Token(TokenKind.StringLit, position, start, lexer.position)
        lexer.advance_char()

    text_end: usize = lexer.position
    if not lexer.is_eof() and lexer.current_char() == '"':
        lexer.advance_char()

    return Token(TokenKind.StringLit, position, start, text_end)

def read_char(lexer: mutable Lexer&) -> Token:
    position: LexerPosition = lexer.cursor_position()
    lexer.advance_char()
    start: usize = lexer.position

    while not lexer.is_eof() and lexer.current_char() != '\'' and lexer.current_char() != '\n':
        if lexer.current_char() == '\\':
            lexer.advance_char()
            if lexer.is_eof():
                return Token(TokenKind.CharLit, position, start, lexer.position)
            if lexer.current_char() == '\n':
                return Token(TokenKind.CharLit, position, start, lexer.position)
        lexer.advance_char()

    text_end: usize = lexer.position
    if not lexer.is_eof() and lexer.current_char() == '\'':
        lexer.advance_char()

    return Token(TokenKind.CharLit, position, start, text_end)
