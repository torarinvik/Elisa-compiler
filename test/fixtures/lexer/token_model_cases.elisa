include "../../../src/frontend/elisacore_frontend.elisa"


const FRONTEND_TOKEN_HASH_OFFSET = 1469598103934665603
const FRONTEND_TOKEN_HASH_PRIME = 1099511628211


def frontend_expect_token_count(tokens: darray[Token], expected: usize) -> bool:
    return tokens.count == expected


def frontend_kind_eq(actual: TokenKind, expected: TokenKind) -> bool:
    return actual == expected


def frontend_expect_kind(tokens: darray[Token], index: usize, expected: TokenKind) -> bool:
    if index >= tokens.count:
        return false
    return frontend_kind_eq(tokens[index].kind, expected)


def frontend_expect_kinds(tokens: darray[Token], expected: TokenKind&, count: usize) -> bool:
    if not frontend_expect_token_count(tokens, count):
        return false
    for i in 0..<count:
        if not frontend_expect_kind(tokens, i, expected[i]):
            return false
    return true


def frontend_expect_text(source: u8&, tokens: darray[Token], index: usize, expected: static u8&) -> bool:
    if index >= tokens.count:
        return false
    actual: sview = get Lexer::text(tokens[index], source) else return false
    return actual == expected


def frontend_expect_suffix(source: u8&, tokens: darray[Token], index: usize, expected: static u8&) -> bool:
    if index >= tokens.count:
        return false
    actual: sview = get Lexer::suffix(tokens[index], source) else return false
    return actual == expected


def frontend_token_kind_code(kind: TokenKind) -> u64:
    match kind:
        TokenKind.Eof:
            return 1
        TokenKind.Newline:
            return 2
        TokenKind.Indent:
            return 3
        TokenKind.Dedent:
            return 4
        TokenKind.Ident:
            return 5
        TokenKind.IntLit:
