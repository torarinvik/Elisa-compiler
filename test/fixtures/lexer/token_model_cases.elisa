def frontend_case_char_literals() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("'a' '\\n' '\\x41' '\\u0041'\n")
        expected: TokenKind[6] = [TokenKind.CharLit, TokenKind.CharLit, TokenKind.CharLit, TokenKind.CharLit, TokenKind.Newline, TokenKind.Eof]
        return frontend_expect_kinds(tokens, (&expected[0]).cast[TokenKind&], 6)


def frontend_token_hash_mix(hash: u64, value: u64) -> u64:
    return (hash ^ value) * FRONTEND_TOKEN_HASH_PRIME


def frontend_hash_sview(hash: u64, value: sview) -> u64:
    active: mutable u64 = frontend_token_hash_mix(hash, value.len.u64())
    for i in 0..<value.len:
        active <- frontend_token_hash_mix(active, value[i].u64())
    return active


def frontend_hash_source_span(hash: u64, source: u8&, start: usize, length: usize) -> u64:
    active: mutable u64 = frontend_token_hash_mix(hash, length.u64())
    for i in 0..<length:
        active <- frontend_token_hash_mix(active, source[start + i].u64())
    return active


def frontend_stage0_latin1_ident_start(byte: u8) -> bool:
    return byte == 0xAA or byte == 0xB5 or byte == 0xBA or byte in 0xC0..0xD6 or byte in 0xD8..0xF6 or byte in 0xF8..0xFF


def frontend_utf8_continuation(byte: u8) -> bool:
    return byte in 0x80..0xBF


def frontend_starts_valid_utf8_sequence(source: u8&, start: usize) -> bool:
    byte: u8 = source[start]
    if byte in 0xC2..0xDF:
        return frontend_utf8_continuation(source[start + 1])
    if byte == 0xE0:
        return source[start + 1] in 0xA0..0xBF and frontend_utf8_continuation(source[start + 2])
    if byte in 0xE1..0xEC or byte in 0xEE..0xEF:
        return frontend_utf8_continuation(source[start + 1]) and frontend_utf8_continuation(source[start + 2])
    if byte == 0xED:
        return source[start + 1] in 0x80..0x9F and frontend_utf8_continuation(source[start + 2])
    if byte == 0xF0:
        return source[start + 1] in 0x90..0xBF and frontend_utf8_continuation(source[start + 2]) and frontend_utf8_continuation(source[start + 3])
    if byte in 0xF1..0xF3:
        return frontend_utf8_continuation(source[start + 1]) and frontend_utf8_continuation(source[start + 2]) and frontend_utf8_continuation(source[start + 3])
    if byte == 0xF4:
        return source[start + 1] in 0x80..0x8F and frontend_utf8_continuation(source[start + 2]) and frontend_utf8_continuation(source[start + 3])
    return false


def frontend_hash_stage0_ident_text(hash: u64, source: u8&, start: usize, length: usize) -> u64:
    if length == 1 and source[start] >= 0x80 and (not frontend_stage0_latin1_ident_start(source[start]) or frontend_starts_valid_utf8_sequence(source, start)):
        active: mutable u64 = frontend_token_hash_mix(hash, 2)
        active <- frontend_token_hash_mix(active, (0xC0 | (source[start] / 64)).u64())
        return frontend_token_hash_mix(active, (0x80 | (source[start] % 64)).u64())
    return frontend_hash_source_span(hash, source, start, length)


def frontend_hex_digit_value(ch: char) -> int:
    match ch:
        '0':
            return 0
        '1':
            return 1
        '2':
            return 2
        '3':
            return 3
        '4':
            return 4
        '5':
            return 5
        '6':
            return 6
        '7':
            return 7
        '8':
            return 8
        '9':
            return 9
        'a':
            return 10
        'b':
            return 11
        'c':
            return 12
        'd':
            return 13
        'e':
            return 14
        'f':
            return 15
        'A':
            return 10
        'B':
            return 11
        'C':
            return 12
        'D':
            return 13
        'E':
            return 14
        'F':
            return 15
        _:
            return 0


@inline(always)
def frontend_is_hex_digit(ch: char) -> bool:
    return ch in '0'..'9' or ch in 'a'..'f' or ch in 'A'..'F'


def frontend_fixed_hex_value(value: sview, start: i64, count: i64, out: mutable int&) -> bool:
    if start + count > value.len:
        return false

    active: mutable int = 0
    for offset in 0..<count:
        ch: char = value[start + offset]
        if not frontend_is_hex_digit(ch):
            return false
        active <- active * 16 + frontend_hex_digit_value(ch)

    out[0] <- active
    return true


def frontend_consumed_hex_prefix_len(value: sview, start: i64, count: i64) -> i64:
    consumed: mutable i64 = 0
    while consumed < count and start + consumed < value.len and frontend_is_hex_digit(value[start + consumed]):
        consumed <- consumed + 1
    return consumed


def frontend_decoded_utf8_len(value: int) -> i64:
    if value < 0x80:
        return 1
    if value < 0x800:
        return 2
    if value < 0x10000:
        return 3
    return 4


def frontend_surrogate_pair_codepoint(high: int, low: int) -> int:
    return 0x10000 + (high - 0xD800) * 1024 + (low - 0xDC00)


def frontend_is_high_surrogate(value: int) -> bool:
    return value >= 0xD800 and value <= 0xDBFF


def frontend_is_low_surrogate(value: int) -> bool:
    return value >= 0xDC00 and value <= 0xDFFF


def frontend_decoded_escape_len(value: sview, esc_index: i64, next_index: mutable i64&, allow_single_quote_escape: bool) -> i64:
    esc: char = value[esc_index]
    if esc == 'x':
        byte: mutable int = 0
        if frontend_fixed_hex_value(value, esc_index + 1, 2, &byte):
            next_index[0] <- esc_index + 3
            return 1
        next_index[0] <- esc_index + 1 + frontend_consumed_hex_prefix_len(value, esc_index + 1, 2)
        return 0

    if esc == 'u':
        codepoint: mutable int = 0
        if not frontend_fixed_hex_value(value, esc_index + 1, 4, &codepoint):
            next_index[0] <- esc_index + 1 + frontend_consumed_hex_prefix_len(value, esc_index + 1, 4)
            return 0
        next_index[0] <- esc_index + 5
        if frontend_is_high_surrogate(codepoint):
            if esc_index + 6 < value.len and value[esc_index + 5] == '\\' and value[esc_index + 6] == 'u':
                low: mutable int = 0
                if frontend_fixed_hex_value(value, esc_index + 7, 4, &low) and frontend_is_low_surrogate(low):
                    next_index[0] <- esc_index + 11
                    return frontend_decoded_utf8_len(frontend_surrogate_pair_codepoint(codepoint, low))
                next_index[0] <- esc_index + 7 + frontend_consumed_hex_prefix_len(value, esc_index + 7, 4)
            return 0
        if frontend_is_low_surrogate(codepoint):
            return 0
        return frontend_decoded_utf8_len(codepoint)

    match esc:
        '\\':
            next_index[0] <- esc_index + 1
            return 1
        '\'':
            next_index[0] <- esc_index + 1
            if allow_single_quote_escape:
                return 1
            return 0
        '"':
            next_index[0] <- esc_index + 1
            return 1
        'n':
            next_index[0] <- esc_index + 1
            return 1
        'r':
            next_index[0] <- esc_index + 1
            return 1
        't':
            next_index[0] <- esc_index + 1
            return 1
        '0':
            next_index[0] <- esc_index + 1
            return 1
        _:
            next_index[0] <- esc_index + 1
            return 0


def frontend_hash_decoded_escape(hash: u64, value: sview, esc_index: i64, next_index: mutable i64&, allow_single_quote_escape: bool) -> u64:
    esc: char = value[esc_index]
    if esc == 'x':
        byte: mutable int = 0
        if frontend_fixed_hex_value(value, esc_index + 1, 2, &byte):
            next_index[0] <- esc_index + 3
            return frontend_token_hash_mix(hash, byte.u64())
        next_index[0] <- esc_index + 1 + frontend_consumed_hex_prefix_len(value, esc_index + 1, 2)
        return hash

    if esc == 'u':
        codepoint: mutable int = 0
        if not frontend_fixed_hex_value(value, esc_index + 1, 4, &codepoint):
            next_index[0] <- esc_index + 1 + frontend_consumed_hex_prefix_len(value, esc_index + 1, 4)
            return hash
        next_index[0] <- esc_index + 5
        if frontend_is_high_surrogate(codepoint):
            if esc_index + 6 < value.len and value[esc_index + 5] == '\\' and value[esc_index + 6] == 'u':
                low: mutable int = 0
                if frontend_fixed_hex_value(value, esc_index + 7, 4, &low) and frontend_is_low_surrogate(low):
                    next_index[0] <- esc_index + 11
                    return frontend_hash_utf8_codepoint(hash, frontend_surrogate_pair_codepoint(codepoint, low))
                next_index[0] <- esc_index + 7 + frontend_consumed_hex_prefix_len(value, esc_index + 7, 4)
            return hash
        if frontend_is_low_surrogate(codepoint):
            return hash
        return frontend_hash_utf8_codepoint(hash, codepoint)

    match esc:
        '\\':
            next_index[0] <- esc_index + 1
            return frontend_token_hash_mix(hash, '\\'.u64())
        '\'':
            next_index[0] <- esc_index + 1
            if allow_single_quote_escape:
                return frontend_token_hash_mix(hash, '\''.u64())
            return hash
        '"':
            next_index[0] <- esc_index + 1
            return frontend_token_hash_mix(hash, '"'.u64())
        'n':
            next_index[0] <- esc_index + 1
            return frontend_token_hash_mix(hash, 10)
        'r':
            next_index[0] <- esc_index + 1
            return frontend_token_hash_mix(hash, 13)
        't':
            next_index[0] <- esc_index + 1
            return frontend_token_hash_mix(hash, 9)
        '0':
            next_index[0] <- esc_index + 1
            return frontend_token_hash_mix(hash, 0)
        _:
            next_index[0] <- esc_index + 1
            return hash


def frontend_hash_utf8_codepoint(hash: u64, value: int) -> u64:
    if value < 0x80:
        return frontend_token_hash_mix(hash, value.u64())
    if value < 0x800:
        active: mutable u64 = frontend_token_hash_mix(hash, (0xC0 | (value / 64)).u64())
        return frontend_token_hash_mix(active, (0x80 | (value % 64)).u64())
    if value < 0x10000:
        active: mutable u64 = frontend_token_hash_mix(hash, (0xE0 | (value / 4096)).u64())
        active <- frontend_token_hash_mix(active, (0x80 | ((value / 64) % 64)).u64())
        return frontend_token_hash_mix(active, (0x80 | (value % 64)).u64())
    active: mutable u64 = frontend_token_hash_mix(hash, (0xF0 | (value / 262144)).u64())
    active <- frontend_token_hash_mix(active, (0x80 | ((value / 4096) % 64)).u64())
    active <- frontend_token_hash_mix(active, (0x80 | ((value / 64) % 64)).u64())
    return frontend_token_hash_mix(active, (0x80 | (value % 64)).u64())


def frontend_case_malformed_escape_checksums() -> bool:
    can Memory.Allocate, Abort.Panic:
        malformed: static u8& = "\"\\x4\"\n\"\\xg0\"\n\"\\x0g\"\n\"\\z\"\n"
        surrogate: static u8& = "\"\\uD83D\\uDE00\"\n\"\\uD83D\"\n\"\\uDE00\"\n"
        return frontend_lexer_token_full_checksum(malformed.cast[u8&]) == 3316119082611457636 and frontend_lexer_token_full_checksum(surrogate.cast[u8&]) == 17793447398112395163


def frontend_case_line_directive_inside_grouping_checksum() -> bool:
    can Memory.Allocate, Abort.Panic:
        source: static u8& = "{\n#line 2~"
        return frontend_lexer_token_full_checksum(source.cast[u8&]) == 13101218515546342978


def frontend_case_backslash_newline_literal_checksums() -> bool:
    can Memory.Allocate, Abort.Panic:
        string_source: static u8& = "\"\\\n"
        char_source: static u8& = "'\\\n"
        return frontend_lexer_token_full_checksum(string_source.cast[u8&]) == 12003011313434608900 and frontend_lexer_token_full_checksum(char_source.cast[u8&]) == 15344937586264664632


def frontend_case_single_quote_escape_in_string_checksum() -> bool:
    can Memory.Allocate, Abort.Panic:
        string_source: static u8& = "\"\\'"
        char_source: static u8& = "'\\''"
        return frontend_lexer_token_full_checksum(string_source.cast[u8&]) == 4844721603692702410 and frontend_lexer_token_full_checksum(char_source.cast[u8&]) == 523973950063774685


def frontend_case_line_zero_directive_normalized_checksum() -> bool:
    can Memory.Allocate, Abort.Panic:
        source: static u8& = "#line 0>\n\n"
        return frontend_lexer_token_full_checksum(source.cast[u8&]) == 8635315372005771610


def frontend_decoded_literal_len(value: sview, allow_single_quote_escape: bool) -> i64:
    length: mutable i64 = 0
    i: mutable i64 = 0
    while i < value.len:
        ch: char = value[i]
        if ch != '\\':
            length <- length + 1
            i <- i + 1
        else:
            i <- i + 1
            if i >= value.len:
                return length
            next: mutable i64 = i + 1
            length <- length + frontend_decoded_escape_len(value, i, &next, allow_single_quote_escape)
            i <- next
    return length


def frontend_hash_decoded_literal(hash: u64, value: sview, allow_single_quote_escape: bool) -> u64:
    active: mutable u64 = frontend_token_hash_mix(hash, frontend_decoded_literal_len(value, allow_single_quote_escape).u64())
    i: mutable i64 = 0
    while i < value.len:
        ch: char = value[i]
        if ch != '\\':
            active <- frontend_token_hash_mix(active, ch.u64())
            i <- i + 1
        else:
            i <- i + 1
            if i >= value.len:
                return active
            next: mutable i64 = i + 1
            active <- frontend_hash_decoded_escape(active, value, i, &next, allow_single_quote_escape)
            i <- next
    return active


def frontend_hash_token(hash: u64, token: Token) -> u64:
    return frontend_token_hash_mix(hash, frontend_token_kind_code(token.kind))


def frontend_hash_token_full_with_line(hash: u64, token: Token, source: u8&, line_value: u64) -> u64:
    active: mutable u64 = frontend_token_hash_mix(hash, frontend_token_kind_code(token.kind))
    active <- frontend_token_hash_mix(active, line_value)
    active <- frontend_token_hash_mix(active, token.column.u64())
    text: sview = Lexer::text_or_empty(token, source)
    if token.kind == TokenKind.StringLit:
        active <- frontend_hash_decoded_literal(active, text, false)
    elif token.kind == TokenKind.CharLit:
        active <- frontend_hash_decoded_literal(active, text, true)
    else:
        active <- frontend_hash_stage0_ident_text(active, source, token.start.usize(), token.length.usize())
    active <- frontend_hash_source_span(active, source, token.start.usize() + token.length.usize(), token.suffix_length.usize())
    return active


def frontend_hash_token_full(hash: u64, token: Token, source: u8&) -> u64:
    return frontend_hash_token_full_with_line(hash, token, source, token.line.u64())


def frontend_collapsed_newline_line_value(token: Token, source: u8&) -> u64:
    start: usize = token.start.usize()
    line_value: mutable u64 = 0
    while source[start + line_value.usize()] == '\n':
        line_value <- line_value + 1
    if line_value == 0:
        return 1
    return line_value


def frontend_token_checksum(tokens: darray[Token]) -> u64:
    hash: mutable u64 = frontend_token_hash_mix(FRONTEND_TOKEN_HASH_OFFSET, tokens.count.u64())
    for token in tokens:
        hash <- frontend_hash_token(hash, token)
    return hash


def frontend_token_full_checksum(source: u8&, tokens: darray[Token]) -> u64:
    hash: mutable u64 = frontend_token_hash_mix(FRONTEND_TOKEN_HASH_OFFSET, tokens.count.u64())
    i: mutable usize = 0
    while i < tokens.count:
        token: Token = tokens[i]
        line_value: mutable u64 = token.line.u64()
        if token.kind == TokenKind.Newline and token.line == 0:
            line_value <- frontend_collapsed_newline_line_value(token, source)
        hash <- frontend_hash_token_full_with_line(hash, token, source, line_value)
        i <- i + 1
    return hash


struct FrontendLexerChecksums:
    kind: mutable u64
    full: mutable u64


def frontend_lexer_stream_checksums_with_len(source: u8&, source_len: usize) -> FrontendLexerChecksums:
    can Memory.Allocate, Abort.Panic:
        lexer: mutable Lexer = Lexer::Lexer("frontend_lexer_bench.elisa", source, source_len)
        kind_hash: mutable u64 = FRONTEND_TOKEN_HASH_OFFSET
        full_hash: mutable u64 = FRONTEND_TOKEN_HASH_OFFSET

        while true:
            token: Token = Lexer::next_token(lexer)
            kind_hash <- frontend_hash_token(kind_hash, token)
            if token.kind == TokenKind.Newline and token.line == 0:
                full_hash <- frontend_hash_token_full_with_line(full_hash, token, source, frontend_collapsed_newline_line_value(token, source))
            else:
                full_hash <- frontend_hash_token_full(full_hash, token, source)
            if token.kind == TokenKind.Eof:
                return FrontendLexerChecksums{kind: kind_hash, full: full_hash}

        return FrontendLexerChecksums{kind: kind_hash, full: full_hash}


def frontend_tokenize_test_source(source: u8&) -> darray[Token]:
    can Memory.Allocate, Abort.Panic:
        lexer: mutable Lexer = Lexer::Lexer("frontend_lexer_test.elisa", source)
        tokens: mutable darray[Token] = []

        while true:
            token: Token = Lexer::next_token(lexer)
            tokens.push(token)
            match token.kind:
                TokenKind.Eof:
                    return tokens
                _:
                    pass

        return tokens


def frontend_tokenize_literal(source: static u8&) -> darray[Token]:
    can Memory.Allocate, Abort.Panic:
        source_ptr: u8& = source.cast[u8&]
        return frontend_tokenize_test_source(source_ptr)


# Test-only (text, expected-kind) pair used to table-drive the keyword self-test
# below. The lexer itself no longer needs this struct: keyword classification is
# the `keywordmap frontend_lookup_keyword` in frontend_lexer_identifiers.elisa.
struct KeywordEntry:
    text: mutable static u8&
    kind: mutable TokenKind
def frontend_expect_lookup_keyword(text: static u8&, expected: TokenKind) -> bool:
    text_ptr: u8& = text.cast[u8&]
    return frontend_kind_eq(Lexer::frontend_lookup_keyword(sview(text_ptr, 0, runtime_strlen(text_ptr).i64())), expected)


def frontend_expect_lookup_keyword_entries(entries: KeywordEntry&, count: usize) -> bool:
    for i in 0..<count:
        entry: KeywordEntry = entries[i]
        if not frontend_expect_lookup_keyword(entry.text, entry.kind):
            return false
    return true
