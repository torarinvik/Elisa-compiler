def frontend_case_simple_ident() -> bool:
    can Memory.Allocate, Abort.Panic:
        source: static u8& = "hello\n"
        tokens: darray[Token] = frontend_tokenize_literal(source)
        expected: TokenKind[3] = [TokenKind.Ident, TokenKind.Newline, TokenKind.Eof]
        return frontend_expect_kinds(tokens, &expected[0], 3) and frontend_expect_text(source.cast[u8&], tokens, 0, "hello")


def frontend_case_arrow_ops() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("x <- y -> z\n")
        expected: TokenKind[7] = [TokenKind.Ident, TokenKind.LArrow, TokenKind.Ident, TokenKind.Arrow, TokenKind.Ident, TokenKind.Newline, TokenKind.Eof]
        return frontend_expect_kinds(tokens, &expected[0], 7)


def frontend_case_number_literals() -> bool:
    can Memory.Allocate, Abort.Panic:
        source: static u8& = "42 0xff 123u64 0xABi32\n"
        tokens: darray[Token] = frontend_tokenize_literal(source)
        expected: TokenKind[6] = [TokenKind.IntLit, TokenKind.HexLit, TokenKind.IntLit, TokenKind.HexLit, TokenKind.Newline, TokenKind.Eof]
        return frontend_expect_kinds(tokens, &expected[0], 6) and frontend_expect_suffix(source.cast[u8&], tokens, 2, "u64") and frontend_expect_suffix(source.cast[u8&], tokens, 3, "i32")


def frontend_case_indent_dedent() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("def foo:\n    x <- 1\n    y <- 2\nz <- 3\n")
        expected: TokenKind[19] = [
            TokenKind.Def, TokenKind.Ident, TokenKind.Colon, TokenKind.Newline,
            TokenKind.Indent, TokenKind.Ident, TokenKind.LArrow, TokenKind.IntLit, TokenKind.Newline,
            TokenKind.Ident, TokenKind.LArrow, TokenKind.IntLit, TokenKind.Newline,
            TokenKind.Dedent, TokenKind.Ident, TokenKind.LArrow, TokenKind.IntLit, TokenKind.Newline,
            TokenKind.Eof
        ]
        return frontend_expect_kinds(tokens, &expected[0], 19)


def frontend_case_intermediate_indent_at_eof() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("  e\n <")
        expected: TokenKind[8] = [
            TokenKind.Indent, TokenKind.Ident, TokenKind.Newline,
            TokenKind.Dedent, TokenKind.Indent, TokenKind.Lt,
            TokenKind.Dedent, TokenKind.Eof
        ]
        return frontend_expect_kinds(tokens, &expected[0], 8)


def frontend_case_empty_block_comment_before_indent() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("\"\"\"\"\"\"\n z")
        expected: TokenKind[4] = [TokenKind.Indent, TokenKind.Ident, TokenKind.Dedent, TokenKind.Eof]
        return frontend_expect_kinds(tokens, &expected[0], 4)


def frontend_case_do_grouped_block_preserves_newline() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("{\"\"do:\n")
        expected: TokenKind[6] = [TokenKind.LBrace, TokenKind.StringLit, TokenKind.Ident, TokenKind.Colon, TokenKind.Newline, TokenKind.Eof]
        return frontend_expect_kinds(tokens, &expected[0], 6)


def frontend_case_plain_brace_suppresses_newline() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("{\n}%m\n")
        expected: TokenKind[6] = [TokenKind.LBrace, TokenKind.RBrace, TokenKind.Percent, TokenKind.Ident, TokenKind.Newline, TokenKind.Eof]
        return frontend_expect_kinds(tokens, &expected[0], 6)


def frontend_case_static_generate_interpolation_ident() -> bool:
    can Memory.Allocate, Abort.Panic:
        source: static u8& = "emit def static_generate_expr_is_${variant.name}(expr: StaticGenerateExpr) -> bool:\n"
        tokens: darray[Token] = frontend_tokenize_literal(source)
        expected: TokenKind[16] = [
            TokenKind.Ident, TokenKind.Def, TokenKind.Ident, TokenKind.Dot,
            TokenKind.Ident, TokenKind.RBrace, TokenKind.LParen, TokenKind.Ident,
            TokenKind.Colon, TokenKind.Ident, TokenKind.RParen, TokenKind.Arrow,
            TokenKind.Ident, TokenKind.Colon, TokenKind.Newline, TokenKind.Eof
        ]
        return frontend_expect_kinds(tokens, &expected[0], 16) and frontend_expect_text(source.cast[u8&], tokens, 2, "static_generate_expr_is_${variant")


def frontend_case_invalid_byte_ident_text_checksum() -> bool:
    can Memory.Allocate, Abort.Panic:
        source: u8[1] = [0x94]
        checksums: FrontendLexerChecksums = frontend_lexer_stream_checksums_with_len((&source[0]).cast[u8&], 1)
        return checksums.kind == 11129316073287017513 and checksums.full == 12415680063486533324


def frontend_case_unicode_identifier_checksums() -> bool:
    can Memory.Allocate, Abort.Panic:
        utf8_ident: u8[4] = ['a', 0xC3, 0xA3, 'b']
        malformed_latin1: u8[3] = [0xE3, 0xB5, 0xE3]
        unicode_digit_cont: u8[4] = ['L', 0xDF, 0x84, 'x']
        valid_nonletter_utf8: u8[2] = [0xC2, 0x94]

        utf8_ident_checksums: FrontendLexerChecksums = frontend_lexer_stream_checksums_with_len((&utf8_ident[0]).cast[u8&], 4)
        malformed_checksums: FrontendLexerChecksums = frontend_lexer_stream_checksums_with_len((&malformed_latin1[0]).cast[u8&], 3)
        digit_checksums: FrontendLexerChecksums = frontend_lexer_stream_checksums_with_len((&unicode_digit_cont[0]).cast[u8&], 4)
        nonletter_checksums: FrontendLexerChecksums = frontend_lexer_stream_checksums_with_len((&valid_nonletter_utf8[0]).cast[u8&], 2)

        return utf8_ident_checksums.kind == 11129316073287017513 and utf8_ident_checksums.full == 1415651573016186572 and malformed_checksums.kind == 11129316073287017513 and malformed_checksums.full == 9926796145220622540 and digit_checksums.kind == 11129316073287017513 and digit_checksums.full == 6697980297914226576 and nonletter_checksums.kind == 14074227463623851164 and nonletter_checksums.full == 9966431036573276702


def frontend_case_comment_and_ellipsis() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("#x\n...\n")
        expected: TokenKind[3] = [TokenKind.Ellipsis, TokenKind.Newline, TokenKind.Eof]
        return frontend_expect_kinds(tokens, &expected[0], 3)


def frontend_case_shift_ops() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("x << 3 >> 2\n")
        expected: TokenKind[7] = [TokenKind.Ident, TokenKind.LShift, TokenKind.IntLit, TokenKind.RShift, TokenKind.IntLit, TokenKind.Newline, TokenKind.Eof]
        return frontend_expect_kinds(tokens, &expected[0], 7)


def frontend_case_paren_suppresses_newline() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("foo(a,\n    b)\n")
        expected: TokenKind[8] = [TokenKind.Ident, TokenKind.LParen, TokenKind.Ident, TokenKind.Comma, TokenKind.Ident, TokenKind.RParen, TokenKind.Newline, TokenKind.Eof]
        return frontend_expect_kinds(tokens, &expected[0], 8)


def frontend_case_region_alloc_syntax() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("region parse\nvalue: i32& = new[parse] 1\ndestroy parse\n")
        expected: TokenKind[18] = [
            TokenKind.Ident, TokenKind.Ident, TokenKind.Newline,
            TokenKind.Ident, TokenKind.Colon, TokenKind.Ident, TokenKind.Ampersand,
            TokenKind.Assign, TokenKind.Ident, TokenKind.LBracket, TokenKind.Ident,
            TokenKind.RBracket, TokenKind.IntLit, TokenKind.Newline,
            TokenKind.Ident, TokenKind.Ident, TokenKind.Newline, TokenKind.Eof
        ]
        return frontend_expect_kinds(tokens, &expected[0], 18)


def frontend_case_with_and_context_keywords() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("with context\n")
        expected: TokenKind[4] = [TokenKind.With, TokenKind.Ident, TokenKind.Newline, TokenKind.Eof]
        return frontend_expect_kinds(tokens, &expected[0], 4)


def frontend_case_lookup_keyword_table() -> bool:
    entries: KeywordEntry[51] = [
        KeywordEntry{text: "as", kind: TokenKind.As},
        KeywordEntry{text: "if", kind: TokenKind.If},
        KeywordEntry{text: "in", kind: TokenKind.In},
        KeywordEntry{text: "is", kind: TokenKind.Is},
        KeywordEntry{text: "or", kind: TokenKind.Or},
        KeywordEntry{text: "to", kind: TokenKind.To},
        KeywordEntry{text: "and", kind: TokenKind.And},
        KeywordEntry{text: "catch", kind: TokenKind.Catch},
        KeywordEntry{text: "def", kind: TokenKind.Def},
        KeywordEntry{text: "not", kind: TokenKind.Not},
        KeywordEntry{text: "try", kind: TokenKind.Try},
        KeywordEntry{text: "elif", kind: TokenKind.Elif},
        KeywordEntry{text: "else", kind: TokenKind.Else},
        KeywordEntry{text: "enum", kind: TokenKind.Enum},
        KeywordEntry{text: "heap", kind: TokenKind.Heap},
        KeywordEntry{text: "null", kind: TokenKind.Null},
        KeywordEntry{text: "pass", kind: TokenKind.Pass},
        KeywordEntry{text: "repr", kind: TokenKind.Repr},
        KeywordEntry{text: "tail", kind: TokenKind.Tail},
        KeywordEntry{text: "true", kind: TokenKind.True},
        KeywordEntry{text: "with", kind: TokenKind.With},
        KeywordEntry{text: "const", kind: TokenKind.Const},
        KeywordEntry{text: "error", kind: TokenKind.Error},
        KeywordEntry{text: "false", kind: TokenKind.False},
        KeywordEntry{text: "match", kind: TokenKind.Match},
        KeywordEntry{text: "panic", kind: TokenKind.Panic},
        KeywordEntry{text: "raise", kind: TokenKind.Raise},
        KeywordEntry{text: "stack", kind: TokenKind.Stack},
        KeywordEntry{text: "while", kind: TokenKind.While},
        KeywordEntry{text: "export", kind: TokenKind.Export},
        KeywordEntry{text: "extern", kind: TokenKind.Extern},
        KeywordEntry{text: "global", kind: TokenKind.Global},
        KeywordEntry{text: "packed", kind: TokenKind.Packed},
        KeywordEntry{text: "return", kind: TokenKind.Return},
        KeywordEntry{text: "sizeof", kind: TokenKind.Sizeof},
        KeywordEntry{text: "size_of", kind: TokenKind.Sizeof},
        KeywordEntry{text: "alignof", kind: TokenKind.Alignof},
        KeywordEntry{text: "align_of", kind: TokenKind.Alignof},
        KeywordEntry{text: "offsetof", kind: TokenKind.Offsetof},
        KeywordEntry{text: "offset_of", kind: TokenKind.Offsetof},
        KeywordEntry{text: "static", kind: TokenKind.Static},
        KeywordEntry{text: "struct", kind: TokenKind.Struct},
        KeywordEntry{text: "zeroed", kind: TokenKind.Zeroed},
        KeywordEntry{text: "aligned", kind: TokenKind.Ident},
        KeywordEntry{text: "context", kind: TokenKind.Ident},
        KeywordEntry{text: "mutable", kind: TokenKind.Mutable},
        KeywordEntry{text: "region", kind: TokenKind.Ident},
        KeywordEntry{text: "new", kind: TokenKind.Ident},
        KeywordEntry{text: "destroy", kind: TokenKind.Ident},
        KeywordEntry{text: "defin", kind: TokenKind.Ident},
        KeywordEntry{text: "truer", kind: TokenKind.Ident}
    ]
    return frontend_expect_lookup_keyword_entries(&entries[0], 51)


def frontend_case_kind_only_keyword_path() -> bool:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_literal("false true zeroed with is context region new destroy 123u64 0xABi32\n")
        expected: TokenKind[13] = [
            TokenKind.False, TokenKind.True, TokenKind.Zeroed, TokenKind.With,
            TokenKind.Is, TokenKind.Ident, TokenKind.Ident, TokenKind.Ident, TokenKind.Ident,
            TokenKind.IntLit, TokenKind.HexLit, TokenKind.Newline, TokenKind.Eof
        ]
        return frontend_expect_kinds(tokens, &expected[0], 13)


def frontend_lexer_parity_suite() -> int:
    can Memory.Allocate, Abort.Panic:
        if not frontend_case_simple_ident():
            return 0
        if not frontend_case_arrow_ops():
            return 0
        if not frontend_case_number_literals():
            return 0
        if not frontend_case_indent_dedent():
            return 0
        if not frontend_case_intermediate_indent_at_eof():
            return 0
        if not frontend_case_empty_block_comment_before_indent():
            return 0
        if not frontend_case_do_grouped_block_preserves_newline():
            return 0
        if not frontend_case_plain_brace_suppresses_newline():
            return 0
        if not frontend_case_static_generate_interpolation_ident():
            return 0
        if not frontend_case_invalid_byte_ident_text_checksum():
            return 0
        if not frontend_case_unicode_identifier_checksums():
            return 0
        if not frontend_case_comment_and_ellipsis():
            return 0
        if not frontend_case_shift_ops():
            return 0
        if not frontend_case_paren_suppresses_newline():
            return 0
        if not frontend_case_region_alloc_syntax():
            return 0
        if not frontend_case_with_and_context_keywords():
            return 0
        if not frontend_case_lookup_keyword_table():
            return 0
        if not frontend_case_kind_only_keyword_path():
            return 0
        if not frontend_case_char_literals():
            return 0
        if not frontend_case_malformed_escape_checksums():
            return 0
        if not frontend_case_line_directive_inside_grouping_checksum():
            return 0
        if not frontend_case_backslash_newline_literal_checksums():
            return 0
        if not frontend_case_single_quote_escape_in_string_checksum():
            return 0
        if not frontend_case_line_zero_directive_normalized_checksum():
            return 0
        return 1


def frontend_lexer_token_checksum(source: u8&) -> u64:
    checksum: u64 = frontend_lexer_token_checksum_with_len(source, runtime_strlen(source)) can Memory.Allocate, Abort.Panic
    return checksum


def frontend_lexer_token_checksum_with_len(source: u8&, source_len: usize) -> u64:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len("frontend_lexer_bench.elisa", source, source_len)
        return frontend_token_checksum(tokens)


def frontend_lexer_token_full_checksum(source: u8&) -> u64:
    checksum: u64 = frontend_lexer_token_full_checksum_with_len(source, runtime_strlen(source)) can Memory.Allocate, Abort.Panic
    return checksum


def frontend_lexer_token_full_checksum_with_len(source: u8&, source_len: usize) -> u64:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len("frontend_lexer_bench.elisa", source, source_len)
        return frontend_token_full_checksum(source, tokens)
