        FrontendKeywordEntry{text: "alignof", kind: FrontendTokenKind.Alignof},
        FrontendKeywordEntry{text: "offsetof", kind: FrontendTokenKind.Offsetof},
        FrontendKeywordEntry{text: "static", kind: FrontendTokenKind.Static},
        FrontendKeywordEntry{text: "struct", kind: FrontendTokenKind.Struct},
        FrontendKeywordEntry{text: "zeroed", kind: FrontendTokenKind.Zeroed},
        FrontendKeywordEntry{text: "aligned", kind: FrontendTokenKind.Ident},
        FrontendKeywordEntry{text: "context", kind: FrontendTokenKind.Ident},
        FrontendKeywordEntry{text: "mutable", kind: FrontendTokenKind.Mutable},
        FrontendKeywordEntry{text: "region", kind: FrontendTokenKind.Ident},
        FrontendKeywordEntry{text: "new", kind: FrontendTokenKind.Ident},
        FrontendKeywordEntry{text: "destroy", kind: FrontendTokenKind.Ident},
