        out: bool = frontend_expect_kind(tokens, 0, TokenKind.Ident) and frontend_expect_kind(tokens, 1, TokenKind.LShift) and frontend_expect_kind(tokens, 2, TokenKind.IntLit) and frontend_expect_kind(tokens, 3, TokenKind.RShift) and frontend_expect_kind(tokens, 4, TokenKind.IntLit) and frontend_expect_kind(tokens, 5, TokenKind.Newline) and frontend_expect_kind(tokens, 6, TokenKind.Eof)
        return out


def frontend_case_paren_suppresses_newline() -> bool:
    can Memory.Allocate, Abort.Panic:
        bytes: u8[15] = [102, 111, 111, 40, 97, 44, 10, 32, 32, 32, 32, 98, 41, 10, 0]
        tokens: darray[Token] = frontend_tokenize_test_source(&bytes[0])
        if not frontend_expect_token_count(tokens, 8):
            return false
        out: bool = frontend_expect_kind(tokens, 0, TokenKind.Ident) and frontend_expect_kind(tokens, 1, TokenKind.LParen) and frontend_expect_kind(tokens, 2, TokenKind.Ident) and frontend_expect_kind(tokens, 3, TokenKind.Comma) and frontend_expect_kind(tokens, 4, TokenKind.Ident) and frontend_expect_kind(tokens, 5, TokenKind.RParen) and frontend_expect_kind(tokens, 6, TokenKind.Newline) and frontend_expect_kind(tokens, 7, TokenKind.Eof)
        return out


def frontend_case_region_alloc_syntax() -> bool:
    can Memory.Allocate, Abort.Panic:
        bytes: u8[55] = [114, 101, 103, 105, 111, 110, 32, 112, 97, 114, 115, 101, 10, 118, 97, 108, 117, 101, 58, 32, 105, 51, 50, 38, 32, 61, 32, 110, 101, 119, 91, 112, 97, 114, 115, 101, 93, 32, 49, 10, 100, 101, 115, 116, 114, 111, 121, 32, 112, 97, 114, 115, 101, 10, 0]
        tokens: darray[Token] = frontend_tokenize_test_source(&bytes[0])
        ok: bool = frontend_expect_token_count(tokens, 18) and frontend_expect_kind(tokens, 0, TokenKind.Ident) and frontend_expect_kind(tokens, 1, TokenKind.Ident) and frontend_expect_kind(tokens, 2, TokenKind.Newline) and frontend_expect_kind(tokens, 3, TokenKind.Ident) and frontend_expect_kind(tokens, 4, TokenKind.Colon) and frontend_expect_kind(tokens, 5, TokenKind.Ident) and frontend_expect_kind(tokens, 6, TokenKind.Ampersand) and frontend_expect_kind(tokens, 7, TokenKind.Assign) and frontend_expect_kind(tokens, 8, TokenKind.Ident) and frontend_expect_kind(tokens, 9, TokenKind.LBracket) and frontend_expect_kind(tokens, 10, TokenKind.Ident) and frontend_expect_kind(tokens, 11, TokenKind.RBracket) and frontend_expect_kind(tokens, 12, TokenKind.IntLit) and frontend_expect_kind(tokens, 13, TokenKind.Newline) and frontend_expect_kind(tokens, 14, TokenKind.Ident) and frontend_expect_kind(tokens, 15, TokenKind.Ident) and frontend_expect_kind(tokens, 16, TokenKind.Newline) and frontend_expect_kind(tokens, 17, TokenKind.Eof)
        return ok


