def frontend_case_number_literals() -> bool:
    can Memory.Allocate, Abort.Panic:
        region scratch(4096)
        a: mutable Arena& = (&scratch).cast[mutable Arena&]
        bytes: u8[25] = [52, 50, 32, 48, 120, 102, 102, 32, 49, 50, 51, 117, 54, 52, 32, 48, 120, 65, 66, 105, 51, 50, 10, 0, 0]
        tokens: darray[FrontendToken] = frontend_tokenize_test_source(a, &bytes[0])
        if not frontend_expect_token_count(tokens, 6):
            destroy scratch
            return false
        if not frontend_expect_kind(tokens, 0, FrontendTokenKind.IntLit):
            destroy scratch
            return false
        if not frontend_expect_kind(tokens, 1, FrontendTokenKind.HexLit):
            destroy scratch
            return false
        if not frontend_expect_kind(tokens, 2, FrontendTokenKind.IntLit):
            destroy scratch
            return false
        if not frontend_expect_kind(tokens, 3, FrontendTokenKind.HexLit):
            destroy scratch
            return false
        if not frontend_expect_kind(tokens, 4, FrontendTokenKind.Newline):
            destroy scratch
            return false
        if not frontend_expect_kind(tokens, 5, FrontendTokenKind.Eof):
            destroy scratch
            return false
        if 2 >= tokens.count:
            destroy scratch
            return false
        if not frontend_sv_eq_literal(tokens[2].suffix, "u64"):
            destroy scratch
            return false
        if 3 >= tokens.count:
            destroy scratch
            return false
        out: bool = frontend_sv_eq_literal(tokens[3].suffix, "i32")
        destroy scratch
        return out


