def frontend_case_lookup_keyword_table() -> bool:
    entries: FrontendKeywordEntry[47] = [
        FrontendKeywordEntry("as", FrontendTokenKind.As),
        FrontendKeywordEntry("if", FrontendTokenKind.If),
        FrontendKeywordEntry("in", FrontendTokenKind.In),
        FrontendKeywordEntry("or", FrontendTokenKind.Or),
        FrontendKeywordEntry("to", FrontendTokenKind.To),
        FrontendKeywordEntry("and", FrontendTokenKind.And),
        FrontendKeywordEntry("catch", FrontendTokenKind.Catch),
        FrontendKeywordEntry("def", FrontendTokenKind.Def),
        FrontendKeywordEntry("not", FrontendTokenKind.Not),
        FrontendKeywordEntry("try", FrontendTokenKind.Try),
        FrontendKeywordEntry("elif", FrontendTokenKind.Elif),
        FrontendKeywordEntry("else", FrontendTokenKind.Else),
        FrontendKeywordEntry("enum", FrontendTokenKind.Enum),
        FrontendKeywordEntry("heap", FrontendTokenKind.Heap),
        FrontendKeywordEntry("null", FrontendTokenKind.Null),
        FrontendKeywordEntry("pass", FrontendTokenKind.Pass),
        FrontendKeywordEntry("repr", FrontendTokenKind.Repr),
        FrontendKeywordEntry("tail", FrontendTokenKind.Tail),
        FrontendKeywordEntry("true", FrontendTokenKind.True),
        FrontendKeywordEntry("with", FrontendTokenKind.With),
        FrontendKeywordEntry("const", FrontendTokenKind.Const),
        FrontendKeywordEntry("error", FrontendTokenKind.Error),
        FrontendKeywordEntry("false", FrontendTokenKind.False),
        FrontendKeywordEntry("match", FrontendTokenKind.Match),
        FrontendKeywordEntry("panic", FrontendTokenKind.Panic),
        FrontendKeywordEntry("raise", FrontendTokenKind.Raise),
        FrontendKeywordEntry("stack", FrontendTokenKind.Stack),
        FrontendKeywordEntry("while", FrontendTokenKind.While),
        FrontendKeywordEntry("export", FrontendTokenKind.Export),
        FrontendKeywordEntry("extern", FrontendTokenKind.Extern),
        FrontendKeywordEntry("global", FrontendTokenKind.Global),
        FrontendKeywordEntry("packed", FrontendTokenKind.Packed),
        FrontendKeywordEntry("return", FrontendTokenKind.Return),
        FrontendKeywordEntry("sizeof", FrontendTokenKind.Sizeof),
        FrontendKeywordEntry("alignof", FrontendTokenKind.Alignof),
        FrontendKeywordEntry("offsetof", FrontendTokenKind.Offsetof),
        FrontendKeywordEntry("static", FrontendTokenKind.Static),
        FrontendKeywordEntry("struct", FrontendTokenKind.Struct),
        FrontendKeywordEntry("zeroed", FrontendTokenKind.Zeroed),
        FrontendKeywordEntry("aligned", FrontendTokenKind.Ident),
        FrontendKeywordEntry("context", FrontendTokenKind.Ident),
        FrontendKeywordEntry("mutable", FrontendTokenKind.Mutable),
        FrontendKeywordEntry("region", FrontendTokenKind.Ident),
        FrontendKeywordEntry("new", FrontendTokenKind.Ident),
        FrontendKeywordEntry("destroy", FrontendTokenKind.Ident),
        FrontendKeywordEntry("defin", FrontendTokenKind.Ident),
        FrontendKeywordEntry("truer", FrontendTokenKind.Ident)
    ]
    return frontend_expect_lookup_keyword_entries((&entries[0]).cast[FrontendKeywordEntry&], 45)


def frontend_case_kind_only_keyword_path() -> bool:
    can Memory.Allocate, Abort.Panic:
        region scratch(4096)
        a: mutable Arena& = (&scratch).cast[mutable Arena&]
        bytes: u8[66] = [102, 97, 108, 115, 101, 32, 116, 114, 117, 101, 32, 122, 101, 114, 111, 101, 100, 32, 119, 105, 116, 104, 32, 99, 111, 110, 116, 101, 120, 116, 32, 114, 101, 103, 105, 111, 110, 32, 110, 101, 119, 32, 100, 101, 115, 116, 114, 111, 121, 32, 49, 50, 51, 117, 54, 52, 32, 48, 120, 65, 66, 105, 51, 50, 10, 0]
        lexer: mutable FrontendLexer = frontend_new_lexer(a, "frontend_kind_only_test.elisa", &bytes[0])

        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.False):
            destroy scratch
            return false
        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.True):
            destroy scratch
            return false
        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.Zeroed):
            destroy scratch
            return false
        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.With):
            destroy scratch
            return false
        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.Ident):
            destroy scratch
            return false
        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.Ident):
            destroy scratch
            return false
        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.Ident):
            destroy scratch
            return false
        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.Ident):
            destroy scratch
            return false
        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.IntLit):
            destroy scratch
            return false
        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.HexLit):
            destroy scratch
            return false
        if not frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.Newline):
            destroy scratch
            return false
        out: bool = frontend_kind_eq(frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&]), FrontendTokenKind.Eof)
        destroy scratch
        return out


def frontend_lexer_parity_suite_impl() -> int:
    can Memory.Allocate, Abort.Panic:
        if not frontend_case_simple_ident():
            return 0
        if not frontend_case_arrow_ops():
            return 0
        if not frontend_case_number_literals():
            return 0
        if not frontend_case_indent_dedent():
            return 0
        if not frontend_case_comment_and_ellipsis():
            return 0
        if not frontend_case_shift_ops():
            return 0
        if not frontend_case_paren_suppresses_newline():
            return 0
        if not frontend_case_region_alloc_syntax():
            return 0
        if not frontend_case_with_and_context_keywords():
            return 0
        if not frontend_case_lookup_keyword_table():
            return 0
        if not frontend_case_kind_only_keyword_path():
            return 0
        if not frontend_case_char_literals():
            return 0
        return 1


def frontend_count_tokens(a: mutable Arena&, filename: u8&, source: u8&) -> usize:
    count: usize = frontend_count_tokens_with_len(a, filename, source, runtime_strlen(source)) can Memory.Allocate, Abort.Panic
    return count


def frontend_count_tokens_with_len(a: mutable Arena&, filename: u8&, source: u8&, source_len: usize) -> usize:
    can Memory.Allocate, Abort.Panic:
        lexer: mutable FrontendLexer = frontend_new_lexer_with_len(a, filename, source, source_len)
        count: mutable usize = 0

        while true:
            kind: FrontendTokenKind = frontend_next_token_kind((&lexer).cast[mutable FrontendLexer&])
            count <- count + 1
            match kind:
                FrontendTokenKind.Eof:
                    return count
                _:
                    pass

        return count


def frontend_lexer_token_count_impl(source: u8&) -> i64:
    count: i64 = frontend_lexer_token_count_with_len_impl(source, runtime_strlen(source)) can Memory.Allocate, Abort.Panic
    return count


def frontend_lexer_token_count_with_len_impl(source: u8&, source_len: usize) -> i64:
    can Memory.Allocate, Abort.Panic:
        arena: mutable Arena& = (&frontend_lexer_bench_arena).cast[mutable Arena&]
        arena_reset(arena)
        return frontend_count_tokens_with_len(arena, "frontend_lexer_bench.elisa", source, source_len).i64()


def frontend_lexer_token_checksum_impl(source: u8&) -> u64:
    checksum: u64 = frontend_lexer_token_checksum_with_len_impl(source, runtime_strlen(source)) can Memory.Allocate, Abort.Panic
    return checksum


def frontend_lexer_token_checksum_with_len_impl(source: u8&, source_len: usize) -> u64:
    can Memory.Allocate, Abort.Panic:
        arena: mutable Arena& = (&frontend_lexer_bench_arena).cast[mutable Arena&]
        arena_reset(arena)
        tokens: darray[FrontendToken] = frontend_tokenize_with_len(arena, "frontend_lexer_bench.elisa", source, source_len)
        return frontend_token_checksum(tokens)


def frontend_lexer_token_kind_at_impl(source: u8&, index: usize) -> u64:
    kind: u64 = frontend_lexer_token_kind_at_with_len_impl(source, runtime_strlen(source), index) can Memory.Allocate, Abort.Panic
    return kind


def frontend_lexer_token_kind_at_with_len_impl(source: u8&, source_len: usize, index: usize) -> u64:
    can Memory.Allocate, Abort.Panic:
        arena: mutable Arena& = (&frontend_lexer_bench_arena).cast[mutable Arena&]
        arena_reset(arena)
        tokens: darray[FrontendToken] = frontend_tokenize_with_len(arena, "frontend_lexer_bench.elisa", source, source_len)
        if index >= tokens.count:
            return 0
        return frontend_token_kind_code(tokens[index].kind)


def frontend_lexer_copy_token_kinds_impl(source: u8&, out: mutable u64&, capacity: usize) -> usize:
    count: usize = frontend_lexer_copy_token_kinds_with_len_impl(source, runtime_strlen(source), out, capacity) can Memory.Allocate, Abort.Panic
    return count


def frontend_lexer_copy_token_kinds_with_len_impl(source: u8&, source_len: usize, out: mutable u64&, capacity: usize) -> usize:
    can Memory.Allocate, Abort.Panic:
        arena: mutable Arena& = (&frontend_lexer_bench_arena).cast[mutable Arena&]
        arena_reset(arena)
        tokens: darray[FrontendToken] = frontend_tokenize_with_len(arena, "frontend_lexer_bench.elisa", source, source_len)
        if capacity < tokens.count:
            return tokens.count

        for i, token in tokens.enumerate():
            out[i] <- frontend_token_kind_code(token.kind)
        return tokens.count

export func frontend_lexer_parity_suite() -> int = frontend_lexer_parity_suite_impl
export func frontend_lexer_token_count(source: u8&) -> i64 = frontend_lexer_token_count_impl
export func frontend_lexer_token_count_with_len(source: u8&, source_len: usize) -> i64 = frontend_lexer_token_count_with_len_impl
export func frontend_lexer_token_checksum(source: u8&) -> u64 = frontend_lexer_token_checksum_impl
export func frontend_lexer_token_checksum_with_len(source: u8&, source_len: usize) -> u64 = frontend_lexer_token_checksum_with_len_impl
export func frontend_lexer_token_kind_at(source: u8&, index: usize) -> u64 = frontend_lexer_token_kind_at_impl
export func frontend_lexer_token_kind_at_with_len(source: u8&, source_len: usize, index: usize) -> u64 = frontend_lexer_token_kind_at_with_len_impl
export func frontend_lexer_copy_token_kinds(source: u8&, out: mutable u64&, capacity: usize) -> usize = frontend_lexer_copy_token_kinds_impl
export func frontend_lexer_copy_token_kinds_with_len(source: u8&, source_len: usize, out: mutable u64&, capacity: usize) -> usize = frontend_lexer_copy_token_kinds_with_len_impl
