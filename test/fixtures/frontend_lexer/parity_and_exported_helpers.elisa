def frontend_case_simple_ident() -> bool:
    can Memory.Allocate, Abort.Panic:
        bytes: u8[7] = [104, 101, 108, 108, 111, 10, 0]
        tokens: darray[Token] = frontend_tokenize_test_source(&bytes[0])
        if not frontend_expect_token_count(tokens, 3):
            return false
        if not frontend_expect_kind(tokens, 0, TokenKind.Ident):
            return false
        if not frontend_expect_kind(tokens, 1, TokenKind.Newline):
            return false
        if not frontend_expect_kind(tokens, 2, TokenKind.Eof):
            return false
        if 0 >= tokens.count:
            return false
        out: bool = frontend_sv_eq_literal(tokens[0].text, "hello")
        return out


def frontend_case_arrow_ops() -> bool:
    can Memory.Allocate, Abort.Panic:
        bytes: u8[14] = [120, 32, 60, 45, 32, 121, 32, 45, 62, 32, 122, 10, 0, 0]
        tokens: darray[Token] = frontend_tokenize_test_source(&bytes[0])
        if not frontend_expect_token_count(tokens, 7):
            return false
        out: bool = frontend_expect_kind(tokens, 0, TokenKind.Ident) and frontend_expect_kind(tokens, 1, TokenKind.LArrow) and frontend_expect_kind(tokens, 2, TokenKind.Ident) and frontend_expect_kind(tokens, 3, TokenKind.Arrow) and frontend_expect_kind(tokens, 4, TokenKind.Ident) and frontend_expect_kind(tokens, 5, TokenKind.Newline) and frontend_expect_kind(tokens, 6, TokenKind.Eof)
        return out


def frontend_case_number_literals() -> bool:
    can Memory.Allocate, Abort.Panic:
        bytes: u8[25] = [52, 50, 32, 48, 120, 102, 102, 32, 49, 50, 51, 117, 54, 52, 32, 48, 120, 65, 66, 105, 51, 50, 10, 0, 0]
        tokens: darray[Token] = frontend_tokenize_test_source(&bytes[0])
        if not frontend_expect_token_count(tokens, 6):
            return false
        if not frontend_expect_kind(tokens, 0, TokenKind.IntLit):
            return false
        if not frontend_expect_kind(tokens, 1, TokenKind.HexLit):
            return false
        if not frontend_expect_kind(tokens, 2, TokenKind.IntLit):
            return false
        if not frontend_expect_kind(tokens, 3, TokenKind.HexLit):
            return false
        if not frontend_expect_kind(tokens, 4, TokenKind.Newline):
            return false
        if not frontend_expect_kind(tokens, 5, TokenKind.Eof):
            return false
        if 2 >= tokens.count:
            return false
        if not frontend_sv_eq_literal(tokens[2].suffix, "u64"):
            return false
        if 3 >= tokens.count:
            return false
        out: bool = frontend_sv_eq_literal(tokens[3].suffix, "i32")
        return out


def frontend_case_indent_dedent() -> bool:
    can Memory.Allocate, Abort.Panic:
        bytes: u8[39] = [100, 101, 102, 32, 102, 111, 111, 58, 10, 32, 32, 32, 32, 120, 32, 60, 45, 32, 49, 10, 32, 32, 32, 32, 121, 32, 60, 45, 32, 50, 10, 122, 32, 60, 45, 32, 51, 10, 0]
        tokens: darray[Token] = frontend_tokenize_test_source(&bytes[0])
        if not frontend_expect_token_count(tokens, 19):
            return false
        out: bool = frontend_expect_kind(tokens, 0, TokenKind.Def) and frontend_expect_kind(tokens, 1, TokenKind.Ident) and frontend_expect_kind(tokens, 2, TokenKind.Colon) and frontend_expect_kind(tokens, 3, TokenKind.Newline) and frontend_expect_kind(tokens, 4, TokenKind.Indent) and frontend_expect_kind(tokens, 9, TokenKind.Ident) and frontend_expect_kind(tokens, 13, TokenKind.Dedent) and frontend_expect_kind(tokens, 18, TokenKind.Eof)
        return out


def frontend_case_comment_and_ellipsis() -> bool:
    can Memory.Allocate, Abort.Panic:
        bytes: u8[9] = [35, 120, 10, 46, 46, 46, 10, 0, 0]
        tokens: darray[Token] = frontend_tokenize_test_source(&bytes[0])
        if not frontend_expect_token_count(tokens, 3):
