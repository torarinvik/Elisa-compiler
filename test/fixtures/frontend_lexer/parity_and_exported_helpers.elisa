def frontend_case_simple_ident() -> bool:
    can Memory.Allocate, Abort.Panic:
        region scratch(4096)
        a: mutable Arena& = (&scratch).cast[mutable Arena&]
        bytes: u8[7] = [104, 101, 108, 108, 111, 10, 0]
        tokens: darray[FrontendToken] = frontend_tokenize_test_source(a, &bytes[0])
        if not frontend_expect_token_count(tokens, 3):
            destroy scratch
            return false
        if not frontend_expect_kind(tokens, 0, FrontendTokenKind.Ident):
            destroy scratch
            return false
        if not frontend_expect_kind(tokens, 1, FrontendTokenKind.Newline):
            destroy scratch
            return false
        if not frontend_expect_kind(tokens, 2, FrontendTokenKind.Eof):
            destroy scratch
            return false
        if 0 >= tokens.count:
            destroy scratch
            return false
        out: bool = frontend_sv_eq_literal(tokens[0].text, "hello")
        destroy scratch
        return out


