        out: bool = frontend_expect_kind(tokens, 0, FrontendTokenKind.Ident) and frontend_expect_kind(tokens, 1, FrontendTokenKind.LArrow) and frontend_expect_kind(tokens, 2, FrontendTokenKind.Ident) and frontend_expect_kind(tokens, 3, FrontendTokenKind.Arrow) and frontend_expect_kind(tokens, 4, FrontendTokenKind.Ident) and frontend_expect_kind(tokens, 5, FrontendTokenKind.Newline) and frontend_expect_kind(tokens, 6, FrontendTokenKind.Eof)
