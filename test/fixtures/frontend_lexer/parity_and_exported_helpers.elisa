    can Memory.Allocate, Abort.Panic:
        bytes: u8[14] = [119, 105, 116, 104, 32, 99, 111, 110, 116, 101, 120, 116, 10, 0]
        tokens: darray[Token] = frontend_tokenize_test_source(&bytes[0])
        ok: bool = frontend_expect_token_count(tokens, 4) and frontend_expect_kind(tokens, 0, TokenKind.With) and frontend_expect_kind(tokens, 1, TokenKind.Ident) and frontend_expect_kind(tokens, 2, TokenKind.Newline) and frontend_expect_kind(tokens, 3, TokenKind.Eof)
        return ok


def frontend_case_lookup_keyword_table() -> bool:
    entries: KeywordEntry[47] = [
        KeywordEntry{text: "as", kind: TokenKind.As},
        KeywordEntry{text: "if", kind: TokenKind.If},
        KeywordEntry{text: "in", kind: TokenKind.In},
        KeywordEntry{text: "or", kind: TokenKind.Or},
        KeywordEntry{text: "to", kind: TokenKind.To},
        KeywordEntry{text: "and", kind: TokenKind.And},
        KeywordEntry{text: "catch", kind: TokenKind.Catch},
        KeywordEntry{text: "def", kind: TokenKind.Def},
        KeywordEntry{text: "not", kind: TokenKind.Not},
        KeywordEntry{text: "try", kind: TokenKind.Try},
        KeywordEntry{text: "elif", kind: TokenKind.Elif},
        KeywordEntry{text: "else", kind: TokenKind.Else},
        KeywordEntry{text: "enum", kind: TokenKind.Enum},
        KeywordEntry{text: "heap", kind: TokenKind.Heap},
        KeywordEntry{text: "null", kind: TokenKind.Null},
        KeywordEntry{text: "pass", kind: TokenKind.Pass},
        KeywordEntry{text: "repr", kind: TokenKind.Repr},
        KeywordEntry{text: "tail", kind: TokenKind.Tail},
        KeywordEntry{text: "true", kind: TokenKind.True},
        KeywordEntry{text: "with", kind: TokenKind.With},
        KeywordEntry{text: "const", kind: TokenKind.Const},
        KeywordEntry{text: "error", kind: TokenKind.Error},
        KeywordEntry{text: "false", kind: TokenKind.False},
        KeywordEntry{text: "match", kind: TokenKind.Match},
        KeywordEntry{text: "panic", kind: TokenKind.Panic},
        KeywordEntry{text: "raise", kind: TokenKind.Raise},
        KeywordEntry{text: "stack", kind: TokenKind.Stack},
        KeywordEntry{text: "while", kind: TokenKind.While},
        KeywordEntry{text: "export", kind: TokenKind.Export},
        KeywordEntry{text: "extern", kind: TokenKind.Extern},
        KeywordEntry{text: "global", kind: TokenKind.Global},
        KeywordEntry{text: "packed", kind: TokenKind.Packed},
        KeywordEntry{text: "return", kind: TokenKind.Return},
        KeywordEntry{text: "sizeof", kind: TokenKind.Sizeof},
        KeywordEntry{text: "alignof", kind: TokenKind.Alignof},
        KeywordEntry{text: "offsetof", kind: TokenKind.Offsetof},
        KeywordEntry{text: "static", kind: TokenKind.Static},
        KeywordEntry{text: "struct", kind: TokenKind.Struct},
        KeywordEntry{text: "zeroed", kind: TokenKind.Zeroed},
        KeywordEntry{text: "aligned", kind: TokenKind.Ident},
        KeywordEntry{text: "context", kind: TokenKind.Ident},
        KeywordEntry{text: "mutable", kind: TokenKind.Mutable},
        KeywordEntry{text: "region", kind: TokenKind.Ident},
        KeywordEntry{text: "new", kind: TokenKind.Ident},
        KeywordEntry{text: "destroy", kind: TokenKind.Ident},
        KeywordEntry{text: "defin", kind: TokenKind.Ident},
        KeywordEntry{text: "truer", kind: TokenKind.Ident}
    ]
    return frontend_expect_lookup_keyword_entries((&entries[0]).cast[KeywordEntry&], 45)


def frontend_case_kind_only_keyword_path() -> bool:
    can Memory.Allocate, Abort.Panic:
        bytes: u8[66] = [102, 97, 108, 115, 101, 32, 116, 114, 117, 101, 32, 122, 101, 114, 111, 101, 100, 32, 119, 105, 116, 104, 32, 99, 111, 110, 116, 101, 120, 116, 32, 114, 101, 103, 105, 111, 110, 32, 110, 101, 119, 32, 100, 101, 115, 116, 114, 111, 121, 32, 49, 50, 51, 117, 54, 52, 32, 48, 120, 65, 66, 105, 51, 50, 10, 0]
        lexer: mutable Lexer = Lexer("frontend_kind_only_test.elisa", &bytes[0])

        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.False):
            return false
        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.True):
            return false
        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.Zeroed):
            return false
        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.With):
            return false
        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.Ident):
            return false
        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.Ident):
            return false
        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.Ident):
            return false
        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.Ident):
            return false
        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.IntLit):
            return false
        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.HexLit):
            return false
        if not frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.Newline):
            return false
        out: bool = frontend_kind_eq(frontend_next_token_kind(lexer), TokenKind.Eof)
        return out


def frontend_lexer_parity_suite_impl() -> int:
    can Memory.Allocate, Abort.Panic:
        if not frontend_case_simple_ident():
            return 0
        if not frontend_case_arrow_ops():
            return 0
        if not frontend_case_number_literals():
            return 0
        if not frontend_case_indent_dedent():
            return 0
        if not frontend_case_comment_and_ellipsis():
            return 0
        if not frontend_case_shift_ops():
            return 0
        if not frontend_case_paren_suppresses_newline():
            return 0
        if not frontend_case_region_alloc_syntax():
            return 0
        if not frontend_case_with_and_context_keywords():
            return 0
        if not frontend_case_lookup_keyword_table():
            return 0
        if not frontend_case_kind_only_keyword_path():
            return 0
        if not frontend_case_char_literals():
            return 0
        return 1


def frontend_count_tokens(filename: u8&, source: u8&) -> usize:
    count: usize = frontend_count_tokens_with_len(filename, source, runtime_strlen(source)) can Memory.Allocate, Abort.Panic
    return count


def frontend_count_tokens_with_len(filename: u8&, source: u8&, source_len: usize) -> usize:
    can Memory.Allocate, Abort.Panic:
        lexer: mutable Lexer = Lexer(filename, source, source_len)
        count: mutable usize = 0

        while true:
            kind: TokenKind = frontend_next_token_kind(lexer)
            count <- count + 1
            match kind:
                TokenKind.Eof:
                    return count
                _:
                    pass

        return count


def frontend_lexer_token_count_impl(source: u8&) -> i64:
    count: i64 = frontend_lexer_token_count_with_len_impl(source, runtime_strlen(source)) can Memory.Allocate, Abort.Panic
    return count


def frontend_lexer_token_count_with_len_impl(source: u8&, source_len: usize) -> i64:
    can Memory.Allocate, Abort.Panic:
        return frontend_count_tokens_with_len("frontend_lexer_bench.elisa", source, source_len).i64()


def frontend_lexer_token_checksum_impl(source: u8&) -> u64:
    checksum: u64 = frontend_lexer_token_checksum_with_len_impl(source, runtime_strlen(source)) can Memory.Allocate, Abort.Panic
    return checksum


def frontend_lexer_token_checksum_with_len_impl(source: u8&, source_len: usize) -> u64:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len("frontend_lexer_bench.elisa", source, source_len)
        return frontend_token_checksum(tokens)


def frontend_lexer_token_kind_at_impl(source: u8&, index: usize) -> u64:
    kind: u64 = frontend_lexer_token_kind_at_with_len_impl(source, runtime_strlen(source), index) can Memory.Allocate, Abort.Panic
    return kind


def frontend_lexer_token_kind_at_with_len_impl(source: u8&, source_len: usize, index: usize) -> u64:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len("frontend_lexer_bench.elisa", source, source_len)
        if index >= tokens.count:
            return 0
        return frontend_token_kind_code(tokens[index].kind)


def frontend_lexer_copy_token_kinds_impl(source: u8&, out: mutable u64&, capacity: usize) -> usize:
    count: usize = frontend_lexer_copy_token_kinds_with_len_impl(source, runtime_strlen(source), out, capacity) can Memory.Allocate, Abort.Panic
    return count


def frontend_lexer_copy_token_kinds_with_len_impl(source: u8&, source_len: usize, out: mutable u64&, capacity: usize) -> usize:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len("frontend_lexer_bench.elisa", source, source_len)
        if capacity < tokens.count:
            return tokens.count

        for i, token in tokens.enumerate():
            out[i] <- frontend_token_kind_code(token.kind)
        return tokens.count

export func frontend_lexer_parity_suite() -> int = frontend_lexer_parity_suite_impl
export func frontend_lexer_token_count(source: u8&) -> i64 = frontend_lexer_token_count_impl
export func frontend_lexer_token_count_with_len(source: u8&, source_len: usize) -> i64 = frontend_lexer_token_count_with_len_impl
export func frontend_lexer_token_checksum(source: u8&) -> u64 = frontend_lexer_token_checksum_impl
export func frontend_lexer_token_checksum_with_len(source: u8&, source_len: usize) -> u64 = frontend_lexer_token_checksum_with_len_impl
export func frontend_lexer_token_kind_at(source: u8&, index: usize) -> u64 = frontend_lexer_token_kind_at_impl
export func frontend_lexer_token_kind_at_with_len(source: u8&, source_len: usize, index: usize) -> u64 = frontend_lexer_token_kind_at_with_len_impl
export func frontend_lexer_copy_token_kinds(source: u8&, out: mutable u64&, capacity: usize) -> usize = frontend_lexer_copy_token_kinds_impl
export func frontend_lexer_copy_token_kinds_with_len(source: u8&, source_len: usize, out: mutable u64&, capacity: usize) -> usize = frontend_lexer_copy_token_kinds_with_len_impl
