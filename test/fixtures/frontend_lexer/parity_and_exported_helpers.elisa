        FrontendKeywordEntry{text: "with", kind: FrontendTokenKind.With},
        FrontendKeywordEntry{text: "const", kind: FrontendTokenKind.Const},
        FrontendKeywordEntry{text: "error", kind: FrontendTokenKind.Error},
        FrontendKeywordEntry{text: "false", kind: FrontendTokenKind.False},
        FrontendKeywordEntry{text: "match", kind: FrontendTokenKind.Match},
        FrontendKeywordEntry{text: "panic", kind: FrontendTokenKind.Panic},
        FrontendKeywordEntry{text: "raise", kind: FrontendTokenKind.Raise},
        FrontendKeywordEntry{text: "stack", kind: FrontendTokenKind.Stack},
        FrontendKeywordEntry{text: "while", kind: FrontendTokenKind.While},
        FrontendKeywordEntry{text: "export", kind: FrontendTokenKind.Export},
        FrontendKeywordEntry{text: "extern", kind: FrontendTokenKind.Extern},
        FrontendKeywordEntry{text: "global", kind: FrontendTokenKind.Global},
        FrontendKeywordEntry{text: "packed", kind: FrontendTokenKind.Packed},
        FrontendKeywordEntry{text: "return", kind: FrontendTokenKind.Return},
