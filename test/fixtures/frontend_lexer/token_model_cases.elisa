include "../../../elisac.elisalib/src/frontend/elisacore_frontend.elisa"


const FRONTEND_TOKEN_HASH_OFFSET = 1469598103934665603
const FRONTEND_TOKEN_HASH_PRIME = 1099511628211


def frontend_expect_token_count(tokens: darray[FrontendToken], expected: usize) -> bool:
    return tokens.count == expected


def frontend_kind_eq(actual: FrontendTokenKind, expected: FrontendTokenKind) -> bool:
    return actual == expected


def frontend_expect_kind(tokens: darray[FrontendToken], index: usize, expected: FrontendTokenKind) -> bool:
    if index >= tokens.count:
        return false
    return frontend_kind_eq(tokens[index].kind, expected)


def frontend_expect_text(tokens: darray[FrontendToken], index: usize, expected: static u8&) -> bool:
    if index >= tokens.count:
        return false
    return tokens[index].text == expected


def frontend_expect_suffix(tokens: darray[FrontendToken], index: usize, expected: static u8&) -> bool:
    if index >= tokens.count:
        return false
    return tokens[index].suffix == expected


def frontend_token_kind_code(kind: FrontendTokenKind) -> u64:
    match kind:
        FrontendTokenKind.Eof:
            return 1
        FrontendTokenKind.Newline:
            return 2
        FrontendTokenKind.Indent:
            return 3
        FrontendTokenKind.Dedent:
            return 4
        FrontendTokenKind.Ident:
