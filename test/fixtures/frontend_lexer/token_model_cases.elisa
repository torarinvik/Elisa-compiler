def frontend_case_char_literals() -> bool:
    can Memory.Allocate, Abort.Panic:
        bytes: u8[26] = [39, 97, 39, 32, 39, 92, 110, 39, 32, 39, 92, 120, 52, 49, 39, 32, 39, 92, 117, 48, 48, 52, 49, 39, 10, 0]
        tokens: darray[FrontendToken] = frontend_tokenize_test_source(&bytes[0])
        if not frontend_expect_token_count(tokens, 6):
            return false
        out: bool = frontend_expect_kind(tokens, 0, FrontendTokenKind.CharLit) and frontend_expect_kind(tokens, 1, FrontendTokenKind.CharLit) and frontend_expect_kind(tokens, 2, FrontendTokenKind.CharLit) and frontend_expect_kind(tokens, 3, FrontendTokenKind.CharLit) and frontend_expect_kind(tokens, 4, FrontendTokenKind.Newline) and frontend_expect_kind(tokens, 5, FrontendTokenKind.Eof)
        return out


def frontend_token_hash_mix(hash: u64, value: u64) -> u64:
    return (hash ^ value) * FRONTEND_TOKEN_HASH_PRIME


def frontend_hash_token(hash: u64, token: FrontendToken) -> u64:
    return frontend_token_hash_mix(hash, frontend_token_kind_code(token.kind))


def frontend_token_checksum(tokens: darray[FrontendToken]) -> u64:
    hash: mutable u64 = frontend_token_hash_mix(FRONTEND_TOKEN_HASH_OFFSET, tokens.count.u64())
    for token in tokens:
        hash <- frontend_hash_token(hash, token)
    return hash


def frontend_tokenize_test_source(source: u8&) -> darray[FrontendToken]:
    can Memory.Allocate, Abort.Panic:
        lexer: mutable FrontendLexer = FrontendLexer("frontend_lexer_test.elisa", source)
        tokens: mutable darray[FrontendToken] = []

        while true:
            token: FrontendToken = frontend_next_token(lexer)
            tokens.push(token)
            match token.kind:
                FrontendTokenKind.Eof:
                    return tokens
                _:
                    pass

        return tokens


# Test-only (text, expected-kind) pair used to table-drive the keyword self-test
# below. The lexer itself no longer needs this struct: keyword classification is
# the `keywordmap frontend_lookup_keyword` in frontend_lexer_identifiers.elisa.
struct FrontendKeywordEntry:
    text: mutable static u8&
    kind: mutable FrontendTokenKind
def frontend_expect_lookup_keyword(text: static u8&, expected: FrontendTokenKind) -> bool:
    text_ptr: u8& = text.cast[u8&]
    return frontend_kind_eq(frontend_lookup_keyword(sview(text_ptr, 0, runtime_strlen(text_ptr).i64())), expected)


def frontend_expect_lookup_keyword_entries(entries: FrontendKeywordEntry&, count: usize) -> bool:
    for i in 0..<count:
        entry: FrontendKeywordEntry = entries[i]
        if not frontend_expect_lookup_keyword(entry.text, entry.kind):
            return false
    return true
