# Codegen smoke target, used by CI (especially Windows, where the native
# link+run path isn't wired yet). Compile with:
#   elisac -emit obj -permissive -o smoke.o test/parity/smoke_harness.elisa
#
# The `export func` anchors the whole stage1 lexer call graph, so without it
# dead-code elimination would strip everything to a ~2 KB empty object. A
# successful, non-trivial object (tens of KB) proves the lexer codegens on the
# platform. `-permissive` lets the std's contracts (arena.elisa min/clamp) degrade
# to warnings so the smoke needs no z3 prover.
#
# Relative include (resolved from this file's directory) keeps the compile a
# pure relative-path invocation — important on Windows, where passing MSYS-style
# absolute paths to the native elisac.exe is unreliable.
include "../fixtures/lexer/frontend_lexer.elisa"


def smoke_lexer_checksums(source: u8&, source_len: usize, kind_out: mutable u64&, full_out: mutable u64&):
    checksums: FrontendLexerChecksums = frontend_lexer_stream_checksums_with_len(source, source_len) can Memory.Allocate, Abort.Panic
    kind_out[0] <- checksums.kind
    full_out[0] <- checksums.full


export func smoke_lexer_checksums_export(source: u8&, source_len: usize, kind_out: mutable u64&, full_out: mutable u64&) -> void = smoke_lexer_checksums
