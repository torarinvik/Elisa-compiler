# Semantic smoke: lex + parse + collect symbols, returning the symbol and
# duplicate counts. Anchors the stage1 semantic (symbol-collection) call graph.
include "../../src/sema/symbols.elisa"


def sema_smoke(source: u8&, source_len: usize, syms_out: mutable u64&, dups_out: mutable u64&, stmts_out: mutable u64&):
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len(source, source, source_len)
        file: Ast::File = frontend_parser_parse_file(source, tokens)
        table: SymbolTable = sema_collect_symbols(file)
        syms_out[0] <- table.symbols.count.u64()
        dups_out[0] <- table.duplicates.u64()
        stmts_out[0] <- table.statements.u64()


export func sema_smoke_export(source: u8&, source_len: usize, syms_out: mutable u64&, dups_out: mutable u64&, stmts_out: mutable u64&) -> void = sema_smoke
