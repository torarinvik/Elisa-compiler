# Name-resolution smoke: lex + parse + resolve references, returning the count of
# unresolved (undefined) value-position identifiers. Anchors the resolver call graph.
include "../../src/semantic/semantic.elisa"


def resolve_smoke(source: u8&, source_len: usize, unresolved_out: mutable u64&):
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len(source, source, source_len)
        file: Ast::File = frontend_parser_parse_file(source, tokens)
        unresolved_out[0] <- Semantic::unresolved_refs(file)


export func resolve_smoke_export(source: u8&, source_len: usize, unresolved_out: mutable u64&) -> void = resolve_smoke


# Run the full semantic check and report the located diagnostics: the total count and
# the source line of the first UndefinedName diagnostic (0 if none). Exercises the
# diagnostics layer's position capture, not just the count.
def diag_probe(source: u8&, source_len: usize, count_out: mutable u64&, first_undef_line_out: mutable u32&):
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len(source, source, source_len)
        file: Ast::File = frontend_parser_parse_file(source, tokens)
        table: Semantic::SymbolTable = Semantic::check(file)
        count_out[0] <- table.diagnostics.count.u64()
        first_undef_line_out[0] <- 0
        for d in table.diagnostics:
            if d.kind == Semantic::DiagnosticKind.UndefinedName and first_undef_line_out[0] == 0:
                first_undef_line_out[0] <- d.line


export func diag_probe_export(source: u8&, source_len: usize, count_out: mutable u64&, first_undef_line_out: mutable u32&) -> void = diag_probe


# Run the full semantic check and report duplicate-declaration findings: the count
# of DuplicateDecl diagnostics and the source line of the first one (0 if none).
# Exercises symbol-collection's duplicate detection (add_symbol / name_indexed),
# which the resolution-focused probes above never touch.
def dup_probe(source: u8&, source_len: usize, dup_count_out: mutable u64&, first_dup_line_out: mutable u32&):
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len(source, source, source_len)
        file: Ast::File = frontend_parser_parse_file(source, tokens)
        table: Semantic::SymbolTable = Semantic::check(file)
        c: mutable u64 = 0
        first_dup_line_out[0] <- 0
        for d in table.diagnostics:
            if d.kind == Semantic::DiagnosticKind.DuplicateDecl:
                c <- c + 1
                if first_dup_line_out[0] == 0:
                    first_dup_line_out[0] <- d.line
        dup_count_out[0] <- c


export func dup_probe_export(source: u8&, source_len: usize, dup_count_out: mutable u64&, first_dup_line_out: mutable u32&) -> void = dup_probe


# Map a stable numeric code to a DiagnosticKind so the C driver can drive the
# wording/severity source-of-truth (`diagnostic_message` / `diagnostic_severity`)
# without depending on the enum's in-memory encoding.
def diag_kind_of_code(code: u32) -> Semantic::DiagnosticKind:
    can Abort.Panic:
        return match code:
            0: Semantic::DiagnosticKind.UndefinedName
            1: Semantic::DiagnosticKind.DuplicateDecl
            2: Semantic::DiagnosticKind.SyntaxExpectedToken
            3: Semantic::DiagnosticKind.SyntaxUnexpectedToken
            4: Semantic::DiagnosticKind.SyntaxExpectedDeclaration
            5: Semantic::DiagnosticKind.SyntaxExpectedExpression
            _: Semantic::DiagnosticKind.UndefinedName


# Write the canonical message for `code`'s diagnostic kind into `out` (capped at
# `out_cap`), returning the byte length. Guards diagnostic_message's per-kind
# wording (e.g. an arm swap or an empty return), which no end-to-end probe reads.
def diag_message_probe(code: u32, out: mutable u8&, out_cap: usize) -> u64:
    can Memory.Allocate, Abort.Panic:
        d: Semantic::Diagnostic = Semantic::Diagnostic{name: sview("x", 0, -1), line: 0, kind: diag_kind_of_code(code)}
        msg: darray[u8] = Semantic::diagnostic_message(d)
        n: mutable usize = msg.count
        if n > out_cap:
            n <- out_cap
        for i in 0..<n:
            out[i] <- msg[i]
        return n.u64()


# Canonical LSP severity for `code`'s diagnostic kind.
def diag_severity_probe(code: u32) -> u32:
    can Abort.Panic:
        d: Semantic::Diagnostic = Semantic::Diagnostic{name: sview("x", 0, -1), line: 0, kind: diag_kind_of_code(code)}
        return Semantic::diagnostic_severity(d).u32()


export func diag_message_probe_export(code: u32, out: mutable u8&, out_cap: usize) -> u64 = diag_message_probe
export func diag_severity_probe_export(code: u32) -> u32 = diag_severity_probe


# Inverse of diag_kind_of_code: a stable numeric code for a DiagnosticKind, so the
# C driver can assert which kind a syntax finding mapped to.
def code_of_diag_kind(k: Semantic::DiagnosticKind) -> u32:
    can Abort.Panic:
        return match k:
            Semantic::DiagnosticKind.UndefinedName:             0
            Semantic::DiagnosticKind.DuplicateDecl:             1
            Semantic::DiagnosticKind.SyntaxExpectedToken:       2
            Semantic::DiagnosticKind.SyntaxUnexpectedToken:     3
            Semantic::DiagnosticKind.SyntaxExpectedDeclaration: 4
            Semantic::DiagnosticKind.SyntaxExpectedExpression:  5


# Run the full check over a source with a syntax error and report how many
# syntax-kind (Syntax*) diagnostics were folded in and the code of the first one.
# Guards append_parse_errors (folding the parser's findings into the stream) and
# parse_error_kind (mapping ParseErrorKind -> DiagnosticKind), which no other
# probe exercises — a semantic-only source never produces a syntax finding.
def syntax_probe(source: u8&, source_len: usize, syntax_count_out: mutable u64&, first_kind_out: mutable u32&):
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len(source, source, source_len)
        file: Ast::File = frontend_parser_parse_file(source, tokens)
        table: Semantic::SymbolTable = Semantic::check(file)
        c: mutable u64 = 0
        first_kind_out[0] <- 9999
        for d in table.diagnostics:
            code: u32 = code_of_diag_kind(d.kind)
            if code >= 2:
                c <- c + 1
                if first_kind_out[0] == 9999:
                    first_kind_out[0] <- code
        syntax_count_out[0] <- c


export func syntax_probe_export(source: u8&, source_len: usize, syntax_count_out: mutable u64&, first_kind_out: mutable u32&) -> void = syntax_probe


# Targeted regression for the name-index hash-collision path (`hash_occupied` /
# `index_name` in symbols.elisa): a manually-seeded name_primary slot at an
# arbitrary hash must read back as occupied, and an untouched hash must not.
# Real 64-bit FNV-1a collisions between two chosen strings aren't practical to
# construct by hand, so this probes `hash_occupied` directly rather than going
# through two colliding names — it's the exact unit a prior bug (and a mutation
# fuzzer pass) both broke by having it always report "not occupied", which
# silently overwrites `name_primary` on a real collision instead of routing the
# colliding name to `name_overflow`.
extend Semantic:
    public:
        # Return u32 (not bool) so the C-ABI export target below is ABI-compatible.
        def hash_occupied_probe(seed: u64) -> u32:
            can Memory.Allocate, Abort.Panic:
                table: SymbolTable = SymbolTable()
                table.name_primary.put(seed, "existing")
                return 1 if hash_occupied(table, seed) else 0


        def hash_occupied_probe_empty(seed: u64) -> u32:
            can Memory.Allocate, Abort.Panic:
                table: SymbolTable = SymbolTable()
                return 1 if hash_occupied(table, seed) else 0


# These `export func … = Mod::fn` bindings exercise the parser's qualified
# export-target support (a `::`-qualified name on the RHS): they bind the C-ABI
# entry points directly to the module-scoped probes with no local wrapper.
export func hash_occupied_probe_export(seed: u64) -> u32 = Semantic::hash_occupied_probe
export func hash_occupied_probe_empty_export(seed: u64) -> u32 = Semantic::hash_occupied_probe_empty
