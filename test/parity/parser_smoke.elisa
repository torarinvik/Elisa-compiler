# Parser codegen smoke: lex + parse a source buffer, return decl/error counts.
# Anchors the whole stage1 parser call graph so DCE can't strip it.
include "../../src/parser/parser.elisa"


def smoke_parse(source: u8&, source_len: usize, decls_out: mutable u64&, errors_out: mutable u64&):
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len(source, source, source_len)
        file: Ast::File = frontend_parser_parse_file(source, tokens)
        decls_out[0] <- file.top_decls.count.u64()
        errors_out[0] <- file.errors.count.u64()


export func smoke_parse_export(source: u8&, source_len: usize, decls_out: mutable u64&, errors_out: mutable u64&) -> void = smoke_parse
