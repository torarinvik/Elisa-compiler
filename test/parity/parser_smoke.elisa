# Parser codegen smoke: lex + parse a source buffer, return decl/error counts.
# Anchors the whole stage1 parser call graph so DCE can't strip it.
include "../../src/parser/parser.elisa"

using Ast


def smoke_parse(source: u8&, source_len: usize, decls_out: mutable u64&, errors_out: mutable u64&):
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len(source, source, source_len)
        file: Ast::File = frontend_parser_parse_file(source, tokens)
        decls_out[0] <- file.top_decls.count.u64()
        errors_out[0] <- file.errors.count.u64()


export func smoke_parse_export(source: u8&, source_len: usize, decls_out: mutable u64&, errors_out: mutable u64&) -> void = smoke_parse


# Debug helper: print the first `limit` parse errors as "line:col kind" lines.
def smoke_dump_errors(source: u8&, source_len: usize, limit: u32):
    can Memory.Allocate, Abort.Panic, Console.Format:
        tokens: darray[Token] = frontend_tokenize_with_len(source, source, source_len)
        file: Ast::File = frontend_parser_parse_file(source, tokens)
        shown: mutable u32 = 0
        for err in file.errors:
            if shown >= limit:
                break
            print(err.line.i64())
            print("\n")
            shown <- shown + 1


export func smoke_dump_errors_export(source: u8&, source_len: usize, limit: u32) -> void = smoke_dump_errors


# Count match arms reachable from a statement list, recursing nested blocks and arm
# bodies. Arms now live directly on each Stmt.Match node's `arms` side-table (docs/76),
# so counting them means walking the tree by `match`.
def smoke_count_arms_stmts(stmts: darray[Ast::Stmt]) -> u64:
    can Memory.Allocate, Abort.Panic:
        total: mutable u64 = 0
        for stmt in stmts:
            match stmt:
                Stmt.Match(scrutinee, arms, line):
                    total <- total + arms.count.u64()
                    for arm in arms:
                        total <- total + smoke_count_arms_stmts(arm.body)
                Stmt.If(cond, then_body, else_body, line):
                    total <- total + smoke_count_arms_stmts(then_body)
                    total <- total + smoke_count_arms_stmts(else_body)
                Stmt.While(cond, body, line):
                    total <- total + smoke_count_arms_stmts(body)
                Stmt.For(vars, iter, body, line):
                    total <- total + smoke_count_arms_stmts(body)
                Stmt.Block(binding, body, line):
                    total <- total + smoke_count_arms_stmts(body)
                _:
                    pass
        return total


def smoke_count_arms_decls(decls: darray[Ast::Decl]) -> u64:
    can Memory.Allocate, Abort.Panic:
        total: mutable u64 = 0
        for decl in decls:
            match decl:
                Decl.Func(name, params, return_type, body, line):
                    total <- total + smoke_count_arms_stmts(body)
                Decl.Module(name, body, line):
                    total <- total + smoke_count_arms_decls(body)
                _:
                    pass
        return total


# Returns the number of match arms parsed across the source — exercises the
# Stmt.Match / MatchArm structural modeling (not just "no errors").
def smoke_match_arms(source: u8&, source_len: usize) -> u64:
    can Memory.Allocate, Abort.Panic:
        tokens: darray[Token] = frontend_tokenize_with_len(source, source, source_len)
        file: Ast::File = frontend_parser_parse_file(source, tokens)
        return smoke_count_arms_decls(file.top_decls)


export func smoke_match_arms_export(source: u8&, source_len: usize) -> u64 = smoke_match_arms
