# ============================================================
# Elisa core Runtime - public wrappers and stage 1 adapters
# ============================================================

# ------------------------------------------------------------
# Type-to-string public API
# ------------------------------------------------------------

def int_to_string(value: i64) -> heap u8&:
    return int_to_string_into(&perm_arena, value) can Memory.Allocate, Console.Format, Abort.Panic

def int_to_string_scratch(value: i64) -> heap u8&:
    return int_to_string_into(&scratch_arena, value) can Memory.Allocate, Console.Format, Abort.Panic

def bool_to_string(value: int) -> u8&:
    return bool_to_string_into(&perm_arena, value)

def bool_to_string_scratch(value: int) -> u8&:
    return bool_to_string_into(&scratch_arena, value)

def char_to_string(value: i64) -> heap u8&:
    return char_to_string_into(&perm_arena, value) can Memory.Allocate, Abort.Panic

def char_to_string_scratch(value: i64) -> heap u8&:
    return char_to_string_into(&scratch_arena, value) can Memory.Allocate, Abort.Panic

def uint_to_string_scratch(value: u64) -> heap u8&:
    can Memory.Allocate, Console.Format, Abort.Panic:
        len: int = snprintf(null, 0, "%llu", value)
        if len < 0:
            panic("uint_to_string_scratch: snprintf failed")
        out: heap u8& = alloc_scratch((len + 1).i64()).cast[heap u8&]
        snprintf(out.cast[u8&?], len.usize() + 1, "%llu", value)
        return out

def float_to_string_scratch(value: f64) -> heap u8&:
    can Memory.Allocate, Console.Format, Abort.Panic:
        len: int = snprintf(null, 0, "%g", value)
        if len < 0:
            panic("float_to_string_scratch: snprintf failed")
        out: heap u8& = alloc_scratch((len + 1).i64()).cast[heap u8&]
        snprintf(out.cast[u8&?], len.usize() + 1, "%g", value)
        return out

# ------------------------------------------------------------
# Basic string predicates
# ------------------------------------------------------------

def __cast__(value: static u8&) -> u8&:
    return value.cast[u8&]


def string_len(value: u8&?) -> i64:
    return runtime_strlen(value).i64()

def streq(lhs: u8&?, rhs: u8&?) -> int:
    left: u8& = lhs if lhs != null else ""
    right: u8& = rhs if rhs != null else ""

    return 1 if left.cast[uintptr] == right.cast[uintptr] or strcmp(left, right) == 0 else 0

# ============================================================
# Stage 1 runtime forwarding wrappers
# ============================================================

def rt_concat2(lhs: cstr[shape_left], rhs: cstr[shape_right]) -> cstr[shape_result]:
    return concat2(lhs, rhs) can Memory.Allocate, Abort.Panic

def rt_concat2_scratch(lhs: cstr[shape_left], rhs: cstr[shape_right]) -> cstr[shape_result]:
    return concat2_scratch(lhs, rhs) can Memory.Allocate, Abort.Panic

def rt_int_to_string(value: i64) -> cstr[shape_out]:
    return int_to_string(value) can Memory.Allocate, Console.Format, Abort.Panic

def rt_int_to_string_scratch(value: i64) -> cstr[shape_out]:
    return int_to_string_scratch(value) can Memory.Allocate, Console.Format, Abort.Panic

def rt_bool_to_string(value: int) -> cstr[shape_out]:
    return bool_to_string(value)

def rt_bool_to_string_scratch(value: int) -> cstr[shape_out]:
    return bool_to_string_scratch(value)

def rt_char_to_string(value: i64) -> cstr[shape_out]:
    return char_to_string(value) can Memory.Allocate, Abort.Panic

def rt_char_to_string_scratch(value: i64) -> cstr[shape_out]:
    return char_to_string_scratch(value) can Memory.Allocate, Abort.Panic

def ctx_strlen(value: cstr[shape_in]) -> i64:
    return string_len(value)

def ctx_streq(lhs: cstr[shape_left], rhs: cstr[shape_right]) -> int:
    return streq(lhs, rhs)

def ctx_string_slice_eq(value: cstr[shape_in], start: i64, end: i64, other: cstr[shape_other]) -> int:
    return string_slice_eq(value, start, end, other)

def ctx_string_slices_eq(lhs: cstr[shape_left], lhs_start: i64, lhs_end: i64, rhs: cstr[shape_right], rhs_start: i64, rhs_end: i64) -> int:
    return string_slices_eq(lhs, lhs_start, lhs_end, rhs, rhs_start, rhs_end)

def ctx_string_index(value: cstr[shape_in], index: i64) -> i64:
    return string_index(value, index)

def ctx_string_slice(value: cstr[shape_in], start: i64, end: i64) -> cstr[shape_out]:
    return string_slice(value, start, end) can Memory.Allocate, Abort.Panic

def ctx_string_view(value: cstr[shape_in], start: i64, end: i64) -> sview:
    return sview(value, start, end)

def ctx_string_view_len(view: sview) -> i64:
    return string_view_len(view)

def ctx_string_view_slice(view: sview, start: i64, end: i64) -> sview:
    return string_view_slice(view, start, end)

def ctx_string_view_prefix(view: sview, end: i64) -> sview:
    return string_view_prefix(view, end)

def ctx_string_view_suffix(view: sview, start: i64) -> sview:
    return string_view_suffix(view, start)

def ctx_string_view_index(view: sview, index: i64) -> i64:
    return string_view_index(view, index)

def ctx_string_view_eq(view: sview, other: cstr[shape_other]) -> int:
    return string_view_eq(view, other)

def ctx_string_views_eq(lhs: sview, rhs: sview) -> int:
    return string_views_eq(lhs, rhs)

def ctx_string_from_view(view: sview) -> cstr[shape_out]:
    return string_view_copy(view).cast[u8&] can Memory.Allocate, Abort.Panic

def rt_reset_scratch():
    reset_scratch()

def rt_puts(value: u8&?) -> int:
    return puts(value if value != null else "") can Console.Write

# ------------------------------------------------------------
# Console printing
# ------------------------------------------------------------

const enum FileDescriptor of int:
    Input = 0
    Output = 1
    Error = 2

@link_name(write)
extern runtime_write(fd: FileDescriptor, buf: void&, count: usize) -> isize can[Console.Write]

protocol Str:
    def __cast__(self: Self) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]

impl Str for cstr:
    def __cast__(self: cstr) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return self

impl Str for bool:
    def __cast__(self: bool) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return "true" if self else "false"

impl Str for sview:
    def __cast__(self: sview) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return string_view_copy(self).cast[u8&]

impl Str for dstr:
    def __cast__(self: dstr) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return string_view_copy(bytes_view(self)).cast[u8&]

impl Str for char:
    def __cast__(self: char) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return char_to_string_scratch(self.i64())

impl Str for int:
    def __cast__(self: int) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return int_to_string_scratch(self.i64())

impl Str for i64:
    def __cast__(self: i64) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return int_to_string_scratch(self)

impl Str for i32:
    def __cast__(self: i32) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return int_to_string_scratch(self.i64())

impl Str for i16:
    def __cast__(self: i16) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return int_to_string_scratch(self.i64())

impl Str for i8:
    def __cast__(self: i8) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return int_to_string_scratch(self.i64())

impl Str for u32:
    def __cast__(self: u32) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return uint_to_string_scratch(self.u64())

impl Str for u16:
    def __cast__(self: u16) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return uint_to_string_scratch(self.u64())

impl Str for u8:
    def __cast__(self: u8) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return uint_to_string_scratch(self.u64())

impl Str for u64:
    def __cast__(self: u64) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return uint_to_string_scratch(self)

impl Str for usize:
    def __cast__(self: usize) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return uint_to_string_scratch(self.u64())

impl Str for uintptr:
    def __cast__(self: uintptr) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return uint_to_string_scratch(self.u64())

impl Str for f64:
    def __cast__(self: f64) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return float_to_string_scratch(self)

impl Str for f32:
    def __cast__(self: f32) -> cstr can[Memory.Allocate, Console.Format, Abort.Panic]:
        return float_to_string_scratch(self.f64())

def printr(value: cstr) -> void can[Console.Write]:
    length: usize = runtime_strlen(value)
    if length == 0:
        return
    _ = runtime_write(FileDescriptor.Output, value.cast[void&], length) can Console.Write

def print(value: cstr) -> void can[Console.Write]:
    printr(value) can Console.Write
    _ = runtime_write(FileDescriptor.Output, "\n".cast[void&], 1.usize()) can Console.Write

def printr[T: Str](value: T) -> void can[Console.Write, Memory.Allocate, Console.Format, Abort.Panic]:
    printr(T.__cast__(value) can Memory.Allocate, Console.Format, Abort.Panic) can Console.Write

def print[T: Str](value: T) -> void can[Console.Write, Memory.Allocate, Console.Format, Abort.Panic]:
    print(T.__cast__(value) can Memory.Allocate, Console.Format, Abort.Panic) can Console.Write

def printr(value: dstr) -> void can[Console.Write]:
    if value.count == 0 or value.items == null:
        return
    items: u8& = value.items
    _ = runtime_write(FileDescriptor.Output, items.cast[void&], value.count) can Console.Write

def print(value: dstr) -> void can[Console.Write]:
    printr(value) can Console.Write
    _ = runtime_write(FileDescriptor.Output, "\n".cast[void&], 1.usize()) can Console.Write

# ------------------------------------------------------------
# Fatal error handler (weak linkage)
# ------------------------------------------------------------

# weak
def ctx_llvm_codegen_fatal(msg: u8&?):
    can Console, Abort.Exit:
        actual_msg: u8& = msg if msg != null else "<null>"
        puts("ctx_llvm_codegen_fatal:")
        puts(actual_msg)
        exit(1)
