# ============================================================
# Elisa core Runtime - string primitives and views
# ============================================================

# ------------------------------------------------------------
# String concatenation
# ------------------------------------------------------------

def concat2(lhs: u8&?, rhs: u8&?) -> u8&:
    can Memory.Allocate, Abort.Panic:
        left: u8& = lhs if lhs != null else ""
        right: u8& = rhs if rhs != null else ""

        left_len: usize = runtime_strlen(left)
        right_len: usize = runtime_strlen(right)

        right return if left_len == 0

        left return if right_len == 0

        if left_len + right_len <= 8:
            text: u8[9]
            memcpy((&text[0]).cast[mutable void&], left.cast[void&], left_len)
            memcpy((&text[0] + left_len).cast[mutable void&], right.cast[void&], right_len)
            text[left_len + right_len] <- 0
            return intern_small_string(&text[0], left_len + right_len).cast[u8&]

        out: u8& = alloc_perm((left_len + right_len + 1).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], left.cast[void&], left_len)
        memcpy((out + left_len).cast[mutable void&], right.cast[void&], right_len)
        out[left_len + right_len] <- 0
        register_perm_string_len(out, left_len + right_len)
        return out

def concat2_scratch(lhs: u8&?, rhs: u8&?) -> u8&:
    can Memory.Allocate, Abort.Panic:
        left: u8& = lhs if lhs != null else ""
        right: u8& = rhs if rhs != null else ""

        left_len: usize = runtime_strlen(left)
        right_len: usize = runtime_strlen(right)

        right return if left_len == 0

        left return if right_len == 0

        if left_len + right_len <= 8:
            text: u8[9]
            memcpy((&text[0]).cast[mutable void&], left.cast[void&], left_len)
            memcpy((&text[0] + left_len).cast[mutable void&], right.cast[void&], right_len)
            text[left_len + right_len] <- 0
            return intern_small_string(&text[0], left_len + right_len).cast[u8&]

        out: u8& = alloc_scratch((left_len + right_len + 1).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], left.cast[void&], left_len)
        memcpy((out + left_len).cast[mutable void&], right.cast[void&], right_len)
        out[left_len + right_len] <- 0
        return out

# ------------------------------------------------------------
# String operations
# ------------------------------------------------------------

def string_index(value: u8&?, index: i64) -> i64:
    src: u8& = value if value != null else ""
    len: usize = runtime_strlen(src)

    return 0 if index < 0 or index.usize() >= len else src[index.usize()].i64()

    

def string_slice_eq(value: u8&?, start: i64, end: i64, other: u8&?) -> int:
    src: u8& = value if value != null else ""
    rhs: u8& = other if other != null else ""
    len: usize = runtime_strlen(src)

    lo: mutable usize = 0
    hi: mutable usize = len

    if start > 0:
        lo <- start.usize()
        if lo > len:
            lo <- len

    if end >= 0:
        hi <- end.usize()
        if hi > len:
            hi <- len

    if hi < lo:
        hi <- lo

    slice_len: usize = hi - lo
    rhs_len: usize = runtime_strlen(rhs)

    0 return if slice_len != rhs_len

    #1 return if slice_len == 0
    #1 return if src + lo == rhs
    1 return if slice_len == 0 or (src + lo).cast[uintptr] == rhs.cast[uintptr]

    return 1 if memcmp((src + lo).cast[void&], rhs.cast[void&], slice_len) == 0 else 0

def string_slices_eq(lhs: u8&?, lhs_start: i64, lhs_end: i64, rhs: u8&?, rhs_start: i64, rhs_end: i64) -> int:
    left: u8& = lhs if lhs != null else ""
    right: u8& = rhs if rhs != null else ""
    left_len: usize = runtime_strlen(left)
    right_len: usize = runtime_strlen(right)

    left_lo: mutable usize = 0
    left_hi: mutable usize = left_len
    right_lo: mutable usize = 0
    right_hi: mutable usize = right_len

    if lhs_start > 0:
        left_lo <- lhs_start.usize()
        if left_lo > left_len:
            left_lo <- left_len

    if lhs_end >= 0:
        left_hi <- lhs_end.usize()
        if left_hi > left_len:
            left_hi <- left_len

    if left_hi < left_lo:
        left_hi <- left_lo

    if rhs_start > 0:
        right_lo <- rhs_start.usize()
        if right_lo > right_len:
            right_lo <- right_len

    if rhs_end >= 0:
        right_hi <- rhs_end.usize()
        if right_hi > right_len:
            right_hi <- right_len

    if right_hi < right_lo:
        right_hi <- right_lo

    left_slice_len: usize = left_hi - left_lo
    right_slice_len: usize = right_hi - right_lo

    0 return if left_slice_len != right_slice_len

    #1 return if left_slice_len == 0
    #1 return if left + left_lo == right + right_lo
    1 return if left_slice_len == 0 or (left + left_lo).cast[uintptr] == (right + right_lo).cast[uintptr]

    return 1 if memcmp((left + left_lo).cast[void&], (right + right_lo).cast[void&], left_slice_len) == 0 else 0

def string_slice(value: u8&?, start: i64, end: i64) -> u8&:
    can Memory.Allocate, Abort.Panic:
        src: u8& = value if value != null else ""
        len: usize = runtime_strlen(src)

        lo: mutable usize = 0
        hi: mutable usize = len

        if start > 0:
            lo <- start.usize()
            if lo > len:
                lo <- len

        if end >= 0:
            hi <- end.usize()
            if hi > len:
                hi <- len

        if hi < lo:
            hi <- lo

        src return if lo == 0 and hi == len

        out_len: usize = hi - lo

        "" return if out_len == 0

        intern_small_string(src + lo, out_len).cast[u8&] return if out_len <= 8

        out: u8& = alloc_perm((out_len + 1).i64()).cast[u8&]
        memcpy(out.cast[mutable void&], (src + lo).cast[void&], out_len)
        out[out_len] <- 0
        register_perm_string_len(out, out_len)
        return out

def sview(value: u8&?, start: i64, end: i64) -> sview:
    src: u8& = value if value != null else ""
    len: usize = runtime_strlen(src)

    lo: mutable usize = 0
    hi: mutable usize = len

    if start > 0:
        lo <- start.usize()
        if lo > len:
            lo <- len

    if end >= 0:
        hi <- end.usize()
        if hi > len:
            hi <- len

    if hi < lo:
        hi <- lo

    return StringView{data: src + lo, len: (hi - lo).i64()}

# Ergonomic cast: a raw C-string (u8&?) -> borrowed string view, so content
# equality works directly (`bytes.sview() == "x86_64"`) instead of streq().
# This is the explicit postfix-shorthand cast `value.sview()`; it strlen's the
# C-string to bound the view (null -> empty view). The view BORROWS the
# underlying storage, so it is valid only while that C-string is alive — the
# compiler tracks the interior borrow. Unlike `cstr`/DStr (a counted/owned
# string that would require a copy), a view is alloc-free and is exactly the
# right primitive for comparison.
def __cast__(value: u8&?) -> sview:
    return sview(value, 0, -1)

def string_view_len(view: sview) -> i64:
    return view.len

def string_view_slice(view: sview, start: i64, end: i64) -> sview:
    lo: mutable i64 = start if start > 0 else 0
    hi: mutable i64 = end if end >= 0 else view.len

    if lo > view.len:
        lo <- view.len
    if hi > view.len:
        hi <- view.len
    if hi < lo:
        hi <- lo

    return StringView{data: view.data + lo.usize(), len: hi - lo}

def string_view_prefix(view: sview, end: i64) -> sview:
    return string_view_slice(view, 0, end)

def string_view_suffix(view: sview, start: i64) -> sview:
    return string_view_slice(view, start, view.len)

def string_view_index(view: sview, index: i64) -> i64:
    0 return if index < 0 or index >= view.len

    return view.data[index.usize()].i64()

def string_view_eq(view: sview, other: u8&?) -> int:
    rhs: u8& = other if other != null else ""
    rhs_len: usize = runtime_strlen(rhs)

    0 return if view.len < 0 or view.len.usize() != rhs_len
    #1 return if view.len == 0
    #1 return if view.data == rhs

    1 return if view.len == 0 or view.data.cast[uintptr] == rhs.cast[uintptr]

    return 1 if memcmp(view.data.cast[void&], rhs.cast[void&], view.len.usize()) == 0 else 0

def string_views_eq(lhs: sview, rhs: sview) -> int:
    0 return if lhs.len != rhs.len

    #1 return if lhs.len == 0
    #1 return if lhs.data == rhs.data
    1 return if lhs.len == 0 or lhs.data.cast[uintptr] == rhs.data.cast[uintptr]
    
    return 1 if memcmp(lhs.data.cast[void&], rhs.data.cast[void&], lhs.len.usize()) == 0 else 0

def string_view_copy(view: sview) -> heap u8&:
    can Memory.Allocate, Abort.Panic:
        intern_small_string("", 0) return if view.len <= 0

        intern_small_string(view.data, view.len.usize()) return if view.len <= 8

        out: heap u8& = alloc_perm((view.len + 1).usize()).cast[heap u8&]
        memcpy(out.cast[mutable void&], view.data.cast[void&], view.len.usize())
        out[view.len.usize()] <- 0
        register_perm_string_len(out.cast[u8&], view.len.usize())
        return out

# ------------------------------------------------------------
# Ergonomic, bounds-safe string-view helpers
#
# These compose the bounds-checked primitives above (string_view_index /
# _prefix / _suffix / _eq), so they read no byte outside the view's length and
# require NO Unsafe permission. They are the safe surface path/string code
# should reach for instead of raw `static u8&` scanning with unchecked indexing.
# ------------------------------------------------------------

def sview_len(view: sview) -> usize:
    return view.len.usize() if view.len > 0 else 0.usize()

def sview_is_empty(view: sview) -> bool:
    return view.len <= 0

# Bounds-safe byte read; returns 0 for an out-of-range index.
def sview_at(view: sview, index: usize) -> u8:
    return string_view_index(view, index.i64()).u8()

def sview_eq(lhs: sview, rhs: sview) -> bool:
    return string_views_eq(lhs, rhs) == 1

def sview_starts_with(view: sview, prefix: sview) -> bool:
    false return if prefix.len > view.len
    return string_views_eq(string_view_prefix(view, prefix.len), prefix) == 1

def sview_ends_with(view: sview, suffix: sview) -> bool:
    false return if suffix.len > view.len
    return string_views_eq(string_view_suffix(view, view.len - suffix.len), suffix) == 1

# Index of the first occurrence of `byte`, or -1 if absent.
def sview_find_byte(view: sview, byte: u8) -> i64:
    i: mutable i64 = 0
    while i < view.len:
        i return if string_view_index(view, i) == byte.i64()
        i <- i + 1
    return -1

def sview_contains_byte(view: sview, byte: u8) -> bool:
    return sview_find_byte(view, byte) >= 0

# Drop a trailing byte (e.g. a path separator) without copying.
def sview_trim_trailing(view: sview, byte: u8) -> sview:
    hi: mutable i64 = view.len
    while hi > 0 and string_view_index(view, hi - 1) == byte.i64():
        hi <- hi - 1
    return string_view_prefix(view, hi)

# The basename: the slice after the last `sep`, or the whole view if none.
def sview_basename(view: sview, sep: u8) -> sview:
    i: mutable i64 = view.len
    while i > 0:
        if string_view_index(view, i - 1) == sep.i64():
            return string_view_suffix(view, i)
        i <- i - 1
    return view

# The dirname: the slice before the last `sep` (empty if none).
def sview_dirname(view: sview, sep: u8) -> sview:
    i: mutable i64 = view.len
    while i > 0:
        if string_view_index(view, i - 1) == sep.i64():
            return string_view_prefix(view, i - 1)
        i <- i - 1
    return string_view_prefix(view, 0)

# A bounds-safe view over the live bytes of a darray[u8]. This is the bridge
# that lets raw byte-buffer scanning (ELF string tables, parse buffers, ...) be
# done through the bounds-checked sview helpers instead of unchecked indexing
# with compound offsets. The single interior pointer is taken under `trusted`
# here, ONCE, so every caller scans with zero Unsafe of its own.
#
# The returned view borrows the darray's storage: it is valid only while the
# darray is alive and un-grown (a relocating push invalidates it — the compiler
# tracks this for interior darray borrows).
def bytes_view(buf: darray[u8]) -> sview:
    n: usize = buf.count
    if n == 0:
        return sview("", 0, 0)
    trusted Unsafe.UncheckedIndex:
        return StringView{data: &buf[0], len: n.i64()}

# FNV-1a 64-bit hash of the bytes of `value` (std::hash<std::string_view>). Deterministic
# and order-sensitive; to hash a C-string / dstr, take a `sview` of its bytes first.
def hash_sview(value: sview) -> u64:
    h: mutable u64 = 0xcbf29ce484222325
    for ch in value:
        h <- h ^ ch.u64()
        h <- h * 0x100000001b3
    return h

# Last index of `byte` in `view`, or -1 if absent (the rfind companion to
# sview_find_byte). Used by the Fs path helpers below.
def sview_find_last_byte(view: sview, byte: u8) -> i64:
    i: mutable i64 = sview_len(view).i64()
    trusted Unsafe.AssumeProgress:
        while i > 0:
            i <- i - 1
            if sview_at(view, i.usize()) == byte:
                return i
    return -1

# `Fs`: pure (allocation-free, OS-free) std::filesystem::path string decomposition.
# All operate on a `/`-separated path `sview` and return sub-views into it — the OS-backed
# queries (exists / is_directory / create_directory / directory_iterator) are separate and
# live with the host FFI. Semantics mirror C++ std::filesystem::path:
#   filename("a/b/c.txt")=="c.txt", parent("a/b/c.txt")=="a/b",
#   extension("a/b/c.txt")==".txt" (incl. the dot; "" for none or a leading-dot name),
#   stem("a/b/c.txt")=="c".
module Fs:
    def filename(p: sview) -> sview:
        slash: i64 = sview_find_last_byte(p, 47)
        return string_view_suffix(p, slash + 1)

    def parent(p: sview) -> sview:
        slash: i64 = sview_find_last_byte(p, 47)
        return string_view_prefix(p, slash) if slash >= 0 else sview("", 0, 0)

    def extension(p: sview) -> sview:
        name_start: i64 = sview_find_last_byte(p, 47) + 1
        dot: i64 = sview_find_last_byte(p, 46)
        return string_view_suffix(p, dot) if dot > name_start else sview("", 0, 0)

    def stem(p: sview) -> sview:
        name_start: i64 = sview_find_last_byte(p, 47) + 1
        dot: i64 = sview_find_last_byte(p, 46)
        return string_view_slice(p, name_start, dot) if dot > name_start else string_view_suffix(p, name_start)

    # Build `base / leaf` into arena `a` (std::filesystem::path::operator/). Inserts a
    # single `/` separator (no doubled slash if `base` already ends with one); an absolute
    # `leaf` (leading `/`) replaces `base`, as in C++. Allocates, so it takes the arena.
    def join(a: mutable Arena&, base: sview, leaf: sview) -> dstr:
        can Memory.Allocate, Abort.Panic:
            out: mutable dstr = []
            sep: sview = sview("/", 0, -1)
            in a:
                if sview_starts_with(leaf, sep):
                    for ch in leaf:
                        _ = out.push(ch)
                    return out
                for cb in base:
                    _ = out.push(cb)
                if sview_len(base) > 0 and not sview_ends_with(base, sep):
                    _ = out.push(47)
                for cl in leaf:
                    _ = out.push(cl)
            return out
