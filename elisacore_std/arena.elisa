# ============================================================
# Arena allocator - Elisa core runtime dialect
# ============================================================

const ARENA_BACKEND_LIBC_MALLOC = 0
const ARENA_BACKEND_LINUX_MMAP = 1
const ARENA_BACKEND_WIN32_VIRTUALALLOC = 2
const ARENA_BACKEND_WASM_HEAPBASE = 3

# Backend chosen by target OS so the arena never depends on host libc malloc on the
# platforms the emulator targets: POSIX (macOS/Linux/FreeBSD) -> mmap, Windows ->
# VirtualAlloc. This matters because on the x86_64-under-Rosetta substrate, libc malloc
# is unusable from inside guarded guest execution; an mmap-backed arena avoids it.
static if ELISA_TARGET_OS_WINDOWS:
    const ARENA_BACKEND: int = ARENA_BACKEND_WIN32_VIRTUALALLOC
static elif ELISA_TARGET_OS_POSIX:
    const ARENA_BACKEND: int = ARENA_BACKEND_LINUX_MMAP
static else:
    const ARENA_BACKEND: int = ARENA_BACKEND_LIBC_MALLOC

const ARENA_REGION_DEFAULT_CAPACITY: usize = 8 * 1024
const ARENA_WASM_PAGE_SIZE: usize = 64 * 1024

# Per-region strategy stored in Arena.strategy (the surface `region r(N) using <strategy>`).
# This single selector encodes both the block source and the growth/stability behavior,
# mirroring the one-selector surface (docs/68 §3). CHAINED (0) is the default, so a
# zero-initialized Arena keeps the existing linked-block behavior unchanged. These are a
# per-region selector, intentionally distinct from the compile-time ARENA_BACKEND_* above.
#
#   CHAINED        linked mmap blocks; grow by chaining a new block; a single contiguous
#                  allocation cannot span blocks (interior refs invalidated on growth).
#   MALLOC         like CHAINED but blocks come from libc malloc/free (retained block source).
#   RESERVE_COMMIT one contiguous reservation; grow in place by committing pages, so the base
#                  never moves and interior refs stay valid; panic on reservation overflow.
#   FIXED          one block of the given capacity; no growth; panic on overflow.
#   SCRATCH        thread-local scratch pool (interim: behaves as CHAINED until pooled).
const ARENA_STRATEGY_CHAINED: int = 0
const ARENA_STRATEGY_MALLOC: int = 1
const ARENA_STRATEGY_RESERVE_COMMIT: int = 2
const ARENA_STRATEGY_FIXED: int = 3
const ARENA_STRATEGY_SCRATCH: int = 4

# Default reservation (in 8-byte slots) for a reserve_commit arena with no inferred bound (docs/73):
# 256 MiB of contiguous virtual address space, reserved LAZILY on first allocation. Pages commit on
# first touch, so this costs address space, not physical memory; overflowing it panics.
const ARENA_DEFAULT_RESERVE_COMMIT_SLOTS: usize = 33554432

error RuntimeError:
    OutOfMemory

# ------------------------------------------------------------
# Basic low-level types
# ------------------------------------------------------------

struct Region:
    next: mutable heap Region&?
    count: mutable usize
    capacity: mutable usize
    owner_tag: mutable uintptr
    owner_next: mutable heap Region&?
    global_index: mutable usize
    # Bytes physically committed from the block base (Windows reserve_commit/fixed lazy
    # MEM_RESERVE+MEM_COMMIT path); 0 on POSIX/WASM/malloc where the block is fully backed at
    # creation, so arena_region_ensure_committed no-ops there.
    committed: mutable usize
    data: tail uintptr

struct Arena:
    begin:mutable heap Region&?
    end:mutable heap Region&?
    end_index: mutable usize
    # Per-region strategy (ARENA_STRATEGY_*); 0 (CHAINED) for a zero-initialized arena, so
    # existing arenas keep the linked-block path. Set by the region declaration's codegen.
    strategy: mutable int

struct ArenaMark:
    region: heap Region&?
    count: usize

# ------------------------------------------------------------
# Backend FFI declarations
# ------------------------------------------------------------

# malloc/free are declared for every backend: the libc-malloc backend uses them for
# region allocation, and other runtime modules (e.g. concurrency) call malloc directly
# and resolve it via this declaration. Under the mmap/VirtualAlloc backends the arena
# itself does not use them for regions.
extern malloc(size: usize) -> mutable heap void&? can[Memory.Allocate]
extern free(ptr: heap void&) can[Memory.Release]

static if ARENA_BACKEND == ARENA_BACKEND_LINUX_MMAP:
    const ELISA_ARENA_PROT_READ = 0x1
    const ELISA_ARENA_PROT_WRITE = 0x2
    const ELISA_ARENA_MAP_PRIVATE = 0x02
    # MAP_ANON differs by OS: 0x20 on Linux, 0x1000 on macOS/BSD.
    static if ELISA_TARGET_OS_LINUX:
        const ELISA_ARENA_MAP_ANONYMOUS = 0x20
    static else:
        const ELISA_ARENA_MAP_ANONYMOUS = 0x1000

    # uintptr-typed to exactly match the declaration the emulator (guest_exec/tls) uses,
    # so the two declarations dedup to one instead of conflicting as "duplicate mmap".
    extern mmap(addr: uintptr, length: usize, prot: int, flags: int, fd: int, offset: i64) -> uintptr

    extern munmap(addr: heap void&, length: usize) -> int

    # MAP_FAILED is the macro ((void*)-1), NOT a libc function. Compute it instead of
    # declaring a (nonexistent) extern function, which would crash when called.
    def MAP_FAILED() -> uintptr:
        return 0.uintptr() - 1.uintptr()

static elif ARENA_BACKEND == ARENA_BACKEND_WIN32_VIRTUALALLOC:
    const MEM_COMMIT = 0x1000
    const MEM_RESERVE = 0x2000
    const MEM_RELEASE = 0x8000
    const PAGE_READWRITE = 0x04

    extern GetCurrentProcess() -> void&
    extern VirtualAllocEx(
        process: void&,
        address: mutable heap void&?,
        size: usize,
        alloc_type: int,
        protect: int
    ) -> mutable heap void&?

    extern VirtualFreeEx(
        process: void&,
        address: heap void&,
        size: usize,
        free_type: int
    ) -> bool

    # Commit granularity for the lazy reserve_commit/fixed path: pages are committed 64 KiB at a
    # time (a multiple of the 4 KiB page size and equal to the reservation allocation granularity),
    # amortizing the per-allocation MEM_COMMIT syscall.
    const WIN_COMMIT_CHUNK: usize = 65536

    def win_commit_round_up(n: usize) -> usize:
        return ((n + (WIN_COMMIT_CHUNK - 1)) / WIN_COMMIT_CHUNK) * WIN_COMMIT_CHUNK

static elif ARENA_BACKEND == ARENA_BACKEND_WASM_HEAPBASE:
    extern __heap_base: heap u8&
    extern wasm_memory_size(index: int) -> int
    extern wasm_memory_grow(index: int, pages: usize) -> int

    global mutable bump_pointer: heap u8& = __heap_base

# ------------------------------------------------------------
# Small utilities
# ------------------------------------------------------------

def assert(condition: bool):
    can Abort.Panic:
        if not condition:
            panic("assert failed")

def max(a: usize, b: usize) -> usize:
    ensure result >= a
    ensure result >= b
    return a if a > b else b

def min(a: usize, b: usize) -> usize:
    ensure result <= a
    ensure result <= b
    return a if a < b else b

def clamp(x: usize, lo: usize, hi: usize) -> usize:
    requires lo <= hi
    ensure result >= lo
    ensure result <= hi
    if x < lo:
        return lo
    if x > hi:
        return hi
    return x

def inv_handle(ptr: heap void&?) -> bool:
    return ptr == null

@internal
def arena_region_from_raw(raw: heap void&) -> mutable heap Region&:
    trusted Unsafe.PointerCast:
        return raw.cast[mutable heap Region&]

@internal
def arena_region_from_uintptr(raw: uintptr) -> mutable heap Region&:
    trusted Unsafe.PointerCast:
        return raw.cast[mutable heap Region&]

@internal
def arena_heap_void_from_region(r: heap Region&) -> heap void&:
    trusted Unsafe.PointerCast:
        return r.cast[heap void&]

@internal
def arena_mutable_heap_void_from_region(r: heap Region&) -> mutable heap void&?:
    trusted Unsafe.PointerCast:
        return r.cast[mutable heap void&?]

@internal
def arena_heap_u8_from_region_data(r: heap Region&) -> mutable heap u8&:
    trusted [Unsafe.PointerCast, Unsafe.PointerArithmetic]:
        return (r.cast[heap u8&] + size_of(Region)).cast[mutable heap u8&]

@internal
def arena_heap_void_from_data_base(data_base: heap u8&, offset_bytes: usize) -> mutable heap void&:
    trusted [Unsafe.PointerCast, Unsafe.PointerArithmetic]:
        return (data_base + offset_bytes).cast[mutable heap void&]

@internal
def arena_heap_void_from_mutable(ptr: mutable void&) -> mutable heap void&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable heap void&]

@internal
def arena_heap_u8_from_void(ptr: heap void&) -> mutable heap u8&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable heap u8&]

@internal
def arena_heap_void_from_u8(ptr: heap u8&) -> heap void&:
    trusted Unsafe.PointerCast:
        return ptr.cast[heap void&]

@internal
def arena_u8_from_void(ptr: void&) -> u8&:
    trusted Unsafe.PointerCast:
        return ptr.cast[u8&]

@internal
def arena_mutable_u8_from_void(ptr: mutable void&) -> mutable u8&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable u8&]

@internal
def arena_heap_u8_from_alloc(ptr: heap void&) -> mutable heap u8&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable heap u8&]

@internal
def arena_void_from_mutable_u8(ptr: mutable heap u8&) -> mutable void&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable void&]

@internal
def arena_void_from_u8(ptr: u8&) -> void&:
    trusted Unsafe.PointerCast:
        return ptr.cast[void&]

@internal
def arena_nullable_u8_from_heap(ptr: heap u8&) -> u8&?:
    trusted Unsafe.PointerCast:
        return ptr.cast[u8&?]

# ------------------------------------------------------------
# Pointer-state helpers
# ------------------------------------------------------------

def sfree[T](ptr: heap T&) -> heap T!:
    can Memory.Release:
        # Only valid against the libc-malloc backend; mmap/VirtualAlloc regions are released
        # by free_region (which knows the size). Calling libc free on an mmap pointer is UB.
        static if ARENA_BACKEND == ARENA_BACKEND_LIBC_MALLOC:
            trusted [Unsafe.PointerCast, Unsafe.RawExtern]:
                free(ptr.cast[heap void&])
    return null

# ------------------------------------------------------------
# Region allocation / freeing
# ------------------------------------------------------------

def new_region_with_owner(capacity: usize, owner_tag: uintptr) -> mutable heap Region&:
    can Memory.Allocate, Abort.Panic:
        size_bytes: usize = size_of(Region) + size_of(uintptr) * capacity

        static if ARENA_BACKEND == ARENA_BACKEND_LIBC_MALLOC:
            raw: mutable heap void&? = null
            trusted Unsafe.RawExtern:
                raw <- malloc(size_bytes)
            assert raw != null
            r: heap Region& = arena_region_from_raw(raw)

        static elif ARENA_BACKEND == ARENA_BACKEND_LINUX_MMAP:
            raw_addr: mutable uintptr = 0.uintptr()
            trusted Unsafe.RawExtern:
                raw_addr <- mmap(
                    0.uintptr(),
                    size_bytes,
                    ELISA_ARENA_PROT_READ | ELISA_ARENA_PROT_WRITE,
                    ELISA_ARENA_MAP_ANONYMOUS | ELISA_ARENA_MAP_PRIVATE,
                    -1,
                    0
                )
            assert raw_addr != MAP_FAILED()
            assert raw_addr != 0.uintptr()
            r: heap Region& = arena_region_from_uintptr(raw_addr)

        static elif ARENA_BACKEND == ARENA_BACKEND_WIN32_VIRTUALALLOC:
            raw: mutable heap void&? = null
            trusted Unsafe.RawExtern:
                raw <- VirtualAllocEx(
                    GetCurrentProcess(),
                    null,
                    size_bytes,
                    MEM_COMMIT | MEM_RESERVE,
                    PAGE_READWRITE
                )
            assert not inv_handle(raw)
            assert raw != null
            r: heap Region& = arena_region_from_raw(raw)

        static elif ARENA_BACKEND == ARENA_BACKEND_WASM_HEAPBASE:
            r: heap Region& = arena_region_from_raw(arena_heap_void_from_u8(bump_pointer))
            current_memory_size: mutable usize = 0
            trusted Unsafe.RawExtern:
                current_memory_size <- ARENA_WASM_PAGE_SIZE * wasm_memory_size(0).usize()
            desired_memory_size: usize = bump_pointer.usize() + size_bytes

            if desired_memory_size > current_memory_size:
                delta_bytes: usize = desired_memory_size - current_memory_size
                delta_pages: usize = (delta_bytes + (ARENA_WASM_PAGE_SIZE - 1)) / ARENA_WASM_PAGE_SIZE

                grow_result: mutable int = -1
                trusted Unsafe.RawExtern:
                    grow_result <- wasm_memory_grow(0, delta_pages)
                assert grow_result >= 0

            bump_pointer <- bump_pointer + size_bytes

        static else:
            static error("Unknown arena backend")

        r.next <- null
        r.count <- 0
        r.capacity <- capacity
        r.owner_tag <- owner_tag
        r.owner_next <- null
        r.global_index <- 0
        r.committed <- 0
        return r

def new_region(capacity: usize) -> mutable heap Region&:
    return new_region_with_owner(capacity, 0.uintptr()) can Memory.Allocate, Abort.Panic

# A libc-malloc-backed region block, available on every target (malloc/free are declared for
# all backends above). Used by malloc-selected regions regardless of the compile-time default.
@internal
def new_region_malloc(capacity: usize) -> mutable heap Region&:
    can Memory.Allocate, Abort.Panic:
        size_bytes: usize = size_of(Region) + size_of(uintptr) * capacity
        raw: mutable heap void&? = null
        trusted Unsafe.RawExtern:
            raw <- malloc(size_bytes)
        assert raw != null
        r: heap Region& = arena_region_from_raw(raw)
        r.next <- null
        r.count <- 0
        r.capacity <- capacity
        r.owner_tag <- 0.uintptr()
        r.owner_next <- null
        r.global_index <- 0
        r.committed <- 0
        return r

# A reserve-only region block for the reserve_commit/fixed strategies. On Windows the block's
# address range is MEM_RESERVE'd up front (no physical backing) and pages are MEM_COMMIT'd on
# demand by arena_region_ensure_committed as the bump pointer advances — so a large default
# reservation (256 MiB) costs only address space, matching POSIX mmap's demand-paging. On every
# other backend it is identical to new_region (mmap demand-pages, or malloc/eager-commit), and
# the commit-on-demand helper no-ops.
@internal
def new_region_reserve(capacity: usize) -> mutable heap Region&:
    can Memory.Allocate, Abort.Panic:
        static if ARENA_BACKEND == ARENA_BACKEND_WIN32_VIRTUALALLOC:
            size_bytes: usize = size_of(Region) + size_of(uintptr) * capacity
            raw: mutable heap void&? = null
            trusted Unsafe.RawExtern:
                raw <- VirtualAllocEx(
                    GetCurrentProcess(),
                    null,
                    size_bytes,
                    MEM_RESERVE,
                    PAGE_READWRITE
                )
            assert not inv_handle(raw)
            assert raw != null
            # Commit an initial chunk covering the Region header before writing any field.
            initial: usize = win_commit_round_up(size_of(Region) + size_of(uintptr))
            commit_raw: mutable heap void&? = null
            trusted Unsafe.RawExtern:
                commit_raw <- VirtualAllocEx(
                    GetCurrentProcess(),
                    raw,
                    initial,
                    MEM_COMMIT,
                    PAGE_READWRITE
                )
            assert not inv_handle(commit_raw)
            r: heap Region& = arena_region_from_raw(raw)
            r.next <- null
            r.count <- 0
            r.capacity <- capacity
            r.owner_tag <- 0.uintptr()
            r.owner_next <- null
            r.global_index <- 0
            r.committed <- initial
            return r
        static else:
            return new_region(capacity)

# WINDOWS reserve_commit/fixed only: commit (page-in) enough pages so that `needed_bytes` from the
# block base are physically backed, growing the committed watermark in chunks to amortize syscalls.
# Idempotent — re-committing already-committed pages is a no-op per VirtualAlloc. A no-op on every
# other backend (their blocks are fully backed at creation: mmap demand-pages, malloc/eager-commit).
@internal
def arena_region_ensure_committed(r: mutable heap Region&, needed_bytes: usize):
    can Abort.Panic:
        static if ARENA_BACKEND == ARENA_BACKEND_WIN32_VIRTUALALLOC:
            if needed_bytes > r.committed:
                target: mutable usize = win_commit_round_up(needed_bytes)
                full: usize = size_of(Region) + size_of(uintptr) * r.capacity
                if target > full:
                    target <- full
                base: mutable heap void&? = arena_mutable_heap_void_from_region(r)
                commit_raw: mutable heap void&? = null
                trusted Unsafe.RawExtern:
                    commit_raw <- VirtualAllocEx(
                        GetCurrentProcess(),
                        base,
                        target,
                        MEM_COMMIT,
                        PAGE_READWRITE
                    )
                assert not inv_handle(commit_raw)
                r.committed <- target
        static else:
            pass

# Strategy-dispatching region allocator: chooses the block source. MALLOC draws blocks from
# libc malloc; every other strategy (CHAINED/RESERVE_COMMIT/FIXED/SCRATCH) uses the compile-time
# ARENA_BACKEND (mmap/VirtualAlloc), so it is identical to new_region for those.
def new_region_backend(capacity: usize, strategy: int) -> mutable heap Region&:
    can Memory.Allocate, Abort.Panic:
        if strategy == ARENA_STRATEGY_MALLOC:
            return new_region_malloc(capacity)
        # reserve_commit/fixed take a contiguous block that grows in place. On Windows that block
        # is reserved-then-committed-on-demand (new_region_reserve); on POSIX it is a demand-paged
        # mmap (new_region_reserve falls through to new_region there). CHAINED/SCRATCH keep the
        # plain block source.
        if strategy == ARENA_STRATEGY_RESERVE_COMMIT or strategy == ARENA_STRATEGY_FIXED:
            return new_region_reserve(capacity)
        return new_region(capacity)

def free_region(r: heap Region&):
    can Memory.Release, Abort.Panic:
        static if ARENA_BACKEND == ARENA_BACKEND_LIBC_MALLOC:
            trusted Unsafe.RawExtern:
                free(arena_heap_void_from_region(r))

        static elif ARENA_BACKEND == ARENA_BACKEND_LINUX_MMAP:
            size_bytes: usize = size_of(Region) + size_of(uintptr) * r.capacity
            ret: mutable int = 0
            trusted Unsafe.RawExtern:
                ret <- munmap(arena_heap_void_from_region(r), size_bytes)
            assert ret == 0

        static elif ARENA_BACKEND == ARENA_BACKEND_WIN32_VIRTUALALLOC:
            ok: bool = VirtualFreeEx(
                GetCurrentProcess(),
                arena_heap_void_from_region(r),
                0,
                MEM_RELEASE
            )
            assert ok

        static elif ARENA_BACKEND == ARENA_BACKEND_WASM_HEAPBASE:
            pass

# Free a libc-malloc-backed region block (counterpart to new_region_malloc).
@internal
def free_region_malloc(r: heap Region&):
    can Memory.Release, Abort.Panic:
        trusted Unsafe.RawExtern:
            free(arena_heap_void_from_region(r))

# Strategy-dispatching region free. MALLOC frees via libc free (matching new_region_backend's
# MALLOC block source); every other strategy frees via free_region (munmap/VirtualFree).
def free_region_backend(r: heap Region&, strategy: int):
    can Memory.Release, Abort.Panic:
        if strategy == ARENA_STRATEGY_MALLOC:
            free_region_malloc(r)
            return
        trusted Unsafe.RawExtern:
            free_region(r)

def arena_alloc(a: mutable Arena&, size_bytes: usize) -> mutable heap void&:
    can Memory.Allocate, Abort.Panic:
        size: usize = (size_bytes + size_of(uintptr) - 1) / size_of(uintptr)

        # RESERVE_COMMIT / FIXED: one contiguous block, never chained. The block is created
        # up front by the region declaration with the full reservation as its capacity, so
        # allocation just bumps within it (pages commit on first touch under mmap). Overflowing
        # the reservation is a hard error -- chaining a second block would break the contiguous,
        # relocation-free layout the type system relies on, so we panic instead.
        if a.strategy == ARENA_STRATEGY_RESERVE_COMMIT or a.strategy == ARENA_STRATEGY_FIXED:
            # Lazy default reservation (docs/73 §3): a reserve_commit arena whose block has not been
            # created yet reserves its default contiguous range on first touch, so empty/tiny regions
            # cost nothing. FIXED and bounded reserve_commit are reserved up front by the region
            # declaration, so they already have a block here.
            if a.end == null:
                cap: mutable usize = ARENA_DEFAULT_RESERVE_COMMIT_SLOTS
                if cap < size:
                    cap <- size
                a.end as & <- new_region_backend(cap, a.strategy)
                a.begin <- a.end
                a.end_index <- 0
            assert a.end != null
            if a.end.count + size > a.end.capacity:
                panic("region overflow: reservation exhausted (reserve_commit/fixed)")
            data_base: heap u8& = arena_heap_u8_from_region_data(a.end)
            offset_bytes: usize = a.end.count * size_of(uintptr)
            result: heap void& = arena_heap_void_from_data_base(data_base, offset_bytes)
            a.end.count <- a.end.count + size
            # Windows: page-in the bytes this allocation now spans (no-op elsewhere).
            arena_region_ensure_committed(a.end, size_of(Region) + a.end.count * size_of(uintptr))
            return result

        if a.end == null:
            assert a.begin == null

            capacity:mutable usize = ARENA_REGION_DEFAULT_CAPACITY
            if capacity < size:
                capacity <- size

            a.end as & <- new_region_backend(capacity, a.strategy)
            a.begin <- a.end
            a.end_index <- 0
            a.end.global_index <- 0

        assert a.end != null

        trusted Unsafe.AssumeProgress:
            while (a.end.owner_tag != 0.uintptr() or a.end.count + size > a.end.capacity) and a.end.next != null:
                a.end <- a.end.next
                a.end_index <- a.end_index + 1

        if a.end.owner_tag != 0.uintptr() or a.end.count + size > a.end.capacity:
            assert a.end.next == null

            capacity:mutable usize = ARENA_REGION_DEFAULT_CAPACITY
            if capacity < size:
                capacity <- size

            a.end.next as & <- new_region_backend(capacity, a.strategy)
            a.end <- a.end.next
            a.end_index <- a.end_index + 1
            a.end.global_index <- a.end_index

        data_base: heap u8& = arena_heap_u8_from_region_data(a.end)
        offset_bytes: usize = a.end.count * size_of(uintptr)
        result: heap void& = arena_heap_void_from_data_base(data_base, offset_bytes)
        a.end.count <- a.end.count + size
        return result

# Slot offset of an in-region allocation from the region's data base. All pointer->int
# casts are discharged here so callers (arena_realloc) surface no Unsafe effect.
@internal
def arena_tail_offset_slots(data_base: heap u8&, ptr: void&) -> usize:
    trusted Unsafe.PointerCast:
        return (ptr.cast[heap u8&].usize() - data_base.usize()) / size_of(uintptr)

def arena_realloc(a: mutable Arena&, oldptr: mutable void&, oldsz: usize, newsz: usize) -> mutable heap void&:
    can Memory.Allocate, Abort.Panic:
        arena_heap_void_from_mutable(oldptr) return if newsz <= oldsz

        # RESERVE_COMMIT / FIXED grow in place: the base must never move (interior-pointer
        # stability, docs/68 §4). When oldptr is the region's tail allocation we just advance
        # the bump pointer to cover newsz and hand back the SAME pointer -- zero copy, no
        # relocation, pages commit on first touch. Any other case (not the tail, or past the
        # reservation) cannot be honored without moving data, so we panic rather than silently
        # invalidate references the type system already proved stable.
        if a.strategy == ARENA_STRATEGY_RESERVE_COMMIT or a.strategy == ARENA_STRATEGY_FIXED:
            assert a.end != null
            old_slots: usize = (oldsz + size_of(uintptr) - 1) / size_of(uintptr)
            new_slots: usize = (newsz + size_of(uintptr) - 1) / size_of(uintptr)
            data_base: heap u8& = arena_heap_u8_from_region_data(a.end)
            old_offset_slots: usize = arena_tail_offset_slots(data_base, oldptr)
            if old_offset_slots + old_slots == a.end.count:
                if old_offset_slots + new_slots > a.end.capacity:
                    panic("region overflow: reservation exhausted (reserve_commit/fixed grow)")
                a.end.count <- old_offset_slots + new_slots
                # Windows: page-in the bytes the grown tail now spans (no-op elsewhere).
                arena_region_ensure_committed(a.end, size_of(Region) + a.end.count * size_of(uintptr))
                return arena_heap_void_from_mutable(oldptr)
            panic("reserve_commit/fixed array cannot grow in place: not the tail allocation")

        newptr: heap void& = arena_alloc(a, newsz)
        newptr_bytes: heap u8& = arena_heap_u8_from_void(newptr)
        oldptr_bytes: u8& = arena_u8_from_void(oldptr)

        trusted Unsafe.UncheckedIndex:
            for i in 0..<oldsz:
                newptr_bytes[i] <- oldptr_bytes[i]

        return newptr

# ------------------------------------------------------------
# Arena introspection (used by region-backing assertions/tests)
# ------------------------------------------------------------

# Total committed (used) slots across the whole region chain, counted in uintptr
# slots. Walks every region from `begin` regardless of the chained/owner topology,
# so it covers regions split off for packed/SoA store columns too. Read-only — does
# not allocate. Multiply by size_of(uintptr) for a byte figure.
def arena_used_slots(a: mutable Arena&) -> usize:
    total: mutable usize = 0
    cursor: mutable heap Region&? = a.begin
    trusted Unsafe.AssumeProgress:
        while cursor != null:
            total <- total + cursor.count
            cursor <- cursor.next
    return total

# Total committed (used) bytes across the whole region chain.
def arena_used_bytes(a: mutable Arena&) -> usize:
    return arena_used_slots(a) * size_of(uintptr)

# Number of regions (blocks) currently chained into the arena.
def arena_region_count(a: mutable Arena&) -> usize:
    n: mutable usize = 0
    cursor: mutable heap Region&? = a.begin
    trusted Unsafe.AssumeProgress:
        while cursor != null:
            n <- n + 1
            cursor <- cursor.next
    return n

# ------------------------------------------------------------
# Memory/string helpers
# ------------------------------------------------------------

def arena_strlen(s: u8&) -> usize:
    n:mutable usize = 0
    trusted Unsafe.UncheckedIndex:
        trusted Unsafe.AssumeProgress:
            while s[n] != 0:
                n <- n + 1
    return n

def arena_memcpy(dest: mutable void&, src: void&, n: usize) -> mutable void&:
    d: mutable u8& = arena_mutable_u8_from_void(dest)
    s: u8& = arena_u8_from_void(src)

    trusted Unsafe.UncheckedIndex:
        for i in 0..<n:
            d[i] <- s[i]

    return dest

def arena_memeq(lhs: void&, rhs: void&, n: usize) -> bool:
    left: u8& = arena_u8_from_void(lhs)
    right: u8& = arena_u8_from_void(rhs)

    trusted Unsafe.UncheckedIndex:
        for i in 0..<n:
            false return if left[i] != right[i]

    return true

def arena_strdup(a: mutable Arena&, cstr: u8&) -> mutable heap u8&:
    n: usize = arena_strlen(cstr)
    dup: mutable heap u8& = arena_heap_u8_from_alloc(arena_alloc(a, n + 1)) can Memory.Allocate, Abort.Panic
    arena_memcpy(arena_void_from_mutable_u8(dup), arena_void_from_u8(cstr), n)
    trusted Unsafe.UncheckedIndex:
        dup[n] <- 0
    return dup

def arena_memdup(a: mutable Arena&, data: void&, size: usize) -> mutable heap void&:
    dup: mutable heap void& = arena_alloc(a, size) can Memory.Allocate, Abort.Panic
    _ = arena_memcpy(dup, data, size)
    return dup

# ------------------------------------------------------------
# Snapshot / rewind / reset / free / trim
# ------------------------------------------------------------

def arena_snapshot(a: Arena&) -> ArenaMark:
    if a.end == null:
        assert a.begin == null
        return ArenaMark{region: null, count: 0}

    return ArenaMark{region: a.end, count: a.end.count}

def arena_reset(a: mutable Arena&):
    r: mutable heap Region&? = a.begin
    trusted Unsafe.AssumeProgress:
        while r != null:
            r.count <- 0
            r <- r.next

    a.end <- a.begin
    a.end_index <- 0

def arena_rewind(a: mutable Arena&, m: ArenaMark):
    if m.region == null:
        arena_reset(a)
        return

    region: heap Region& = m.region
    region.count <- m.count

    r: mutable heap Region&? = region.next
    trusted Unsafe.AssumeProgress:
        while r != null:
            r.count <- 0
            r <- r.next

    a.end as & <- region

    region_index: mutable usize = 0
    current: mutable heap Region&? = a.begin
    trusted Unsafe.AssumeProgress:
        while current != null and current != region:
            current <- current.next
            region_index <- region_index + 1

    assert current != null
    a.end_index <- region_index

def arena_free(a: mutable Arena&):
    can Memory.Release, Abort.Panic:
        r: mutable heap Region&? = a.begin

        trusted Unsafe.AssumeProgress:
            while r != null:
                r0: mutable heap Region& = r
                r <- r.next
                trusted Unsafe.RawExtern:
                    free_region_backend(r0, a.strategy)

        a.begin as ! <- null
        a.end as ! <- null
        a.end_index <- 0

def arena_trim(a: mutable Arena&):
    can Memory.Release, Abort.Panic:
        if a.end == null:
            return

        r: mutable heap Region&? = a.end.next
        trusted Unsafe.AssumeProgress:
            while r != null:
                r0: mutable heap Region& = r
                r <- r.next
                trusted Unsafe.RawExtern:
                    free_region_backend(r0, a.strategy)

        a.end.next as ! <- null

# Splice an entire child region's block chain onto the parent (docs/67 adopt).
# Zero-copy: the child's blocks (and the data they already hold) are appended to
# the parent's chain and will be freed when the parent is freed. Each adopted
# block is marked owned so the parent's bump allocator skips it and never
# overwrites its data. The child is then emptied, so its own cleanup is a no-op.
# The semantic layer has already proven the child is consumed and that the two
# backings are compatible (so the parent's free can reclaim the adopted blocks).
def arena_adopt(parent: mutable Arena&, child: mutable Arena&):
    if child.begin == null:
        return

    c: mutable heap Region&? = child.begin
    trusted Unsafe.AssumeProgress:
        while c != null:
            c.owner_tag <- 1.uintptr()
            c <- c.next

    if parent.begin == null:
        parent.begin <- child.begin
        parent.end <- child.begin
        parent.end_index <- 0
    else:
        last: mutable heap Region&? = parent.begin
        trusted Unsafe.AssumeProgress:
            while last != null and last.next != null:
                last <- last.next
        if last != null:
            last.next as & <- child.begin

    child.begin as ! <- null
    child.end as ! <- null
    child.end_index <- 0

# ------------------------------------------------------------
# Optional stdio formatting stubs
# ------------------------------------------------------------

extern va_list
extern va_copy(args: va_list) -> va_list
extern va_end(args: va_list)

extern vsnprintf(
    buffer: u8&?,
    buffer_size: usize,
    format: u8&,
    args: va_list
) -> int

def arena_vsprintf(a: mutable Arena&, format: u8&, args: va_list) -> mutable heap u8&:
    can Memory.Allocate, Console.Format, Abort.Panic:
        args_copy: mutable va_list = args
        n: mutable int = -1
        trusted Unsafe.RawExtern:
            args_copy <- va_copy(args)
            n <- vsnprintf(null, 0, format, args_copy)
            va_end(args_copy)

        assert n >= 0

        result: heap u8& = arena_heap_u8_from_alloc(arena_alloc(a, n.usize() + 1))
        trusted Unsafe.RawExtern:
            _ = vsnprintf(arena_nullable_u8_from_heap(result), n.usize() + 1, format, args)
        return result
