# ============================================================
# Collections helpers - Elisa core runtime dialect
# ============================================================

include "./deque.elisa"

extern memset(dest: mutable void&, val: int, n: usize) -> mutable void&

const ARENA_DA_INIT_CAP: usize = 256
const DICT_INIT_CAP: usize = 8

struct DynArray[T]:
    items: mutable T&?
    count: mutable usize
    capacity: mutable usize

struct DynArrayView:
    data: mutable void&?
    len: mutable usize

def view_from_parts[T](data: void&?, len: usize) -> view[T]:
    return DynArrayView{data: data, len: len}

# Open-addressing slot: `state` is 0=empty, 1=occupied, 2=tombstone (deleted, but probing
# must continue past it). A zeroed bucket is therefore an empty slot.
struct DictBucket[K, T]:
    key: mutable K
    value: mutable T
    state: mutable u8

struct DynDict[K, T]:
    items: mutable DictBucket[K, T]&?
    count: mutable usize
    used: mutable usize
    capacity: mutable usize
    arena: mutable Arena&?

struct DictProbeResult:
    index: mutable usize
    found: mutable bool

extern SymbolTableSlot

type SymbolTableId = id[SymbolTableSlot]


def __cast__(value: u32) -> SymbolTableId:
    return value.cast[SymbolTableId]


global SYMBOL_TABLE_INVALID_ID: SymbolTableId = 0.u32().SymbolTableId()


struct SymbolEntry[K, T]:
    key: mutable K
    value: mutable T


struct IndexMapEntry[K, T]:
    key: mutable K
    value: mutable T


struct IndexMap[K, T]:
    owner: mutable Arena&?
    entries: mutable darray[IndexMapEntry[K, T]]
    by_key: mutable dict[K, usize]


struct InlineVec[T, N: usize]:
    owner: mutable Arena&?
    inline_items: mutable T[N]
    overflow: mutable darray[T]
    len: mutable usize
    is_spilled: mutable bool


struct Flags[T]:
    bits: mutable u64


struct IndexMapNamespace:
    _unused: u8


struct InlineVecNamespace:
    _unused: u8


struct FlagsNamespace:
    _unused: u8


global indexmap: IndexMapNamespace = IndexMapNamespace{_unused: 0}
global inlinevec: InlineVecNamespace = InlineVecNamespace{_unused: 0}
global flags: FlagsNamespace = FlagsNamespace{_unused: 0}

@internal
def collections_items_from_alloc[T](ptr: heap void&) -> mutable T&:
    trusted Unsafe.PointerCast:
        return ptr.cast[mutable T&]

@internal
def collections_void_from_items[T](items: T&) -> void&:
    trusted Unsafe.PointerCast:
        return items.cast[void&]

@internal
def collections_mutable_void_from_items[T](items: mutable T&) -> mutable void&:
    trusted Unsafe.PointerCast:
        return items.cast[mutable void&]

@internal
def collections_void_from_items_at[T](items: T&, index: usize) -> void&:
    trusted [Unsafe.PointerCast, Unsafe.PointerArithmetic]:
        return (items + index).cast[void&]

@internal
def collections_mutable_void_from_items_at[T](items: mutable T&, index: usize) -> mutable void&:
    trusted [Unsafe.PointerCast, Unsafe.PointerArithmetic]:
        return (items + index).cast[mutable void&]

@internal
def collections_void_from_data_at(data: void&, offset: usize) -> void&:
    trusted [Unsafe.PointerCast, Unsafe.PointerArithmetic]:
        return (data.cast[u8&] + offset).cast[void&]

@internal
def collections_items_from_data_at[T](data: void&, offset: usize) -> T&:
    trusted [Unsafe.PointerCast, Unsafe.PointerArithmetic]:
        return (data.cast[u8&] + offset).cast[T&]

@internal
def collections_items_from_data[T](data: void&) -> T&:
    trusted Unsafe.PointerCast:
        return data.cast[T&]

@internal
def collections_mutable_items_from_data[T](data: mutable void&) -> mutable T&:
    trusted Unsafe.PointerCast:
        return data.cast[mutable T&]

# Allocate a single zero-initialized T on an arena and return a heap reference
# to it. This is the heap equivalent of `out: mutable T = zeroed`, but it never
# materializes a T-sized value on the stack -- essential for very large
# aggregate types (e.g. the shader IR program) whose by-value stack frame would
# be enormous. The libc memset is used (not the byte-loop cxx_memset) so zeroing
# stays O(1) syscalls rather than O(size) interpreted iterations.
def arena_box_zeroed[T](a: mutable Arena&) -> mutable heap T&:
    can Memory.Allocate, Abort.Panic:
        raw: mutable heap void& = arena_alloc(a, size_of(T))
        trusted Unsafe.RawExtern:
            memset(raw, 0, size_of(T))
        return collections_items_from_alloc[T](raw)

# ------------------------------------------------------------
# Dynamic array helpers (replacement for C macros)
# ------------------------------------------------------------

def arena_da_reserve[T](a: mutable Arena&, da: mutable darray[T, shape_in]&, needed: usize) -> mutable darray[T, shape_out]&:
    can Memory.Allocate, Abort.Panic:
        da return if needed <= da.capacity

        new_capacity: mutable usize = da.capacity
        if new_capacity == 0:
            new_capacity <- ARENA_DA_INIT_CAP

        trusted Unsafe.AssumeProgress:
            while needed > new_capacity:
                new_capacity <- new_capacity * 2

        old_size: usize = da.capacity * size_of(T)
        new_size: usize = new_capacity * size_of(T)

        if da.items == null:
            da.items as & <- collections_items_from_alloc[T](arena_alloc(a, new_size))
        else:
            resized: heap void& = arena_realloc(
                a,
                collections_mutable_void_from_items[T](da.items),
                old_size,
                new_size
            )
            da.items as & <- collections_items_from_alloc[T](resized)

        da.capacity <- new_capacity
        return da

def arena_da_view[T](da: darray[T, shape_in]&, start: usize, end: usize) -> view[T]:
    DynArrayView{data: null, len: 0} return if da.items == null or da.count == 0

    lo: mutable usize = start if start < da.count else da.count
    hi: mutable usize = end if end < da.count else da.count
    if hi < lo:
        hi <- lo

    DynArrayView{data: null, len: 0} return if hi == lo

    return DynArrayView{data: collections_void_from_items_at[T](da.items, lo), len: hi - lo}

def arena_da_view_len[T](view: view[T]) -> usize:
    return view.len

def arena_da_view_slice[T](view: view[T], start: usize, end: usize) -> view[T]:
    elem_size: usize = size_of(T)
    DynArrayView{data: null, len: 0} return if view.data == null or view.len == 0

    lo: mutable usize = start if start < view.len else view.len
    hi: mutable usize = end if end < view.len else view.len
    if hi < lo:
        hi <- lo

    DynArrayView{data: null, len: 0} return if hi == lo

    offset: usize = lo * elem_size
    return DynArrayView{data: collections_void_from_data_at(view.data, offset), len: hi - lo}

def arena_da_view_prefix[T](view: view[T], end: usize) -> view[T]:
    return arena_da_view_slice(view, 0, end)

def arena_da_view_suffix[T](view: view[T], start: usize) -> view[T]:
    return arena_da_view_slice(view, start, view.len)

def arena_da_view_get[T](view: view[T], index: usize) -> T:
    assert index < view.len
    assert view.data != null

    offset: usize = index * size_of(T)
    base: T& = collections_items_from_data_at[T](view.data, offset)
    return base[0]

def arena_da_fill[T](dst: view[T], value: T):
	if dst.len == 0:
		return

	assert dst.data != null

    out: mutable T& = collections_mutable_items_from_data[T](dst.data)
    for i in 0..<dst.len:
		out[i] <- value

def arena_da_copy_exact[T](dst: view[T], src: view[T]):
    assert dst.len == src.len
    if dst.len == 0:
        return

    assert dst.data != null
    assert src.data != null

    out: mutable T& = collections_mutable_items_from_data[T](dst.data)
    src_items: T& = collections_items_from_data[T](src.data)
    for i in 0..<dst.len:
        out[i] <- src_items[i]

def arena_da_eq_exact[T](left: view[T], right: view[T]) -> bool:
    assert left.len == right.len
    true return if left.len == 0

    assert left.data != null
    assert right.data != null

    byte_count: usize = left.len * size_of(T)
    return arena_memeq(left.data, right.data, byte_count)

def arena_da_from_view[T](a: mutable Arena&, view: view[T]) -> darray[T, shape_out]:
    can Memory.Allocate, Abort.Panic:
        zeroed return if view.len == 0

        items: mutable T& = collections_items_from_alloc[T](arena_alloc(a, view.len * size_of(T)))
        assert view.data != null
        arena_memcpy(collections_mutable_void_from_items[T](items), view.data, view.len * size_of(T))

        out: mutable darray[T, shape_out] = zeroed
        out.items as & <- items
        out.count <- view.len
        out.capacity <- view.len
        return out


def darray_view[T](da: darray[T]) -> view[T]:
    DynArrayView{data: null, len: 0} return if da.items == null or da.count == 0
    return DynArrayView{data: collections_void_from_items[T](da.items), len: da.count}


def view[T](da: darray[T]) -> view[T]:
    return darray_view[T](da)


# Build a read-only view over a fixed-size array (T[N]) with no copy and no
# arena. Pass the array by reference, e.g. `array_view(TABLE.ref[u32[N]&])`.
# Works for top-level `const` tables too (they are addressable as read-only
# globals), so a static table can be handed out as a zero-copy slice. Mirrors
# inline_vec_view's inline-buffer path.
def array_view[T, N: usize](arr: T[N]&) -> view[T]:
    DynArrayView{data: null, len: 0} return if N == 0
    trusted Unsafe.UncheckedIndex:
        return DynArrayView{data: collections_void_from_items[T](&arr[0]), len: N}


# ------------------------------------------------------------
# Inline vectors
# ------------------------------------------------------------

def inline_vec[T, N: usize](owner: mutable Arena&) -> InlineVec[T, N]:
    out: mutable InlineVec[T, N] = zeroed
    out.owner as & <- owner
    return out


def new[T, N: usize](api: InlineVecNamespace, owner: mutable Arena&) -> InlineVec[T, N]:
    _ = api
    return inline_vec[T, N](owner)


def inline_vec_count[T, N: usize](vec: InlineVec[T, N]&) -> usize:
    return vec.len


def count[T, N: usize](vec: InlineVec[T, N]&) -> usize:
    return inline_vec_count[T, N](vec)


def inline_vec_is_empty[T, N: usize](vec: InlineVec[T, N]&) -> bool:
    return vec.len == 0


def is_empty[T, N: usize](vec: InlineVec[T, N]&) -> bool:
    return inline_vec_is_empty[T, N](vec)


def inline_vec_spilled[T, N: usize](vec: InlineVec[T, N]&) -> bool:
    return vec.is_spilled


def spilled[T, N: usize](vec: InlineVec[T, N]&) -> bool:
    return inline_vec_spilled[T, N](vec)


def inline_vec_get[T, N: usize](vec: InlineVec[T, N]&, index: usize) -> T:
    assert index < vec.len
    if vec.is_spilled:
        trusted Unsafe.UncheckedIndex:
            return vec.overflow[index]
    trusted Unsafe.UncheckedIndex:
        return vec.inline_items[index]


def get[T, N: usize](vec: InlineVec[T, N]&, index: usize) -> T:
    return inline_vec_get[T, N](vec, index)


def inline_vec_set[T, N: usize](vec: mutable InlineVec[T, N]&, index: usize, item: T):
    assert index < vec.len
    if vec.is_spilled:
        trusted Unsafe.UncheckedIndex:
            vec.overflow[index] <- item
    else:
        trusted Unsafe.UncheckedIndex:
            vec.inline_items[index] <- item


def set[T, N: usize](vec: mutable InlineVec[T, N]&, index: usize, item: T):
    inline_vec_set[T, N](vec, index, item)


def inline_vec_spill[T, N: usize](vec: mutable InlineVec[T, N]&):
    can Memory.Allocate, Abort.Panic:
        if vec.is_spilled:
            return

        assert vec.owner != null
        owner: mutable Arena& = vec.owner
        in owner:
            _ = vec.overflow.reserve(N * 2)
            for index in 0..<vec.len:
                trusted Unsafe.UncheckedIndex:
                    vec.overflow.push(vec.inline_items[index])

        vec.is_spilled <- true


def inline_vec_push[T, N: usize](vec: mutable InlineVec[T, N]&, item: T):
    can Memory.Allocate, Abort.Panic:
        if vec.is_spilled:
            assert vec.owner != null
            owner: mutable Arena& = vec.owner
            in owner:
                vec.overflow.push(item)
            vec.len <- vec.len + 1
            return

        if vec.len < N:
            trusted Unsafe.UncheckedIndex:
                vec.inline_items[vec.len] <- item
            vec.len <- vec.len + 1
            return

        inline_vec_spill[T, N](vec)
        assert vec.owner != null
        owner: mutable Arena& = vec.owner
        in owner:
            vec.overflow.push(item)
        vec.len <- vec.len + 1


def push[T, N: usize](vec: mutable InlineVec[T, N]&, item: T):
    can Memory.Allocate, Abort.Panic:
        inline_vec_push[T, N](vec, item)


def inline_vec_pop[T, N: usize](vec: mutable InlineVec[T, N]&) -> T:
    assert vec.len > 0
    vec.len <- vec.len - 1
    if vec.is_spilled:
        vec.overflow.count <- vec.len
        trusted Unsafe.UncheckedIndex:
            return vec.overflow[vec.len]
    trusted Unsafe.UncheckedIndex:
        return vec.inline_items[vec.len]


def pop[T, N: usize](vec: mutable InlineVec[T, N]&) -> T:
    return inline_vec_pop[T, N](vec)


def inline_vec_last[T, N: usize](vec: InlineVec[T, N]&) -> T:
    assert vec.len > 0
    return inline_vec_get[T, N](vec, vec.len - 1)


def last[T, N: usize](vec: InlineVec[T, N]&) -> T:
    return inline_vec_last[T, N](vec)


def inline_vec_view[T, N: usize](vec: InlineVec[T, N]&) -> view[T]:
    DynArrayView{data: null, len: 0} return if vec.len == 0
    if vec.is_spilled:
        assert vec.overflow.items != null
        return DynArrayView{data: collections_void_from_items[T](vec.overflow.items), len: vec.len}
    trusted Unsafe.UncheckedIndex:
        return DynArrayView{data: collections_void_from_items[T](&vec.inline_items[0]), len: vec.len}


def view[T, N: usize](vec: InlineVec[T, N]&) -> view[T]:
    return inline_vec_view[T, N](vec)


def inline_vec_clear[T, N: usize](vec: mutable InlineVec[T, N]&):
    if vec.is_spilled:
        vec.overflow.count <- 0
    vec.len <- 0
    vec.is_spilled <- false


def clear[T, N: usize](vec: mutable InlineVec[T, N]&):
    inline_vec_clear[T, N](vec)


# ------------------------------------------------------------
# Typed enum flags
# ------------------------------------------------------------

def flags_new[T](api: FlagsNamespace) -> Flags[T]:
    _ = api
    result: Flags[T] = zeroed
    return result


def new[T](api: FlagsNamespace) -> Flags[T]:
    return flags_new[T](api)


def flags_empty[T]() -> Flags[T]:
    result: Flags[T] = zeroed
    return result


def flags_from_bits[T](bits: u64) -> Flags[T]:
    result: mutable Flags[T] = zeroed
    result.bits <- bits
    return result


def flags_bits[T](items: Flags[T]&) -> u64:
    return items.bits


def bits[T](items: Flags[T]&) -> u64:
    return flags_bits[T](items)


def flags_mask[T](value: T) -> u64:
    index: u64 = value.u64()
    assert index < 64
    return 1.u64() << index.u32()


def flags_has[T](items: Flags[T]&, value: T) -> bool:
    return (items.bits & flags_mask[T](value)) != 0


def has[T](items: Flags[T]&, value: T) -> bool:
    return flags_has[T](items, value)


def flags_add[T](items: mutable Flags[T]&, value: T):
    items.bits <- items.bits | flags_mask[T](value)


def add[T](items: mutable Flags[T]&, value: T):
    flags_add[T](items, value)


def flags_remove[T](items: mutable Flags[T]&, value: T):
    items.bits <- items.bits & ~flags_mask[T](value)


def remove[T](items: mutable Flags[T]&, value: T):
    flags_remove[T](items, value)


def flags_set[T](items: mutable Flags[T]&, value: T, enabled: bool):
    if enabled:
        items.add(value)
    else:
        items.remove(value)


def flags_clear[T](items: mutable Flags[T]&):
    items.bits <- 0


def flags_any[T](items: Flags[T]&) -> bool:
    return items.bits != 0


def flags_union[T](left: Flags[T]&, right: Flags[T]&) -> Flags[T]:
    return flags_from_bits[T](left.bits | right.bits)


def flags_intersection[T](left: Flags[T]&, right: Flags[T]&) -> Flags[T]:
    return flags_from_bits[T](left.bits & right.bits)


def flags_difference[T](left: Flags[T]&, right: Flags[T]&) -> Flags[T]:
    return flags_from_bits[T](left.bits & ~right.bits)


def arena_da_append[T](a: mutable Arena&, da: mutable darray[T, shape_in]&, item: T) -> mutable darray[T, shape_out]&:
    can Memory.Allocate, Abort.Panic:
        in a:
            _ = da.reserve(da.count + 1)

        assert da.items != null

        da.items[da.count] <- item
        da.count <- da.count + 1
        return da

def darray_pop[T](da: mutable darray[T]&) -> T:
    can Abort.Panic:
        assert da.count > 0
        da.count <- da.count - 1
        return da[da.count]

def pop[T](da: mutable darray[T]&) -> T:
    can Abort.Panic:
        trusted Unsafe.UncheckedIndex:
            return darray_pop[T](da)

def darray_remove_at[T](da: mutable darray[T]&, index: usize) -> T:
    can Abort.Panic:
        assert index < da.count
        removed: T = da[index]
        next: mutable usize = index + 1
        trusted Unsafe.AssumeProgress:
            while next < da.count:
                da[next - 1] <- da[next]
                next <- next + 1
        da.count <- da.count - 1
        return removed

def remove_at[T](da: mutable darray[T]&, index: usize) -> T:
    can Abort.Panic:
        trusted Unsafe.UncheckedIndex:
            return darray_remove_at[T](da, index)

# Read-only range algorithms (no allocation). The predicate is a pure
# `func(T) -> bool`, so a named function or a `lambda` works. These replace
# hand-rolled scan loops and transliterate std::any_of / all_of / count_if /
# find_if directly (`v.any_of(pred)` reads as `std::any_of(v..., pred)`).
def any_of[T](da: darray[T], pred: func(T) -> bool) -> bool:
    for x in da:
        if pred(x):
            return true
    return false

def all_of[T](da: darray[T], pred: func(T) -> bool) -> bool:
    for x in da:
        if not pred(x):
            return false
    return true

def count_if[T](da: darray[T], pred: func(T) -> bool) -> usize:
    n: mutable usize = 0
    for x in da:
        if pred(x):
            n <- n + 1
    return n

# Returns the first element satisfying `pred`, or `null` if none does
# (std::find_if, returning the element rather than an iterator).
def find_if[T](da: darray[T], pred: func(T) -> bool) -> T?:
    for x in da:
        if pred(x):
            return x
    return null

# Comparator-based ordering algorithms (the C++ idiom: a strict-weak-ordering
# `less(a, b)`, not a `T`-level `<`, so they stay generic without operator
# overloading). All in-place / allocation-free.

# Internal heapsort sift-down used by `sort`.
def darray_sift_down[T](da: mutable darray[T]&, less: func(T, T) -> bool, start: usize, end: usize):
    can Abort.Panic:
        root: mutable usize = start
        trusted Unsafe.AssumeProgress:
            while true:
                child: usize = root * 2 + 1
                if child >= end:
                    return
                largest: mutable usize = root
                if less(da[largest], da[child]):
                    largest <- child
                if child + 1 < end and less(da[largest], da[child + 1]):
                    largest <- child + 1
                if largest == root:
                    return
                tmp: T = da[root]
                da[root] <- da[largest]
                da[largest] <- tmp
                root <- largest

# In-place sort ascending by `less` (std::sort). O(n log n) heapsort, no allocation.
def sort[T](da: mutable darray[T]&, less: func(T, T) -> bool):
    can Abort.Panic:
        n: usize = da.count
        if n < 2:
            return
        i: mutable usize = n / 2
        trusted Unsafe.AssumeProgress:
            while i > 0:
                i <- i - 1
                trusted Unsafe.UncheckedIndex:
                    darray_sift_down[T](da, less, i, n)
        e: mutable usize = n
        trusted Unsafe.AssumeProgress:
            while e > 1:
                e <- e - 1
                tmp: T = da[0]
                da[0] <- da[e]
                da[e] <- tmp
                trusted Unsafe.UncheckedIndex:
                    darray_sift_down[T](da, less, 0, e)

# Reverse the elements in place (std::reverse).
def reverse[T](da: mutable darray[T]&):
    n: usize = da.count
    if n < 2:
        return
    i: mutable usize = 0
    j: mutable usize = n - 1
    trusted Unsafe.AssumeProgress:
        while i < j:
            tmp: T = da[i]
            da[i] <- da[j]
            da[j] <- tmp
            i <- i + 1
            j <- j - 1

# True if no element compares `less` than its predecessor (std::is_sorted).
def is_sorted[T](da: darray[T], less: func(T, T) -> bool) -> bool:
    i: mutable usize = 1
    trusted Unsafe.AssumeProgress:
        while i < da.count:
            if less(da[i], da[i - 1]):
                return false
            i <- i + 1
    return true

# Smallest / largest element by `less`, or `null` if empty (std::min_element /
# std::max_element, returning the element rather than an iterator).
def min_element[T](da: darray[T], less: func(T, T) -> bool) -> T?:
    if da.count == 0:
        return null
    best: mutable T = da[0]
    i: mutable usize = 1
    trusted Unsafe.AssumeProgress:
        while i < da.count:
            if less(da[i], best):
                best <- da[i]
            i <- i + 1
    return best

def max_element[T](da: darray[T], less: func(T, T) -> bool) -> T?:
    if da.count == 0:
        return null
    best: mutable T = da[0]
    i: mutable usize = 1
    trusted Unsafe.AssumeProgress:
        while i < da.count:
            if less(best, da[i]):
                best <- da[i]
            i <- i + 1
    return best

# Binary-search lookups over a range already sorted by the same `less`
# (std::lower_bound / std::binary_search). O(log n).
def lower_bound[T](da: darray[T], target: T, less: func(T, T) -> bool) -> usize:
    lo: mutable usize = 0
    hi: mutable usize = da.count
    trusted Unsafe.AssumeProgress:
        while lo < hi:
            mid: usize = lo + (hi - lo) / 2
            if less(da[mid], target):
                lo <- mid + 1
            else:
                hi <- mid
    return lo

def binary_search[T](da: darray[T], target: T, less: func(T, T) -> bool) -> bool:
    idx: mutable usize = 0
    trusted Unsafe.UncheckedIndex:
        idx <- da.lower_bound(target, less)
    if idx >= da.count:
        return false
    return not less(target, da[idx])

def arena_da_append_many[T](a: mutable Arena&, da: mutable darray[T, shape_in]&, new_items: T&, new_items_count: usize) -> mutable darray[T, shape_out]&:
    can Memory.Allocate, Abort.Panic:
        needed: usize = da.count + new_items_count

        if needed > da.capacity:
            new_capacity: mutable usize = da.capacity
            if new_capacity == 0:
                new_capacity <- ARENA_DA_INIT_CAP

            trusted Unsafe.AssumeProgress:
                while needed > new_capacity:
                    new_capacity <- new_capacity * 2

            old_size: usize = da.capacity * size_of(T)
            new_size: usize = new_capacity * size_of(T)

            if da.items == null:
                da.items as & <- collections_items_from_alloc[T](arena_alloc(a, new_size))
            else:
                resized: heap void& = arena_realloc(
                    a,
                    collections_mutable_void_from_items[T](da.items),
                    old_size,
                    new_size
                )
                da.items as & <- collections_items_from_alloc[T](resized)

            da.capacity <- new_capacity

        assert da.items != null

        arena_memcpy(
            collections_mutable_void_from_items_at[T](da.items, da.count),
            collections_void_from_items[T](new_items),
            new_items_count * size_of(T)
        )

        da.count <- da.count + new_items_count
        return da

def arena_sb_append_buf(a: mutable Arena&, sb: mutable darray[u8, shape_in]&, buf: u8&, n: usize) -> mutable darray[u8, shape_out]&:
    return arena_da_append_many(a, sb, buf, n) can Memory.Allocate, Abort.Panic

def arena_sb_append_cstr(a: mutable Arena&, sb: mutable darray[u8, shape_in]&, cstr: u8&) -> mutable darray[u8, shape_out]&:
    n: usize = arena_strlen(cstr)
    return arena_da_append_many(a, sb, cstr, n) can Memory.Allocate, Abort.Panic

def arena_sb_append_null(a: mutable Arena&, sb: mutable darray[u8, shape_in]&) -> mutable darray[u8, shape_out]&:
    can Memory.Allocate, Abort.Panic:
        in a:
            return sb.extend([0.u8()])

# ------------------------------------------------------------
# Dictionary helpers
# ------------------------------------------------------------

def arena_dict_next_capacity(min_capacity: usize) -> usize:
    0 return if min_capacity == 0

    cap: mutable usize = DICT_INIT_CAP
    trusted Unsafe.AssumeProgress:
        while cap < min_capacity:
            cap <- cap * 2
    return cap

# Key hashing for the open-addressing dict. The `ctx_hash_value` builtin (compiler-emitted)
# dispatches on the concrete key type after monomorphization: a cstr hashes its CONTENT via
# ctx_hash_cstr (FNV-1a), every fixed-size scalar key (integer/bool/char/const enum) is
# zero-extended to u64 and finalized by ctx_hash_u64 (splitmix64). Both are deterministic and
# defined here as plain functions the builtin lowers to.
def ctx_hash_cstr(s: cstr) -> u64:
    # FNV-1a over the string content (self-contained so collections.elisa needs no string
    # module). Matches hash_sview; deterministic and content-based (not pointer-based).
    h: mutable u64 = 0xcbf29ce484222325
    for ch in s[0:s.len]:
        h <- h ^ ch.u64()
        h <- h * 0x100000001b3
    return h

def ctx_hash_u64(value: u64) -> u64:
    h: mutable u64 = value
    h <- (h ^ (h >> 30)) * 0xbf58476d1ce4e5b9
    h <- (h ^ (h >> 27)) * 0x94d049bb133111eb
    h <- h ^ (h >> 31)
    return h

# Open-addressing probe (linear probing over a power-of-2 table). Returns found=true with the
# slot of the matching occupied entry, or found=false with the slot to insert at: the first
# tombstone seen (slot reuse), else the terminating empty slot. O(1) expected with load < 3/4.
def arena_dict_find_index[K, T](m: dict[K, T]&, key: K) -> DictProbeResult:
    DictProbeResult{index: 0, found: false} return if m.capacity == 0 or m.items == null

    assert m.items != null
    items: DictBucket[K, T]& = m.items
    mask: usize = m.capacity - 1
    slot: mutable usize = ctx_hash_value(key).usize() & mask
    insert_slot: mutable usize = m.capacity   # sentinel: no reusable slot seen yet
    probed: mutable usize = 0
    trusted Unsafe.AssumeProgress:
        while probed < m.capacity:
            st: u8 = items[slot].state
            if st == 0:
                final_slot: usize = slot if insert_slot == m.capacity else insert_slot
                return DictProbeResult{index: final_slot, found: false}
            if st == 1 and items[slot].key == key:
                return DictProbeResult{index: slot, found: true}
            if st == 2 and insert_slot == m.capacity:
                insert_slot <- slot
            slot <- (slot + 1.usize()) & mask
            probed <- probed + 1.usize()
    DictProbeResult{index: insert_slot, found: false} return if insert_slot != m.capacity
    return DictProbeResult{index: 0, found: false}

# Place (key, value) into a table that is known to have room and to not already contain `key`
# (used by rehash). The probe terminates at an empty slot since the fresh table has no tombstones.
def arena_dict_place_fresh[K, T](m: mutable dict[K, T]&, key: K, value: T) -> void:
    assert m.items != null
    items: mutable DictBucket[K, T]& = m.items
    probe: DictProbeResult = arena_dict_find_index(m, key)
    items[probe.index].key <- key
    items[probe.index].value <- value
    items[probe.index].state <- 1
    m.count <- m.count + 1.usize()
    m.used <- m.used + 1.usize()

def arena_dict_zero_buckets[K, T](items: mutable DictBucket[K, T]&, capacity: usize):
    view: view[DictBucket[K, T]] = DynArrayView{data: collections_void_from_items[DictBucket[K, T]](items), len: capacity}
    arena_da_fill(view, zeroed)

def arena_dict_new[K, T](a: mutable Arena&, initial_capacity: usize) -> dict[K, T]:
    can Memory.Allocate, Abort.Panic:
        out: mutable dict[K, T] = zeroed
        out.arena as & <- a

        capacity: usize = arena_dict_next_capacity(initial_capacity)
        out return if capacity == 0

        items: mutable DictBucket[K, T]& = collections_items_from_alloc[DictBucket[K, T]](arena_alloc(a, capacity * size_of(DictBucket[K, T])))
        arena_dict_zero_buckets(items, capacity)

        out.items as & <- items
        out.capacity <- capacity
        return out

def arena_dict_reserve[K, T](a: mutable Arena&, m: mutable dict[K, T]&, min_capacity: usize) -> void error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
        target_capacity: usize = arena_dict_next_capacity(min_capacity)
        if target_capacity == 0:
            return

        if target_capacity <= m.capacity:
            return

        owner: mutable Arena& = m.arena if m.arena != null else a
        if m.arena == null:
            m.arena as & <- owner

        old_items_opt: mutable DictBucket[K, T]&? = m.items
        old_capacity: usize = m.capacity

        new_items: mutable DictBucket[K, T]& = collections_items_from_alloc[DictBucket[K, T]](arena_alloc(owner, target_capacity * size_of(DictBucket[K, T])))
        arena_dict_zero_buckets(new_items, target_capacity)

        # Switch to the fresh table, then re-probe every live entry into it. Rehashing drops
        # tombstones, so `used` is reset to the live count as entries are placed.
        m.items as & <- new_items
        m.capacity <- target_capacity
        m.count <- 0.usize()
        m.used <- 0.usize()

        if old_items_opt != null and old_capacity > 0:
            old_items: mutable DictBucket[K, T]& = old_items_opt
            for i in 0..<old_capacity:
                if old_items[i].state == 1:
                    arena_dict_place_fresh(m, old_items[i].key, old_items[i].value)
        return

def arena_dict_get[K, T](m: dict[K, T]&, key: K) -> T&?:
	null return if m.count == 0 or m.items == null

	probe: DictProbeResult = arena_dict_find_index(m, key)
	null return if not probe.found

	assert m.items != null
	items: DictBucket[K, T]& = m.items
	return &items[probe.index].value

@internal
def arena_dict_get_mut[K, T](m: mutable dict[K, T]&, key: K) -> mutable T&?:
	null return if m.count == 0 or m.items == null

	probe: DictProbeResult = arena_dict_find_index(m, key)
	null return if not probe.found

	assert m.items != null
	items: mutable DictBucket[K, T]& = m.items
	return &items[probe.index].value

def arena_dict_get[K, T](m: mutable dict[K, T]&, key: K) -> mutable T&?:
	return arena_dict_get_mut(m, key)

def arena_dict_put[K, T](a: mutable Arena&, m: mutable dict[K, T]&, key: K, value: T) -> mutable T&? error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = m.arena if m.arena != null else a
        if m.arena == null:
            m.arena as & <- owner

        # Grow before probing when the load (occupied + tombstones) would exceed 3/4, so a probe
        # always terminates at an empty slot. Growing rehashes and clears tombstones.
        if m.capacity == 0 or (m.used + 1.usize()) * 4.usize() > m.capacity * 3.usize():
            target_capacity: usize = DICT_INIT_CAP if m.capacity == 0 else m.capacity * 2
            try arena_dict_reserve(owner, m, target_capacity)

        assert m.items != null
        assert m.capacity > 0

        items: mutable DictBucket[K, T]& = m.items
        probe: DictProbeResult = arena_dict_find_index(m, key)
        if probe.found:
            items[probe.index].value <- value
            return &items[probe.index].value

        reused_tombstone: bool = items[probe.index].state == 2
        items[probe.index].key <- key
        items[probe.index].value <- value
        items[probe.index].state <- 1
        m.count <- m.count + 1.usize()
        if not reused_tombstone:
            m.used <- m.used + 1.usize()
        return &items[probe.index].value

def arena_dict_get_or_insert[K, T](a: mutable Arena&, m: mutable dict[K, T]&, key: K, value: T) -> mutable T&? error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
		existing: mutable T&? = arena_dict_get_mut(m, key)
        existing return if existing != null
        return try arena_dict_put(a, m, key, value)

# Non-error wrappers used by the dict-entry codegen ABI (`d.entry(k).insert(v)`
# / `.get_or_insert(v)`). The entry ops run under `can Abort.Panic`, so a growth
# OOM surfaces as null rather than an error-union the hand-rolled call site would
# have to thread. These keep the codegen call shape simple: a plain nullable
# value ref (`mutable T&?` -> nullable ptr), no sret/error-tag ABI.
def arena_dict_put_checked[K, T](a: mutable Arena&, m: mutable dict[K, T]&, key: K, value: T) -> T&?:
    can Memory.Allocate, Abort.Panic:
        return try arena_dict_put(a, m, key, value) else null

def arena_dict_get_or_insert_checked[K, T](a: mutable Arena&, m: mutable dict[K, T]&, key: K, value: T) -> T&?:
    can Memory.Allocate, Abort.Panic:
        return try arena_dict_get_or_insert(a, m, key, value) else null

def arena_dict_reserve_checked[K, T](a: mutable Arena&, m: mutable dict[K, T]&, min_capacity: usize) -> void:
    can Memory.Allocate, Abort.Panic:
        catch arena_dict_reserve(a, m, min_capacity):
            ok:
                return
            error e:
                return

# Panic-on-failure wrappers: the frictionless default surface for `d.put`/`.get_or_insert`/
# `.reserve` (dict parity with darray push). darray push panics on allocation failure and
# surfaces no error union; these give dict the same shape. A growth OOM is unrecoverable in
# the common in-region case, so it aborts rather than forcing every call site to thread an
# error union. These are invoked only from the backend's synthetic `dict.put`/`.get_or_insert`/
# `.reserve` lowering (dictMutationHelperName), which carries no effect of its own — exactly
# like darray push — so `d.put(k, v)` needs no `can` grant. Callers who want to RECOVER from
# OOM use the error-returning arena_dict_put directly.
def arena_dict_put_or_panic[K, T](a: mutable Arena&, m: mutable dict[K, T]&, key: K, value: T) -> T&?:
    can Memory.Allocate, Abort.Panic:
        catch arena_dict_put(a, m, key, value):
            slot:
                return slot
            error e:
                panic("dict put: allocation failed")

def arena_dict_get_or_insert_or_panic[K, T](a: mutable Arena&, m: mutable dict[K, T]&, key: K, value: T) -> T&?:
    can Memory.Allocate, Abort.Panic:
        catch arena_dict_get_or_insert(a, m, key, value):
            slot:
                return slot
            error e:
                panic("dict get_or_insert: allocation failed")

def arena_dict_reserve_or_panic[K, T](a: mutable Arena&, m: mutable dict[K, T]&, min_capacity: usize) -> void:
    can Memory.Allocate, Abort.Panic:
        catch arena_dict_reserve(a, m, min_capacity):
            ok:
                return
            error e:
                panic("dict reserve: allocation failed")

def arena_dict_contains[K, T](m: dict[K, T]&, key: K) -> bool:
    return arena_dict_get(m, key) != null

def arena_dict_remove[K, T](m: mutable dict[K, T]&, key: K) -> bool:
    false return if m.count == 0 or m.items == null

    probe: DictProbeResult = arena_dict_find_index(m, key)
    false return if not probe.found

    assert m.items != null
    items: mutable DictBucket[K, T]& = m.items
    # Tombstone the slot (state 2): it stays non-empty so probes for entries that collided past
    # it still reach them. `used` is unchanged; the slot is reclaimed on the next rehash.
    items[probe.index] <- zeroed
    items[probe.index].state <- 2
    m.count <- m.count - 1.usize()
    return true

def arena_dict_clear[K, T](m: mutable dict[K, T]&):
    if m.items == null or m.capacity == 0:
        m.count <- 0
        m.used <- 0
        return

    assert m.items != null
    items: DictBucket[K, T]& = m.items
    arena_dict_zero_buckets(items, m.capacity)
    m.count <- 0
    m.used <- 0

def arena_dict_new__i64(a: mutable Arena&, initial_capacity: usize) -> dict[cstr[key_shape], i64]:
    return arena_dict_new[cstr[key_shape], i64](a, initial_capacity) can Memory.Allocate, Abort.Panic

def arena_dict_reserve__i64(a: mutable Arena&, m: mutable dict[cstr[key_shape], i64]&, min_capacity: usize) -> void error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
        try arena_dict_reserve[cstr[key_shape], i64](a, m, min_capacity)

def arena_dict_get__i64(m: dict[cstr[key_shape], i64]&, key: cstr[key_shape]) -> i64&?:
	return arena_dict_get[cstr[key_shape], i64](m, key)

def arena_dict_get_mut__i64(m: mutable dict[cstr[key_shape], i64]&, key: cstr[key_shape]) -> mutable i64&?:
	return arena_dict_get_mut[cstr[key_shape], i64](m, key)

def arena_dict_put__i64(a: mutable Arena&, m: mutable dict[cstr[key_shape], i64]&, key: cstr[key_shape], value: i64) -> mutable i64&? error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
        return try arena_dict_put[cstr[key_shape], i64](a, m, key, value)

def arena_dict_get_or_insert__i64(a: mutable Arena&, m: mutable dict[cstr[key_shape], i64]&, key: cstr[key_shape], value: i64) -> mutable i64&? error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
        return try arena_dict_get_or_insert[cstr[key_shape], i64](a, m, key, value)

def arena_dict_contains__i64(m: dict[cstr[key_shape], i64]&, key: cstr[key_shape]) -> bool:
    return arena_dict_contains[cstr[key_shape], i64](m, key)

def arena_dict_remove__i64(m: mutable dict[cstr[key_shape], i64]&, key: cstr[key_shape]) -> bool:
    return arena_dict_remove[cstr[key_shape], i64](m, key)

def arena_dict_clear__i64(m: mutable dict[cstr[key_shape], i64]&):
    arena_dict_clear[cstr[key_shape], i64](m)


# ------------------------------------------------------------
# Set helpers
# ------------------------------------------------------------

def arena_set_find_index[T](s: set[T]&, key: T) -> DictProbeResult:
    DictProbeResult{index: 0, found: false} return if s.capacity == 0 or s.items == null

    assert s.items != null
    items: SetBucket[T]& = s.items
    mask: usize = s.capacity - 1
    slot: mutable usize = ctx_hash_value(key).usize() & mask
    insert_slot: mutable usize = s.capacity
    probed: mutable usize = 0
    trusted Unsafe.AssumeProgress:
        while probed < s.capacity:
            st: u8 = items[slot].state
            if st == 0:
                final_slot: usize = slot if insert_slot == s.capacity else insert_slot
                return DictProbeResult{index: final_slot, found: false}
            if st == 1 and items[slot].key == key:
                return DictProbeResult{index: slot, found: true}
            if st == 2 and insert_slot == s.capacity:
                insert_slot <- slot
            slot <- (slot + 1.usize()) & mask
            probed <- probed + 1.usize()
    DictProbeResult{index: insert_slot, found: false} return if insert_slot != s.capacity
    return DictProbeResult{index: 0, found: false}

def arena_set_place_fresh[T](s: mutable set[T]&, key: T) -> void:
    assert s.items != null
    items: mutable SetBucket[T]& = s.items
    probe: DictProbeResult = arena_set_find_index(s, key)
    items[probe.index].key <- key
    items[probe.index].state <- 1
    s.count <- s.count + 1.usize()
    s.used <- s.used + 1.usize()

def arena_set_zero_buckets[T](items: mutable SetBucket[T]&, capacity: usize):
    view: view[SetBucket[T]] = DynArrayView{data: collections_void_from_items[SetBucket[T]](items), len: capacity}
    arena_da_fill(view, zeroed)

def arena_set_new[T](a: mutable Arena&, initial_capacity: usize) -> set[T]:
    can Memory.Allocate, Abort.Panic:
        out: mutable set[T] = zeroed
        out.arena as & <- a

        capacity: usize = arena_dict_next_capacity(initial_capacity)
        out return if capacity == 0

        items: mutable SetBucket[T]& = collections_items_from_alloc[SetBucket[T]](arena_alloc(a, capacity * size_of(SetBucket[T])))
        arena_set_zero_buckets(items, capacity)

        out.items as & <- items
        out.capacity <- capacity
        return out

def arena_set_reserve[T](a: mutable Arena&, s: mutable set[T]&, min_capacity: usize) -> void error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
        target_capacity: usize = arena_dict_next_capacity(min_capacity)
        if target_capacity == 0:
            return

        if target_capacity <= s.capacity:
            return

        owner: mutable Arena& = s.arena if s.arena != null else a
        if s.arena == null:
            s.arena as & <- owner

        old_items_opt: mutable SetBucket[T]&? = s.items
        old_capacity: usize = s.capacity

        new_items: mutable SetBucket[T]& = collections_items_from_alloc[SetBucket[T]](arena_alloc(owner, target_capacity * size_of(SetBucket[T])))
        arena_set_zero_buckets(new_items, target_capacity)

        s.items as & <- new_items
        s.capacity <- target_capacity
        s.count <- 0.usize()
        s.used <- 0.usize()

        if old_items_opt != null and old_capacity > 0:
            old_items: mutable SetBucket[T]& = old_items_opt
            for i in 0..<old_capacity:
                if old_items[i].state == 1:
                    arena_set_place_fresh(s, old_items[i].key)
        return

def arena_set_add[T](a: mutable Arena&, s: mutable set[T]&, key: T) -> bool error[RuntimeError]:
    can Memory.Allocate, Abort.Panic:
        owner: mutable Arena& = s.arena if s.arena != null else a
        if s.arena == null:
            s.arena as & <- owner

        if s.capacity == 0 or (s.used + 1.usize()) * 4.usize() > s.capacity * 3.usize():
            target_capacity: usize = DICT_INIT_CAP if s.capacity == 0 else s.capacity * 2
            try arena_set_reserve(owner, s, target_capacity)

        assert s.items != null
        assert s.capacity > 0

        items: mutable SetBucket[T]& = s.items
        probe: DictProbeResult = arena_set_find_index(s, key)
        false return if probe.found

        reused_tombstone: bool = items[probe.index].state == 2
        items[probe.index].key <- key
        items[probe.index].state <- 1
        s.count <- s.count + 1.usize()
        if not reused_tombstone:
            s.used <- s.used + 1.usize()
        return true

def arena_set_add_or_panic[T](a: mutable Arena&, s: mutable set[T]&, key: T) -> bool:
    can Memory.Allocate, Abort.Panic:
        catch arena_set_add(a, s, key):
            inserted:
                return inserted
            error e:
                panic("set add: allocation failed")

def arena_set_reserve_or_panic[T](a: mutable Arena&, s: mutable set[T]&, min_capacity: usize) -> void:
    can Memory.Allocate, Abort.Panic:
        catch arena_set_reserve(a, s, min_capacity):
            ok:
                return
            error e:
                panic("set reserve: allocation failed")

def arena_set_contains[T](s: set[T]&, key: T) -> bool:
    false return if s.count == 0 or s.items == null
    probe: DictProbeResult = arena_set_find_index(s, key)
    return probe.found

def contains[T](s: set[T]&, key: T) -> bool:
    return arena_set_contains[T](s, key)

def has[T](s: set[T]&, key: T) -> bool:
    return arena_set_contains[T](s, key)

def arena_set_remove[T](s: mutable set[T]&, key: T) -> bool:
    false return if s.count == 0 or s.items == null

    probe: DictProbeResult = arena_set_find_index(s, key)
    false return if not probe.found

    assert s.items != null
    items: mutable SetBucket[T]& = s.items
    items[probe.index] <- zeroed
    items[probe.index].state <- 2
    s.count <- s.count - 1.usize()
    return true

def remove[T](s: mutable set[T]&, key: T) -> bool:
    return arena_set_remove[T](s, key)

def arena_set_clear[T](s: mutable set[T]&):
    if s.items == null or s.capacity == 0:
        s.count <- 0
        s.used <- 0
        return

    assert s.items != null
    items: mutable SetBucket[T]& = s.items
    arena_set_zero_buckets(items, s.capacity)
    s.count <- 0
    s.used <- 0

def clear[T](s: mutable set[T]&):
    arena_set_clear[T](s)


# ------------------------------------------------------------
# Ordered index maps
# ------------------------------------------------------------

def index_map[K, T](owner: mutable Arena&, initial_capacity: usize) -> IndexMap[K, T]:
    can Memory.Allocate, Abort.Panic:
        map: mutable IndexMap[K, T] = zeroed
        map.owner as & <- owner
        map.by_key <- arena_dict_new[K, usize](owner, initial_capacity)
        in owner:
            _ = map.entries.reserve(initial_capacity)
        return map


def index_map_new[K, T](owner: mutable Arena&) -> IndexMap[K, T]:
    can Memory.Allocate, Abort.Panic:
        return index_map[K, T](owner, 32)


def new[K, T](api: IndexMapNamespace, owner: mutable Arena&) -> IndexMap[K, T]:
    can Memory.Allocate, Abort.Panic:
        _ = api
        return index_map_new[K, T](owner)


def index_map_with_capacity[K, T](owner: mutable Arena&, initial_capacity: usize) -> IndexMap[K, T]:
    can Memory.Allocate, Abort.Panic:
        return index_map[K, T](owner, initial_capacity)


def with_capacity[K, T](api: IndexMapNamespace, owner: mutable Arena&, initial_capacity: usize) -> IndexMap[K, T]:
    can Memory.Allocate, Abort.Panic:
        _ = api
        return index_map_with_capacity[K, T](owner, initial_capacity)


def index_map_count[K, T](map: IndexMap[K, T]&) -> usize:
    return map.entries.count


def count[K, T](map: IndexMap[K, T]&) -> usize:
    return index_map_count[K, T](map)


def index_map_valid_index[K, T](map: IndexMap[K, T]&, index: usize) -> bool:
    return index < map.entries.count


def index_map_find_index[K, T](map: IndexMap[K, T]&, key: K) -> usize?:
	found: usize&? = arena_dict_get[K, usize](map.by_key, key)
    null return if found == null
    trusted Unsafe.UncheckedIndex:
        return found[0]


def index_map_contains[K, T](map: IndexMap[K, T]&, key: K) -> bool:
    return index_map_find_index[K, T](map, key) != null


def index_map_entry[K, T](map: IndexMap[K, T]&, index: usize) -> IndexMapEntry[K, T]:
    assert index < map.entries.count
    return map.entries[index]


def index_map_value[K, T](map: IndexMap[K, T]&, index: usize) -> T:
    return index_map_entry[K, T](map, index).value


def index_map_entries[K, T](map: IndexMap[K, T]&) -> view[IndexMapEntry[K, T]]:
    return map.entries.view()


def entry[K, T](map: IndexMap[K, T]&, index: usize) -> IndexMapEntry[K, T]:
    return index_map_entry[K, T](map, index)


def value[K, T](map: IndexMap[K, T]&, index: usize) -> T:
    return index_map_value[K, T](map, index)


def entry_view[K, T](map: IndexMap[K, T]&) -> view[IndexMapEntry[K, T]]:
    return index_map_entries[K, T](map)


def index_map_put[K, T](map: mutable IndexMap[K, T]&, key: K, value: T) -> usize:
    can Memory.Allocate, Abort.Panic:
        match index_map_find_index[K, T](map, key):
            null:
                pass
            existing_index:
                assert existing_index < map.entries.count
                map.entries[existing_index].value <- value
                return existing_index

        assert map.owner != null
        owner: mutable Arena& = map.owner
        index: usize = map.entries.count
        in owner:
            map.entries.push(IndexMapEntry[K, T]{key: key, value: value})
        _ = try arena_dict_put[K, usize](owner, map.by_key, key, index) else null
        return index


def put[K, T](map: mutable IndexMap[K, T]&, key: K, value: T) -> usize:
    can Memory.Allocate, Abort.Panic:
        return index_map_put[K, T](map, key, value)


def index_map_set[K, T](map: mutable IndexMap[K, T]&, key: K, value: T) -> usize:
    can Memory.Allocate, Abort.Panic:
        return index_map_put[K, T](map, key, value)


def set[K, T](map: mutable IndexMap[K, T]&, key: K, value: T) -> usize:
    can Memory.Allocate, Abort.Panic:
        return index_map_set[K, T](map, key, value)


def index_map_get[K, T](map: IndexMap[K, T]&, key: K) -> T?:
    index: usize = get index_map_find_index[K, T](map, key) else return null
    value: T = index_map_value[K, T](map, index)
    return value


def get[K, T](map: IndexMap[K, T]&, key: K) -> T?:
    return index_map_get[K, T](map, key)


def index_map_has[K, T](map: IndexMap[K, T]&, key: K) -> bool:
    return index_map_contains[K, T](map, key)


def has[K, T](map: IndexMap[K, T]&, key: K) -> bool:
    return index_map_has[K, T](map, key)


def update_at[K, T](map: mutable IndexMap[K, T]&, index: usize, value: T) -> bool:
    false return if not index_map_valid_index[K, T](map, index)
    assert index < map.entries.count
    map.entries[index].value <- value
    return true


def clear[K, T](map: mutable IndexMap[K, T]&):
    map.entries.count <- 0
    arena_dict_clear[K, usize](map.by_key)


# ------------------------------------------------------------
# Symbol tables
# ------------------------------------------------------------

def symbol_table_index(symbol_id: SymbolTableId) -> usize:
    assert symbol_id != SYMBOL_TABLE_INVALID_ID
    return (!symbol_id).usize() - 1


def symbol_table_id_from_index(index: usize) -> SymbolTableId:
    return (index + 1).u32().SymbolTableId()


# --- Store / Handle unification (docs/69) -----------------------------------
# `Store` is the shared surface over every handle-into-store container: a handle
# resolves to an element, and the store has a size. darray is the first backing
# (Handle = usize index); dict/pool/packed stores implement the same interface
# with their own Handle representations. Layout/provenance/usage stay orthogonal:
# the core surface is read + size only and says nothing about growth or ownership.
protocol Store:
    type Elem
    type Handle
    def store_get(s: Self&, h: Handle) -> Elem&
    def store_count(s: Self&) -> usize

impl[T] Store for darray[T]:
    type Elem = T
    type Handle = usize
    def store_get(s: darray[T]&, h: usize) -> T&:
        return s[h]
    def store_count(s: darray[T]&) -> usize:
        return s.count

# Deque is a second Store backing: a ring buffer rather than a contiguous darray, yet the
# same surface — a usize handle resolves to an element and there's a count. arena_deque_at
# maps the logical handle through the ring's head/wrap. (Deque comes from the include above.)
impl[T] Store for Deque[T]:
    type Elem = T
    type Handle = usize
    def store_get(s: Deque[T]&, h: usize) -> T&:
        return arena_deque_at(s, h)
    def store_count(s: Deque[T]&) -> usize:
        return arena_deque_len(s)


# --- KeyedStore: the partial-lookup sub-protocol (docs/69) ----------------------
# Some stores are addressed by a KEY that may or may not be present, so their lookup is
# partial: `store_find` returns an optional element rather than the total `store_get`. This
# is the orthogonality the core Store preserves — dict is keyed/partial, not a total
# handle→element store, so it implements KeyedStore instead of distorting the core.
protocol KeyedStore:
    type Key
    type Elem
    def store_find(s: Self&, k: Key) -> Elem&?
    def store_count(s: Self&) -> usize

impl[K, T] KeyedStore for dict[K, T]:
    type Key = K
    type Elem = T
    def store_find(s: dict[K, T]&, k: K) -> T&?:
        return arena_dict_get(s, k)
    def store_count(s: dict[K, T]&) -> usize:
        return s.count
